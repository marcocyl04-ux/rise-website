{
  "redirects": [
    {
      "source": "/nutrition",
      "destination": "/portal/tracker",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/nutrition/(.*)",
      "destination": "https://rise-nutrition-v2.vercel.app/$1"
    },
    {
      "source": "/portal/tracker",
      "destination": "https://rise-nutrition-v2.vercel.app/portal/tracker"
    },
    {
      "source": "/portal/tracker/(.*)",
      "destination": "https://rise-nutrition-v2.vercel.app/portal/tracker/$1"
    }
  ]
}
