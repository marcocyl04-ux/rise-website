{
  "redirects": [
    {
      "source": "/nutrition",
      "destination": "/portal/tracker",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/nutrition/(.*)",
      "destination": "https://rise-nutrition-v2.vercel.app/$1"
    },
    {
      "source": "/portal",
      "destination": "https://rise-nutrition-v2.vercel.app/portal"
    },
    {
      "source": "/portal/(.*)",
      "destination": "https://rise-nutrition-v2.vercel.app/portal/$1"
    },
    {
      "source": "/install-guide",
      "destination": "https://rise-nutrition-v2.vercel.app/install-guide"
    },
    {
      "source": "/install-guide/(.*)",
      "destination": "https://rise-nutrition-v2.vercel.app/install-guide/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Content-Security-Policy-Report-Only", "value": "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net https://challenges.cloudflare.com https://*.supabase.co 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https://*.supabase.co data: blob:; connect-src 'self' https://*.supabase.co https://openrouter.ai https://generativelanguage.googleapis.com wss://*.supabase.co; frame-src https://challenges.cloudflare.com" }
      ]
    }
  ]
}
