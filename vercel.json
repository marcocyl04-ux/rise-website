{
  "redirects": [
    {
      "source": "/nutrition",
      "destination": "/portal/tracker",
      "permanent": false
    },
    {
      "source": "/nutrition/",
      "destination": "/portal/tracker",
      "permanent": false
    },
    {
      "source": "/portal/brain",
      "destination": "/portal/",
      "permanent": false
    },
    {
      "source": "/portal/brain/(.*)",
      "destination": "/portal/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/nutrition/(.*)",
      "destination": "https://rise-nutrition-v2.vercel.app/$1"
    },
    {
      "source": "/portal",
      "destination": "https://rise-nutrition-v2.vercel.app/portal"
    },
    {
      "source": "/portal/(.*)",
      "destination": "https://rise-nutrition-v2.vercel.app/portal/$1"
    },
    {
      "source": "/install-guide",
      "destination": "https://rise-nutrition-v2.vercel.app/install-guide"
    },
    {
      "source": "/install-guide/(.*)",
      "destination": "https://rise-nutrition-v2.vercel.app/install-guide/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.woff2",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|gif|svg|webp|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://challenges.cloudflare.com https://*.supabase.co https://rise-nutrition-v2.vercel.app 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://rise-nutrition-v2.vercel.app; font-src 'self' https://fonts.gstatic.com https://rise-nutrition-v2.vercel.app; img-src 'self' https://*.supabase.co data: blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://accounts.google.com https://*.googleapis.com; frame-src https://challenges.cloudflare.com; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self' https://*.supabase.co https://accounts.google.com"
        }
      ]
    }
  ]
}
