---
// Portal dashboard — entry point for authenticated users (RISE Website).
// After extraction: brain access only. Nutrition tracker is in rise-nutrition.
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<BaseLayout title="Portal" description="Your RISE Advancement portal — access the marketing brain.">
  <Header slot="header" />

  <!-- Loading state while we check auth -->
  <section id="portal-loading" class="portal-loading">
    <div class="portal-spinner" aria-hidden="true"></div>
  </section>

  <!-- Floating lang toggle -->
  <button id="portal-lang-toggle" class="portal-lang-toggle" type="button" aria-label="Toggle language">中文</button>

  <!-- Unauthed prompt -->
  <section id="portal-anon" class="portal-anon section" hidden>
    <div class="container portal-narrow">
      <h1 class="portal-anon-title" data-i18n="common.signInToPortal">Sign in to your portal</h1>
      <p class="portal-anon-sub">
        Access the RISE marketing brain.
      </p>
      <div class="portal-anon-actions">
        <button class="btn-primary" type="button" data-open-auth data-i18n="common.signupOrLogin">Log in / Sign up</button>
        <a class="btn-ghost" href="/" data-i18n="common.backToHome">Back to home</a>
      </div>
    </div>
  </section>

  <!-- Authed dashboard -->
  <section id="portal-dashboard" class="portal-dashboard section" hidden>
    <div class="container">
      <header class="portal-header">
        <div class="portal-header-top">
          <p class="portal-eyebrow" data-i18n="portal.eyebrow">RISE Portal</p>
          <button type="button" class="portal-logout-btn" id="portal-logout-btn" data-i18n="common.logout">Log out</button>
        </div>
        <h1 class="portal-title" id="portal-hello" data-i18n="portal.welcome">Welcome</h1>
        <p class="portal-sub" data-i18n="portal.subPick">Pick a tool to get started.</p>
      </header>

      <h2 class="portal-section-title">Your tools</h2>
      <div class="portal-grid">
        <!-- Nutrition Tracker — visible to all authenticated users -->
        <a class="portal-card portal-card-active" href="/portal/tracker" id="portal-tracker-card">
          <div class="portal-card-icon" aria-hidden="true" style="background: rgba(34,197,94,0.1); color: #16a34a">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z" />
              <path d="M12 6v6l4 2" />
            </svg>
          </div>
          <div class="portal-card-body">
            <h3 class="portal-card-title" data-i18n="portal.card.tracker.title">Nutrition Tracker</h3>
            <p class="portal-card-desc" data-i18n="portal.card.tracker.desc">Log protein, track meals, hit your daily target.</p>
          </div>
          <span class="portal-card-arrow" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M7 4l6 6-6 6" /></svg>
          </span>
        </a>

        <!-- Marketing Brain — founder only -->
        <a class="portal-card portal-card-active" href="/portal/brain" id="portal-brain-card" hidden>
          <div class="portal-card-icon" aria-hidden="true" style="background: rgba(211,25,31,0.1); color: var(--rise-red)">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2a7 7 0 0 1 7 7c0 2.4-1.2 4.5-3 5.7V17a1 1 0 0 1-1 1h-6a1 1 0 0 1-1-1v-2.3C6.2 13.5 5 11.4 5 9a7 7 0 0 1 7-7z" />
              <path d="M9 21h6" /><path d="M10 17v4" /><path d="M14 17v4" />
            </svg>
          </div>
          <div class="portal-card-body">
            <h3 class="portal-card-title">Marketing Brain</h3>
            <p class="portal-card-desc">Strategic marketing intelligence engine.</p>
          </div>
          <span class="portal-card-arrow" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M7 4l6 6-6 6" /></svg>
          </span>
        </a>

        <!-- Coach Dashboard — coach + founder -->
        <a class="portal-card portal-card-active" href="/portal/coach" id="portal-coach-card" hidden>
          <div class="portal-card-icon" aria-hidden="true" style="background: rgba(211,25,31,0.1); color: var(--rise-red)">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
          </div>
          <div class="portal-card-body">
            <h3 class="portal-card-title">Coach Dashboard</h3>
            <p class="portal-card-desc">Monitor your team's nutrition and progress.</p>
          </div>
          <span class="portal-card-arrow" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M7 4l6 6-6 6" /></svg>
          </span>
        </a>

        <!-- Security Dashboard — visible to all (page itself is role-gated) -->
        <a class="portal-card portal-card-active" href="/portal/admin" id="portal-admin-card">
          <div class="portal-card-icon" aria-hidden="true" style="background: rgba(211,25,31,0.1); color: var(--rise-red)">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /><circle cx="12" cy="16" r="1" />
            </svg>
          </div>
          <div class="portal-card-body">
            <h3 class="portal-card-title">Security Dashboard</h3>
            <p class="portal-card-desc">Admin controls, invite codes, and audit logs.</p>
          </div>
          <span class="portal-card-arrow" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M7 4l6 6-6 6" /></svg>
          </span>
        </a>

        <!-- Install App — visible to all authenticated users (hidden when already standalone) -->
        <a class="portal-card portal-card-active" href="/portal/install" id="portal-install-card">
          <div class="portal-card-icon" aria-hidden="true" style="background: rgba(59,130,246,0.1); color: #2563eb">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3v12m0 0l-4-4m4 4l4-4M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2" />
            </svg>
          </div>
          <div class="portal-card-body">
            <h3 class="portal-card-title">Get the App</h3>
            <p class="portal-card-desc">Add RISE to your home screen for quick access.</p>
          </div>
          <span class="portal-card-arrow" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M7 4l6 6-6 6" /></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style is:global>
  .lang-toggle { display: none !important; }
</style>

<style>
  .portal-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
  }
  .portal-spinner {
    width: 32px;
    height: 32px;
    border: 3px solid var(--rise-neutral-100);
    border-top-color: var(--rise-red);
    border-radius: 50%;
    animation: portal-spin 0.8s linear infinite;
  }
  @keyframes portal-spin { to { transform: rotate(360deg); } }

  .portal-anon {
    min-height: 60vh;
    display: flex;
    align-items: center;
    text-align: center;
  }
  .portal-narrow { max-width: 520px; }
  .portal-anon-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 2.8rem);
    color: var(--rise-black);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 0 0 var(--space-3);
  }
  .portal-anon-sub {
    font-family: var(--font-body);
    color: var(--rise-neutral-500);
    font-size: 1rem;
    line-height: 1.6;
    margin: 0 0 var(--space-6);
  }
  .portal-anon-actions {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary, .btn-ghost {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    border: 1px solid transparent;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .btn-primary {
    background: var(--rise-red);
    color: var(--rise-white);
  }
  .btn-primary:hover {
    background: var(--rise-red-dark);
    text-decoration: none;
  }
  .btn-ghost {
    background: transparent;
    color: var(--rise-neutral-700);
    border-color: var(--rise-neutral-200);
  }
  .btn-ghost:hover {
    border-color: var(--rise-red);
    color: var(--rise-red);
    text-decoration: none;
  }

  .portal-dashboard {
    padding: var(--space-12) 0;
  }

  .portal-header {
    margin-bottom: var(--space-8);
  }
  .portal-header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-2);
  }
  .portal-eyebrow {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--rise-red);
    margin: 0;
  }
  .portal-logout-btn {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--rise-neutral-500);
    background: none;
    border: 1px solid var(--rise-neutral-200);
    border-radius: 999px;
    padding: 4px 12px;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }
  .portal-logout-btn:hover {
    color: var(--rise-red);
    border-color: var(--rise-red);
  }
  .portal-title {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--rise-black);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 0 0 var(--space-2);
  }
  .portal-sub {
    font-family: var(--font-body);
    color: var(--rise-neutral-500);
    font-size: 1rem;
    margin: 0;
  }

  .portal-section-title {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--rise-neutral-400);
    margin: 0 0 var(--space-4);
  }

  .portal-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 640px) {
    .portal-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .portal-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-4);
    background: var(--rise-white);
    border: 1px solid var(--rise-neutral-100);
    border-radius: 12px;
    padding: var(--space-5);
    text-decoration: none;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
    color: inherit;
  }
  .portal-card-active:hover {
    border-color: var(--rise-red);
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(18, 18, 18, 0.08);
    text-decoration: none;
  }
  .portal-card-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 10px;
    background: var(--rise-red-light);
    color: var(--rise-red);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .portal-card-body { flex: 1; }
  .portal-card-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--rise-black);
    margin: 0 0 4px;
  }
  .portal-card-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--rise-neutral-500);
    margin: 0;
    line-height: 1.5;
  }
  .portal-card-arrow {
    color: var(--rise-neutral-300);
    transition: color 0.15s, transform 0.15s;
  }
  .portal-card-active:hover .portal-card-arrow {
    color: var(--rise-red);
    transform: translateX(2px);
  }

  .portal-card-disabled {
    opacity: 0.55;
    cursor: default;
    pointer-events: none;
  }
  .portal-card-coming {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--rise-neutral-400);
    background: var(--rise-neutral-100);
    border-radius: 999px;
    padding: 2px 8px;
    margin-top: 6px;
  }

  .portal-lang-toggle {
    position: fixed;
    top: 12px;
    right: 12px;
    z-index: 50;
    background: var(--rise-white);
    border: 1px solid var(--rise-neutral-200);
    color: var(--rise-neutral-700);
    border-radius: 999px;
    padding: 6px 12px;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    box-shadow: 0 2px 6px rgba(0,0,0,0.06);
    transition: border-color 0.15s, color 0.15s;
  }
  .portal-lang-toggle:hover {
    border-color: var(--rise-red);
    color: var(--rise-red);
  }
  @media (min-width: 640px) {
    .portal-lang-toggle { top: 16px; right: 16px; }
  }
</style>

<script>
  import { getLang, setLang, getTranslation, translations, type Lang } from "../../lib/i18n";

  function currentName(): string {
    return (window as any).__riseFirstName || "";
  }

  function applyTranslations() {
    const lang = getLang();
    (window as any).__t = translations[lang];

    document.querySelectorAll<HTMLElement>("[data-i18n]").forEach((el) => {
      const key = el.getAttribute("data-i18n");
      if (!key) return;
      if (el.id === "portal-hello") return;
      el.textContent = getTranslation(lang, key);
    });

    const hello = document.getElementById("portal-hello");
    const first = currentName();
    if (hello) {
      const base = getTranslation(lang, "portal.welcome");
      hello.textContent = first ? `${base}, ${first}` : base;
    }

    const toggle = document.getElementById("portal-lang-toggle");
    if (toggle) {
      toggle.textContent = lang === "zh" ? getTranslation("en", "lang.toggle.en") : getTranslation("zh", "lang.toggle.zh");
    }

    document.documentElement.setAttribute("lang", lang === "zh" ? "zh-HK" : "en");
  }

  function wireLangToggle() {
    const btn = document.getElementById("portal-lang-toggle");
    if (!btn) return;
    btn.addEventListener("click", () => {
      const next: Lang = getLang() === "zh" ? "en" : "zh";
      setLang(next);
      applyTranslations();
    });
  }

  function deriveDisplayName(user: any): string {
    if (!user) return "user";
    const meta = user.user_metadata || {};
    return (meta.full_name || meta.name || user.email?.split("@")[0] || "user").trim();
  }

  async function initPortal() {
    const sb = (window as any).supabaseClient;
    if (!sb) {
      setTimeout(initPortal, 100);
      return;
    }

    const loading = document.getElementById("portal-loading");
    const anon = document.getElementById("portal-anon");
    const dash = document.getElementById("portal-dashboard");

    const { data: { session } } = await sb.auth.getSession();

    if (!session) {
      loading?.setAttribute("hidden", "");
      anon?.removeAttribute("hidden");
      applyTranslations();
      sb.auth.onAuthStateChange((_e: string, s: any) => {
        if (s) window.location.reload();
      });
      return;
    }

    const user = session.user;

    // Load profile for hello message
    const { data: profile } = await sb
      .from("user_profiles")
      .select("full_name, role")
      .eq("id", user.id)
      .maybeSingle();

    // Role-based routing: single-tool roles skip the portal hub.
    // Athletes → tracker (their only tool)
    if (profile?.role === "athlete") {
      window.location.replace("/portal/tracker");
      return;
    }
    // Coaches → coach dashboard (their primary view)
    if (profile?.role === "coach") {
      window.location.replace("/portal/coach");
      return;
    }
    // Founders see everything: Tracker, Coach Dashboard, Brain
    if (profile?.role === "founder") {
      const brainCard = document.getElementById("portal-brain-card");
      if (brainCard) brainCard.removeAttribute("hidden");
      const coachCard = document.getElementById("portal-coach-card");
      if (coachCard) coachCard.removeAttribute("hidden");
    }

    // Hide "Get the App" card when already running as installed PWA
    const isStandalone = (window.matchMedia && window.matchMedia("(display-mode: standalone)").matches) || (navigator as any).standalone === true;
    if (isStandalone) {
      const installCard = document.getElementById("portal-install-card");
      if (installCard) installCard.setAttribute("hidden", "");
    }

    const name = profile?.full_name || deriveDisplayName(user);
    const firstName = name.split(" ")[0];
    (window as any).__riseFirstName = firstName;

    loading?.setAttribute("hidden", "");
    dash?.removeAttribute("hidden");
    applyTranslations();
  }

  applyTranslations();
  wireLangToggle();
  initPortal();

  document.getElementById("portal-logout-btn")?.addEventListener("click", async () => {
    const sb = (window as any).supabaseClient;
    if (sb) await sb.auth.signOut();
    window.location.href = "/";
  });
</script>
