    font-size: 0.8rem;
    color: var(--rise-neutral-500);
    font-weight: 400;
    margin-left: 4px;
  }
</style>

<script>
  import { getLang, setLang, getTranslation, translations, type Lang } from "../../lib/i18n";

  // ===== i18n helpers =====
  function t(key: string, params?: Record<string, string | number>): string {
    let s = getTranslation(getLang(), key);
    if (params) {
      for (const k in params) s = s.replace(`{${k}}`, String(params[k]));
    }
    return s;
  }
  function isZh(): boolean { return getLang() === "zh"; }
  // Display name for a food item, preferring zh when lang=zh and name_zh available.
  function foodDisplayName(item: { name: string; name_zh?: string | null }): string {
    if (isZh() && item.name_zh && typeof item.name_zh === "string" && item.name_zh.trim()) return item.name_zh;
    return item.name;
  }

  // ===== Types =====
  type Profile = {
    id: string;
    email: string | null;
    full_name: string | null;
    team_id: string | null;
    role?: string | null;
    timezone?: string | null;
  };
  type Baseline = {
    user_id: string;
    weight_kg: number;
    height_cm: number | null;
    age: number;
    growth_rate: string;
    primary_goal: string;
    protein_target_g: number;
  };
  type Weight = { user_id: string; logged_date: string; weight_kg: number };
  type Meal = {
    id: string;
    user_id: string;
    meal_slot: string;
    logged_date: string;
    total_protein_g: number;
    total_calories_kcal: number;
    total_fat_g: number;
    total_sugar_g: number;
    food_items: any;
    ai_feedback: string | null;
    created_at: string;
  };
  type AlertSpec = {
    level: "red" | "yellow";
    key: string;
    params?: Record<string, string | number>;
  };
  type Athlete = {
    profile: Profile;
    baseline: Baseline | null;
    weights: Weight[]; // newest first
    meals: Meal[]; // newest first
    status: "green" | "yellow" | "red";
    mealsToday: number;
    proteinToday: number;
    mealsYesterday: number;
    weightLatest: Weight | null;
    weightTrend: "up" | "down" | "flat" | null;
    weightTrendValue: number; // signed kg change vs 7d ago
    lastActive: Date | null;
    alerts: AlertSpec[];
  };

  // ===== Date helpers (timezone-aware) =====
  // Build a local "today" YYYY-MM-DD string for a given IANA timezone.
  function tzTodayISO(tz: string): string {
    const parts = new Intl.DateTimeFormat("en-CA", {
      timeZone: tz,
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
    }).formatToParts(new Date());
    const y = parts.find((p) => p.type === "year")!.value;
    const m = parts.find((p) => p.type === "month")!.value;
    const d = parts.find((p) => p.type === "day")!.value;
    return `${y}-${m}-${d}`;
  }
  function isoToDate(iso: string): Date {
    const [y, m, d] = iso.split("-").map(Number);
    return new Date(y, m - 1, d);
  }
  function dateToISO(d: Date): string {
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, "0");
    const day = String(d.getDate()).padStart(2, "0");
    return `${y}-${m}-${day}`;
  }
  function addDaysISO(iso: string, n: number): string {
    const d = isoToDate(iso);
    d.setDate(d.getDate() + n);
    return dateToISO(d);
  }
  function formatDateLong(date: Date) {
    return date.toLocaleDateString(undefined, {
      weekday: "long",
      month: "short",
      day: "numeric",
    });
  }
  function formatRelativeAgo(d: Date | null): string {
    if (!d) return t("coach.relative.never");
    const now = new Date();
    const diffMs = now.getTime() - d.getTime();
    const mins = Math.floor(diffMs / 60000);
    if (mins < 1) return t("coach.relative.justNow");
    if (mins < 60) return t("coach.relative.minAgo", { n: mins });
    const hrs = Math.floor(mins / 60);
    if (hrs < 24) return t("coach.relative.hrAgo", { n: hrs });
    const days = Math.floor(hrs / 24);
    if (days === 1) return t("coach.relative.yesterday");
    if (days < 7) return t("coach.relative.daysAgo", { n: days });
    if (days < 14) return t("coach.relative.lastWeek");
    return d.toLocaleDateString(undefined, { month: "short", day: "numeric" });
  }
  function formatDateShort(date: Date) {
    return date.toLocaleDateString(undefined, { weekday: "short", month: "short", day: "numeric" });
  }

  // Coach's own "today" (browser timezone) for display/header only.
  const COACH_TZ = Intl.DateTimeFormat().resolvedOptions().timeZone;
  const TODAY = tzTodayISO(COACH_TZ);

  // ===== Data fetching =====
  async function loadCoachData(sb: any, coachTeamId: string): Promise<Athlete[]> {
    // First, fetch the athlete profiles to get the athlete IDs.
    const profilesRes = await sb
      .from("user_profiles")
      .select("id, email, full_name, team_id, role, timezone")
      .eq("team_id", coachTeamId)
      .eq("role", "athlete");

    if (profilesRes.error) {
      console.warn("coach profiles", profilesRes.error);
      return [];
    }

    const profiles = (profilesRes.data ?? []) as Profile[];
    if (profiles.length === 0) return [];

    const athleteIds = profiles.map((p) => p.id);

    // Fetch related data scoped to these athletes (defense-in-depth).
    const [baselinesRes, weightsRes, mealsRes] = await Promise.all([
      sb
        .from("baseline_intake")
        .select("user_id, weight_kg, height_cm, age, growth_rate, primary_goal, protein_target_g")
        .in("user_id", athleteIds),
      sb
        .from("daily_weight")
        .select("user_id, logged_date, weight_kg")
        .in("user_id", athleteIds)
        .order("logged_date", { ascending: false }),
      sb
        .from("meal_logs")
        .select("id, user_id, meal_slot, logged_date, total_protein_g, total_calories_kcal, total_fat_g, total_sugar_g, food_items, ai_feedback, created_at")
        .in("user_id", athleteIds)
        .order("created_at", { ascending: false })
        .limit(500),
    ]);

    const baselines = (baselinesRes.data ?? []) as Baseline[];
    const weights = (weightsRes.data ?? []) as Weight[];
    const meals = (mealsRes.data ?? []) as Meal[];

    return profiles.map((p) => {
      const baseline = baselines.find((b) => b.user_id === p.id) || null;
      const aWeights = weights.filter((w) => w.user_id === p.id);
      const aMeals = meals.filter((m) => m.user_id === p.id);

      // Per-athlete "today" based on their stored timezone (falls back to HK).
      const athleteTz = p.timezone || "Asia/Hong_Kong";
      const today = tzTodayISO(athleteTz);
      const yesterday = addDaysISO(today, -1);
      const sevenDaysAgo = addDaysISO(today, -7);

      // Today / yesterday counts
      const todayMeals = aMeals.filter((m) => m.logged_date === today);
      const yesterdayMeals = aMeals.filter((m) => m.logged_date === yesterday);
      const mealsToday = todayMeals.length;
      const mealsYesterday = yesterdayMeals.length;
      const proteinToday = todayMeals.reduce(
        (s, m) => s + Number(m.total_protein_g || 0),
        0
      );

      // Last activity = most recent meal created_at OR most recent weight created_at
      const lastMealAt = aMeals[0]?.created_at ? new Date(aMeals[0].created_at) : null;
      // weights don't have created_at sort key; fall back to logged_date
      const lastWeightDay = aWeights[0]?.logged_date ? isoToDate(aWeights[0].logged_date) : null;
      let lastActive: Date | null = null;
      if (lastMealAt && lastWeightDay) {
        lastActive = lastMealAt > lastWeightDay ? lastMealAt : lastWeightDay;
      } else {
        lastActive = lastMealAt || lastWeightDay;
      }

      // Weight trend over the most recent 7 days (compare latest to ~7d ago)
      const weightLatest = aWeights[0] || null;
      let weightTrend: "up" | "down" | "flat" | null = null;
      let weightTrendValue = 0;
      if (aWeights.length >= 2) {
        const latest = aWeights[0];
        const sevenAgo =
          aWeights.find((w) => w.logged_date <= addDaysISO(latest.logged_date, -6)) ||
          aWeights[aWeights.length - 1];
        const diff = latest.weight_kg - sevenAgo.weight_kg;
        weightTrendValue = diff;
        if (Math.abs(diff) < 0.3) weightTrend = "flat";
        else if (diff > 0) weightTrend = "up";
        else weightTrend = "down";
      }

      // Weight drop > 2kg in 7 days check
      let weightDrop7d = 0;
      if (aWeights.length > 0) {
        const recent = aWeights.filter((w) => w.logged_date >= sevenDaysAgo);
        if (recent.length >= 2) {
          const max = Math.max(...recent.map((w) => w.weight_kg));
          const min = Math.min(...recent.map((w) => w.weight_kg));
          const maxDate = recent.find((w) => w.weight_kg === max)?.logged_date;
          const minDate = recent.find((w) => w.weight_kg === min)?.logged_date;
          // count as a drop only when the min comes AFTER the max
          if (maxDate && minDate && minDate > maxDate) {
            weightDrop7d = max - min;
          }
        }
      }

      // Alerts — store key+params so lang switch re-translates at render time.
      const alerts: AlertSpec[] = [];
      const hoursSinceLastMeal = lastMealAt
        ? (Date.now() - lastMealAt.getTime()) / 3600000
        : Infinity;

      if (hoursSinceLastMeal > 48) {
        alerts.push({ level: "red", key: "coach.alert.noMeals48" });
      }
      if (weightDrop7d > 2) {
        alerts.push({
          level: "red",
          key: "coach.alert.weightDropped",
          params: { n: weightDrop7d.toFixed(1) },
        });
      }
      if (mealsYesterday > 0 && mealsYesterday < 3) {
        alerts.push({
          level: "yellow",
          key: "coach.alert.onlyMealsYesterday",
          params: { n: mealsYesterday },
        });
      }
      const daysSinceWeight = lastWeightDay
        ? Math.floor((isoToDate(today).getTime() - lastWeightDay.getTime()) / 86400000)
        : Infinity;
      if (daysSinceWeight >= 3 && daysSinceWeight !== Infinity) {
        alerts.push({
          level: "yellow",
          key: "coach.alert.noWeightDays",
          params: { n: daysSinceWeight },
        });
      } else if (daysSinceWeight === Infinity) {
        alerts.push({ level: "yellow", key: "coach.alert.noWeightYet" });
      }

      // Status color
      const hasWeightToday = aWeights.some((w) => w.logged_date === today);
      let status: "green" | "yellow" | "red";
      if (hoursSinceLastMeal > 48 || mealsYesterday < 3) {
        status = "red";
      } else if (mealsYesterday >= 3 && hasWeightToday) {
        status = "green";
      } else {
        status = "yellow";
      }

      return {
        profile: p,
        baseline,
        weights: aWeights,
        meals: aMeals,
        status,
        mealsToday,
        proteinToday: Math.round(proteinToday),
        mealsYesterday,
        weightLatest,
        weightTrend,
        weightTrendValue,
        lastActive,
        alerts,
      };
    });
  }

  // ===== Rendering =====
  function statusRank(s: "green" | "yellow" | "red"): number {
    if (s === "red") return 0;
    if (s === "yellow") return 1;
    return 2;
  }

  function sortAthletes(list: Athlete[]): Athlete[] {
    return [...list].sort((a, b) => {
      const ar = statusRank(a.status);
      const br = statusRank(b.status);
      if (ar !== br) return ar - br;
      const an = (a.profile.full_name || a.profile.email || "").toLowerCase();
      const bn = (b.profile.full_name || b.profile.email || "").toLowerCase();
      return an.localeCompare(bn);
    });
  }

  function renderAlerts(athletes: Athlete[]) {
    const wrap = document.getElementById("coach-alerts");
    const list = document.getElementById("coach-alerts-list");
    const toggle = document.getElementById("coach-alerts-toggle") as HTMLButtonElement | null;
    if (!wrap || !list || !toggle) return;

    type AlertItem = {
      level: "red" | "yellow";
      msg: string;
      athleteId: string;
      athleteName: string;
    };
    const all: AlertItem[] = [];
    for (const a of athletes) {
      for (const al of a.alerts) {
        all.push({
          level: al.level,
          msg: t(al.key, al.params),
          athleteId: a.profile.id,
          athleteName: a.profile.full_name || a.profile.email || t("coach.row.athlete"),
        });
      }
    }
    if (all.length === 0) {
      wrap.setAttribute("hidden", "");
      return;
    }
    wrap.removeAttribute("hidden");
    all.sort((x, y) => (x.level === "red" ? -1 : 1) - (y.level === "red" ? -1 : 1));

    let visible = all;
    let expanded = false;
    if (all.length > 5) {
      toggle.removeAttribute("hidden");
      toggle.textContent = `${t("coach.alerts.viewAll")} (${all.length})`;
    } else {
      toggle.setAttribute("hidden", "");
    }

    function paint() {
      const items = expanded ? visible : visible.slice(0, 5);
      list!.innerHTML = items
        .map(
          (it) => `
        <button class="coach-alert coach-alert-${it.level}" data-aid="${it.athleteId}">
          <span class="coach-alert-dot"></span>
          <span class="coach-alert-body">
            <span class="coach-alert-name">${escapeHtml(it.athleteName)}</span>
            <span class="coach-alert-msg">${escapeHtml(it.msg)}</span>
          </span>
        </button>`
        )
        .join("");
      list!.querySelectorAll<HTMLButtonElement>(".coach-alert").forEach((btn) => {
        btn.style.cursor = "pointer";
        btn.style.textAlign = "left";
        btn.style.background = btn.style.background || "";
        btn.style.width = "100%";
        btn.addEventListener("click", () => {
          const id = btn.getAttribute("data-aid")!;
          openDrawer(id);
        });
      });
    }
    paint();
    toggle.onclick = () => {
      expanded = !expanded;
      toggle.textContent = expanded ? t("coach.alerts.showLess") : `${t("coach.alerts.viewAll")} (${all.length})`;
      paint();
    };
  }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) =>
      ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" } as any)[c]
    );
  }

  function renderTable(athletes: Athlete[]) {
    const root = document.getElementById("coach-table");
    const empty = document.getElementById("coach-empty");
    if (!root || !empty) return;

    if (athletes.length === 0) {
      root.innerHTML = "";
      empty.removeAttribute("hidden");
      return;
    }
    empty.setAttribute("hidden", "");

    const headers = `
      <div class="coach-table-headers">
        <div>${t("coach.table.header.name")}</div>
        <div>${t("coach.table.header.status")}</div>
        <div>${t("coach.table.header.meals")}</div>
        <div>${t("coach.table.header.protein")}</div>
        <div class="coach-header-weight">${t("coach.table.header.weight")}</div>
        <div class="coach-header-last">${t("coach.table.header.lastActive")}</div>
      </div>`;

    const rows = athletes
      .map((a) => {
        const target = Math.round(a.baseline?.protein_target_g ?? 0);
        const trendArrow =
          a.weightTrend === "up"
            ? `<span class="coach-trend-up">↑</span>`
            : a.weightTrend === "down"
            ? `<span class="coach-trend-down">↓</span>`
            : a.weightTrend === "flat"
            ? `<span class="coach-trend-flat">→</span>`
            : "";
        const weightCell = a.weightLatest
          ? `<span class="coach-row-strong">${a.weightLatest.weight_kg.toFixed(1)} kg</span> ${trendArrow}`
          : `<span class="coach-row-secondary">${t("coach.weight.noData")}</span>`;
        const lastActiveText = formatRelativeAgo(a.lastActive);
        const nameLine = `${escapeHtml(a.profile.full_name || a.profile.email || t("coach.row.athlete"))}`;
        return `
          <button class="coach-row" data-aid="${a.profile.id}">
            <div>
              <div class="coach-row-name">${nameLine}</div>
              <div class="coach-row-secondary">${escapeHtml(a.profile.email || "")}</div>
            </div>
            <div class="coach-row-status">
              <span class="coach-status-dot coach-status-${a.status}"></span>
            </div>
            <div>
              <span class="coach-row-strong">${a.mealsToday}</span>
              <span class="coach-row-label">/ 6</span>
            </div>
            <div>
              <span class="coach-row-strong">${a.proteinToday}g</span>
              <span class="coach-row-label">/ ${target}g</span>
            </div>
            <div class="coach-row-col-weight">${weightCell}</div>
            <div class="coach-row-col-last">
              <span class="coach-row-label">${lastActiveText}</span>
            </div>
          </button>`;
      })
      .join("");

    root.innerHTML = headers + rows;
    root.querySelectorAll<HTMLButtonElement>(".coach-row").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.getAttribute("data-aid")!;
        openDrawer(id);
      });
    });
  }

  // ===== Drawer / drill-down =====
  let athletesCache: Athlete[] = [];
  let drawerChartRange: 7 | 30 = 7;
  let currentDrawerAthleteId: string | null = null;

  function openDrawer(athleteId: string) {
    const a = athletesCache.find((x) => x.profile.id === athleteId);
    if (!a) return;
    currentDrawerAthleteId = athleteId;
    const drawer = document.getElementById("coach-drawer");
    const nameEl = document.getElementById("coach-drawer-name");
    const eyebrow = document.getElementById("coach-drawer-eyebrow");
    if (!drawer || !nameEl || !eyebrow) return;

    nameEl.textContent = a.profile.full_name || a.profile.email || t("coach.drawer.athlete");
    const statusWord = a.status === "green" ? t("coach.status.green") : a.status === "yellow" ? t("coach.status.yellow") : t("coach.status.red");
    eyebrow.textContent = `${statusWord} • ${a.profile.email || ""}`;
    drawer.removeAttribute("hidden");
    drawer.setAttribute("aria-hidden", "false");
    drawerChartRange = 7;
    renderDrawerBody(a);
    document.body.style.overflow = "hidden";
  }

  function closeDrawer() {
    const drawer = document.getElementById("coach-drawer");
    if (!drawer) return;
    drawer.setAttribute("hidden", "");
    drawer.setAttribute("aria-hidden", "true");
    currentDrawerAthleteId = null;
    document.body.style.overflow = "";
  }

  // ===== Excel Export =====
  function loadXLSX(): Promise<any> {
    if ((window as any).XLSX) return Promise.resolve((window as any).XLSX);
    return new Promise((resolve, reject) => {
      const script = document.createElement("script");
      script.src = "https://cdn.sheetjs.com/xlsx-0.20.3/package/dist/xlsx.full.min.js";
      script.onload = () => resolve((window as any).XLSX);
      script.onerror = () => reject(new Error("Failed to load XLSX library"));
      document.head.appendChild(script);
    });
  }

  async function downloadReport() {
    const a = athletesCache.find((x) => x.profile.id === currentDrawerAthleteId);
    if (!a) return;

    const btn = document.getElementById("coach-drawer-dl-btn");
    if (btn) {
      (btn as HTMLButtonElement).disabled = true;
      (btn as HTMLButtonElement).textContent = "...";
    }

    try {
      const XLSX = await loadXLSX();

      // Last 30 days
      const athleteTz = a.profile.timezone || "Asia/Hong_Kong";
      const today = tzTodayISO(athleteTz);
      const thirtyDaysAgo = addDaysISO(today, -30);

      const recentMeals = a.meals.filter((m) => m.logged_date >= thirtyDaysAgo);

      // Sheet 1: Meal Log — sorted by date descending
      const sortedMeals = [...recentMeals].sort((a, b) => b.logged_date.localeCompare(a.logged_date));
      const mealRows = sortedMeals.map((m) => {
        const foods = Array.isArray(m.food_items)
          ? m.food_items.map((f: any) => f.name || "Food").join(", ")
          : "";
        return {
          Date: m.logged_date,
          "Meal Slot": m.meal_slot.replace(/_/g, " ").replace(/\b\w/g, (l) => l.toUpperCase()),
          "Food Items": foods,
          "Protein (g)": Math.round(m.total_protein_g || 0),
          "Calories (kcal)": Math.round(m.total_calories_kcal || 0),
          "Fat (g)": Math.round((m.total_fat_g || 0) * 10) / 10,
          "Sugar (g)": Math.round((m.total_sugar_g || 0) * 10) / 10,
        };
      });

      // Sheet 2: Daily Summary — one row per day, sorted by date descending
      const dailyMap: Record<string, { protein: number; cals: number; fat: number; sugar: number; count: number }> = {};
      for (const m of recentMeals) {
        if (!dailyMap[m.logged_date]) {
          dailyMap[m.logged_date] = { protein: 0, cals: 0, fat: 0, sugar: 0, count: 0 };
        }
        dailyMap[m.logged_date].protein += Math.round(m.total_protein_g || 0);
        dailyMap[m.logged_date].cals += Math.round(m.total_calories_kcal || 0);
        dailyMap[m.logged_date].fat += Math.round((m.total_fat_g || 0) * 10) / 10;
        dailyMap[m.logged_date].sugar += Math.round((m.total_sugar_g || 0) * 10) / 10;
        dailyMap[m.logged_date].count += 1;
      }

      // Include all 30 days (even with 0 meals)
      const allDays: string[] = [];
      for (let i = 29; i >= 0; i--) allDays.push(addDaysISO(today, -i));

      const dailyRows = allDays.map((iso) => {
        const d = dailyMap[iso] || { protein: 0, cals: 0, fat: 0, sugar: 0, count: 0 };
        return {
          Date: iso,
          "Total Protein (g)": d.protein,
          "Total Calories (kcal)": d.cals,
          "Total Fat (g)": d.fat,
          "Total Sugar (g)": d.sugar,
          "Meal Count": d.count,
        };
      });

      const wb = XLSX.utils.book_new();
      const ws1 = XLSX.utils.json_to_sheet(mealRows);
      const ws2 = XLSX.utils.json_to_sheet(dailyRows);
      XLSX.utils.book_append_sheet(wb, ws1, "Meal Log");
      XLSX.utils.book_append_sheet(wb, ws2, "Daily Summary");

      const athleteName = (a.profile.full_name || a.profile.email || "athlete").replace(/[^a-zA-Z0-9_\- ]/g, "_");
      XLSX.writeFile(wb, `${athleteName}_nutrition_report.xlsx`);
    } catch (err) {
      console.error("Export failed:", err);
      alert("Could not generate report. Please try again.");
    } finally {
      if (btn) {
        (btn as HTMLButtonElement).disabled = false;
        (btn as HTMLButtonElement).textContent = t("coach.drawer.downloadReport");
      }
    }
  }

  function renderDrawerBody(a: Athlete) {
    const body = document.getElementById("coach-drawer-body");
    if (!body) return;

    // 7-day meal grid (today is rightmost, relative to athlete's timezone)
    const athleteTz = a.profile.timezone || "Asia/Hong_Kong";
    const athleteToday = tzTodayISO(athleteTz);
    const days: { iso: string; label: string }[] = [];
    for (let i = 6; i >= 0; i--) {
      const iso = addDaysISO(athleteToday, -i);
      days.push({ iso, label: isoToDate(iso).toLocaleDateString(undefined, { weekday: "short" }) });
    }
    const countByDay: Record<string, number> = {};
    const proteinByDay: Record<string, number> = {};
    const calsByDay: Record<string, number> = {};
    const fatByDay: Record<string, number> = {};
    const sugarByDay: Record<string, number> = {};
    for (const m of a.meals) {
      countByDay[m.logged_date] = (countByDay[m.logged_date] || 0) + 1;
      proteinByDay[m.logged_date] = (proteinByDay[m.logged_date] || 0) + Math.round(m.total_protein_g || 0);
      calsByDay[m.logged_date] = (calsByDay[m.logged_date] || 0) + Math.round(m.total_calories_kcal || 0);
      fatByDay[m.logged_date] = (fatByDay[m.logged_date] || 0) + Math.round((m.total_fat_g || 0) * 10) / 10;
      sugarByDay[m.logged_date] = (sugarByDay[m.logged_date] || 0) + Math.round((m.total_sugar_g || 0) * 10) / 10;
    }
    const gridHtml = days
      .map((d) => {
        const c = countByDay[d.iso] || 0;
        const p = proteinByDay[d.iso] || 0;
        const cal = calsByDay[d.iso] || 0;
        const f = fatByDay[d.iso] || 0;
        const s = sugarByDay[d.iso] || 0;
        const level = c === 0 ? 0 : c <= 1 ? 1 : c <= 2 ? 2 : c <= 3 ? 3 : 4;
        const dateLabel = isoToDate(d.iso).toLocaleDateString(undefined, { month: "short", day: "numeric" });
        return `<button class="coach-grid-cell coach-grid-l${level}" data-iso="${d.iso}" data-p="${p}" data-cal="${cal}" data-f="${f}" data-s="${s}" data-c="${c}" title="${dateLabel}: ${c} meals">
          <strong>${c}</strong>
          <span class="coach-grid-cell-date">${d.label}</span>
        </button>`;
      })
      .join("");

    // Recent meals (last 5)
    const recent = a.meals.slice(0, 5);
    const recentHtml =
      recent.length === 0
        ? `<div class="coach-chart-empty" style="padding:14px;">${t("coach.drawer.noMealsYet")}</div>`
        : recent
            .map((m) => {
              const foods = Array.isArray(m.food_items)
                ? m.food_items.map((f: any) => escapeHtml(f.name || "Food")).join(", ")
                : "";
              const slotLabel = m.meal_slot
                .replace(/_/g, " ")
                .replace(/\b\w/g, (l) => l.toUpperCase());
              const created = new Date(m.created_at);
              const fb = m.ai_feedback
                ? `<div class="coach-meal-fb">${escapeHtml(m.ai_feedback)}</div>`
                : "";
              const cal = Math.round(m.total_calories_kcal || 0);
              const fat = Math.round((m.total_fat_g || 0) * 10) / 10;
              const sugar = Math.round((m.total_sugar_g || 0) * 10) / 10;
              return `
              <div class="coach-meal">
                <div class="coach-meal-head">
                  <span class="coach-meal-slot">${slotLabel}</span>
                  <span class="coach-meal-date">${created.toLocaleDateString(undefined, { month: "short", day: "numeric" })} • ${created.toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" })}</span>
                </div>
                <div class="coach-meal-foods">${foods || `<em>${t("coach.drawer.noItems")}</em>`}</div>
                <div class="coach-meal-protein">${Math.round(m.total_protein_g)}g protein · ${cal}kcal · ${fat}g fat · ${sugar}g sugar</div>
                ${fb}
              </div>`;
            })
            .join("");

    // Baseline
    const b = a.baseline;
    const baselineHtml = b
      ? `
        <div class="coach-baseline">
          <div class="coach-baseline-cell">
            <div class="coach-baseline-label">${t("coach.drawer.baselineWeight")}</div>
            <div class="coach-baseline-value">${Number(b.weight_kg).toFixed(1)}<span class="coach-baseline-unit">kg</span></div>
          </div>
          <div class="coach-baseline-cell">
            <div class="coach-baseline-label">${t("coach.drawer.height")}</div>
            <div class="coach-baseline-value">${b.height_cm != null ? `${Number(b.height_cm).toFixed(1)}<span class="coach-baseline-unit">cm</span>` : "—"}</div>
          </div>
          <div class="coach-baseline-cell">
            <div class="coach-baseline-label">${t("coach.drawer.age")}</div>
            <div class="coach-baseline-value">${b.age}<span class="coach-baseline-unit">yrs</span></div>
          </div>
          <div class="coach-baseline-cell">
            <div class="coach-baseline-label">${t("coach.drawer.growth")}</div>
            <div class="coach-baseline-value">${t("coach.growth." + b.growth_rate) || escapeHtml(b.growth_rate)}</div>
          </div>
          <div class="coach-baseline-cell">
            <div class="coach-baseline-label">${t("coach.drawer.proteinTarget")}</div>
            <div class="coach-baseline-value">${Math.round(b.protein_target_g)}<span class="coach-baseline-unit">g/day</span></div>
          </div>
        </div>`
      : `<div class="coach-chart-empty">${t("coach.drawer.noBaseline")}</div>`;

    body.innerHTML = `
      <div class="coach-drawer-section">
        <h3 class="coach-section-title">${t("coach.drawer.last7days")}</h3>
        <div class="coach-grid">${gridHtml}</div>
        <div class="coach-grid-macro-detail" id="coach-grid-macro-detail"></div>
      </div>

      <div class="coach-drawer-section">
        <h3 class="coach-section-title">${t("coach.drawer.weightTrend")}</h3>
        <div class="coach-chart-toggle" role="tablist">
          <button class="coach-chart-btn ${drawerChartRange === 7 ? "active" : ""}" data-range="7">7d</button>
          <button class="coach-chart-btn ${drawerChartRange === 30 ? "active" : ""}" data-range="30">30d</button>
        </div>
        <div class="coach-chart-body" id="coach-chart-body"></div>
      </div>

      <div class="coach-drawer-section">
        <h3 class="coach-section-title">${t("coach.drawer.recentMeals")}</h3>
        ${recentHtml}
      </div>

      <div class="coach-drawer-section">
        <h3 class="coach-section-title">${t("coach.drawer.baseline")}</h3>
        ${baselineHtml}
      </div>
    `;

    // Wire grid cell clicks for macro detail popover
    const gridDetail = body.querySelector<HTMLDivElement>("#coach-grid-macro-detail");
    body.querySelectorAll<HTMLButtonElement>(".coach-grid-cell").forEach((btn) => {
      btn.addEventListener("click", () => {
        if (!gridDetail) return;
        const iso = btn.getAttribute("data-iso");
        const currentActive = gridDetail.getAttribute("data-active");
        if (currentActive === iso) {
          gridDetail.removeAttribute("data-active");
        } else {
          const p = btn.getAttribute("data-p") || "0";
          const cal = btn.getAttribute("data-cal") || "0";
          const f = btn.getAttribute("data-f") || "0";
          const s = btn.getAttribute("data-s") || "0";
          const c = btn.getAttribute("data-c") || "0";
          const dateLabel = iso ? isoToDate(iso).toLocaleDateString(undefined, { month: "short", day: "numeric", weekday: "short" }) : "";
          gridDetail.innerHTML = `
            <div class="coach-grid-macro-detail-date">${dateLabel} — ${c} meals</div>
            <div class="coach-grid-macro-detail-row">
              <span class="coach-grid-macro-detail-item">Protein: <strong>${p}g</strong></span>
              <span class="coach-grid-macro-detail-item">Calories: <strong>${cal}kcal</strong></span>
              <span class="coach-grid-macro-detail-item">Fat: <strong>${f}g</strong></span>
              <span class="coach-grid-macro-detail-item">Sugar: <strong>${s}g</strong></span>
            </div>
          `;
          gridDetail.setAttribute("data-active", iso!);
        }
      });
    });

    // Wire chart toggle + render chart
    body.querySelectorAll<HTMLButtonElement>(".coach-chart-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        drawerChartRange = (Number(btn.dataset.range) || 7) as 7 | 30;
        body
          .querySelectorAll<HTMLButtonElement>(".coach-chart-btn")
          .forEach((b2) => b2.classList.toggle("active", b2 === btn));
        renderWeightChart(a);
      });
    });
    renderWeightChart(a);
  }

  function renderWeightChart(a: Athlete) {
    const root = document.getElementById("coach-chart-body");
    if (!root) return;

    const athleteTz = a.profile.timezone || "Asia/Hong_Kong";
    const today = tzTodayISO(athleteTz);
    const days: string[] = [];
    for (let i = drawerChartRange - 1; i >= 0; i--) days.push(addDaysISO(today, -i));

    const weightMap: Record<string, number> = {};
    for (const w of a.weights) weightMap[w.logged_date] = w.weight_kg;
    const points = days
      .map((iso) => ({ iso, w: weightMap[iso] }))
      .filter((p) => typeof p.w === "number") as Array<{ iso: string; w: number }>;

    if (points.length === 0) {
      root.innerHTML = `<div class="coach-chart-empty">${t("coach.drawer.noWeightRange")}</div>`;
      return;
    }

    const W = 520;
    const H = 160;
    const padL = 36;
    const padR = 12;
    const padT = 16;
    const padB = 28;
    const innerW = W - padL - padR;
    const innerH = H - padT - padB;
    const weights = points.map((p) => p.w);
    let minW = Math.min(...weights);
    let maxW = Math.max(...weights);
    if (minW === maxW) {
      minW -= 1;
      maxW += 1;
    } else {
      const pad = (maxW - minW) * 0.15;
      minW -= pad;
      maxW += pad;
    }
    const xFor = (iso: string) => {
      const idx = days.indexOf(iso);
      if (days.length === 1) return padL + innerW / 2;
      return padL + (idx / (days.length - 1)) * innerW;
    };
    const yFor = (w: number) => padT + (1 - (w - minW) / (maxW - minW)) * innerH;

    const gridLines: string[] = [];
    const labels: string[] = [];
    for (let i = 0; i < 3; i++) {
      const y = padT + (i / 2) * innerH;
      const w = maxW - (i / 2) * (maxW - minW);
      gridLines.push(
        `<line x1="${padL}" y1="${y.toFixed(1)}" x2="${padL + innerW}" y2="${y.toFixed(1)}" stroke="var(--rise-neutral-100)" stroke-width="1" />`
      );
      labels.push(
        `<text x="${padL - 6}" y="${(y + 3).toFixed(1)}" text-anchor="end" font-size="10" font-family="var(--font-body)" fill="var(--rise-neutral-400)">${w.toFixed(1)}</text>`
      );
    }
    const xLabelIdx =
      days.length <= 2 ? [0, days.length - 1] : [0, Math.floor((days.length - 1) / 2), days.length - 1];
    const xLabels = xLabelIdx.map((idx) => {
      const iso = days[idx];
      const d = isoToDate(iso);
      const text = d.toLocaleDateString(undefined, { month: "short", day: "numeric" });
      const x = xFor(iso);
      return `<text x="${x.toFixed(1)}" y="${H - 8}" text-anchor="middle" font-size="10" font-family="var(--font-body)" fill="var(--rise-neutral-400)">${text}</text>`;
    });
    const path = points
      .map((p, i) => `${i === 0 ? "M" : "L"} ${xFor(p.iso).toFixed(1)} ${yFor(p.w).toFixed(1)}`)
      .join(" ");
    const dots = points
      .map(
        (p) =>
          `<circle cx="${xFor(p.iso).toFixed(1)}" cy="${yFor(p.w).toFixed(1)}" r="3.5" fill="var(--rise-red)" stroke="var(--rise-white)" stroke-width="1.5"><title>${p.iso}: ${p.w.toFixed(1)} kg</title></circle>`
      )
      .join("");

    root.innerHTML = `<svg viewBox="0 0 ${W} ${H}" preserveAspectRatio="xMidYMid meet" aria-label="Weight trend chart" role="img">
      ${gridLines.join("")}
      ${labels.join("")}
      <path d="${path}" fill="none" stroke="var(--rise-red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      ${dots}
      ${xLabels.join("")}
    </svg>`;
  }

  // ===== i18n processing =====
  (window as any).__t = translations[getLang()];
  (window as any).__riseT = t;

  function applyCoachTranslations() {
    const lang = getLang();
    (window as any).__t = translations[lang];

    document.querySelectorAll<HTMLElement>("[data-i18n]").forEach((el) => {
      const key = el.getAttribute("data-i18n");
      if (!key) return;
      el.textContent = getTranslation(lang, key);
    });
    document.querySelectorAll<HTMLElement>("[data-i18n-attr]").forEach((el) => {
      const spec = el.getAttribute("data-i18n-attr");
      if (!spec) return;
      spec.split(",").forEach((pair) => {
        const [key, attr] = pair.split(":").map((s) => s.trim());
        if (key && attr) el.setAttribute(attr, getTranslation(lang, key));
      });
    });

    // Lang toggle text
    const toggle = document.getElementById("portal-lang-toggle");
    if (toggle) {
      toggle.textContent = lang === "zh" ? getTranslation("en", "lang.toggle.en") : getTranslation("zh", "lang.toggle.zh");
    }
    document.documentElement.setAttribute("lang", lang === "zh" ? "zh-HK" : "en");

    // Re-render dynamic parts
    if (athletesCache.length > 0) {
      renderAlerts(athletesCache);
      renderTable(athletesCache);
    }
  }

  function wireLangToggle() {
    const btn = document.getElementById("portal-lang-toggle");
    if (!btn) return;
    btn.addEventListener("click", () => {
      const next: Lang = getLang() === "zh" ? "en" : "zh";
      setLang(next);
      applyCoachTranslations();
    });
  }

  // ===== Init =====
  async function initCoach() {
    const sb = (window as any).supabaseClient;
    if (!sb) {
      setTimeout(initCoach, 100);
      return;
    }

    const loading = document.getElementById("coach-loading");
    const anon = document.getElementById("coach-anon");
    const notCoach = document.getElementById("coach-not-coach");
    const dash = document.getElementById("coach-dashboard");

    const { data: { session } } = await sb.auth.getSession();
    if (!session) {
      loading?.setAttribute("hidden", "");
      anon?.removeAttribute("hidden");
      sb.auth.onAuthStateChange((_e: string, s: any) => {
        if (s) window.location.reload();
      });
      return;
    }

    const user = session.user;
    const { data: profile } = await sb
      .from("user_profiles")
      .select("role, team_id, full_name")
      .eq("id", user.id)
      .maybeSingle();

    if (profile?.role !== "coach" && profile?.role !== "founder") {
      loading?.setAttribute("hidden", "");
      notCoach?.removeAttribute("hidden");
      return;
    }

    if (!profile.team_id) {
      loading?.setAttribute("hidden", "");
      notCoach?.removeAttribute("hidden");
      const sub = document.querySelector("#coach-not-coach .coach-anon-sub");
      if (sub) sub.textContent = t("coach.notCoach.noTeam");
      return;
    }

    const athletes = await loadCoachData(sb, profile.team_id);
    athletesCache = sortAthletes(athletes);

    // Header chrome
    const titleEl = document.getElementById("coach-title");
    if (titleEl) titleEl.textContent = t("coach.title");
    const teamEl = document.getElementById("coach-team-name");
    if (teamEl) teamEl.textContent = `${t("coach.team")} ${profile.team_id}`;
    const countEl = document.getElementById("coach-athlete-count");
    if (countEl) countEl.textContent = `${athletes.length} ${athletes.length === 1 ? t("coach.athlete") : t("coach.athletes")}`;
    const dateEl = document.getElementById("coach-today-date");
    if (dateEl) dateEl.textContent = formatDateLong(isoToDate(TODAY));

    renderAlerts(athletesCache);
    renderTable(athletesCache);

    loading?.setAttribute("hidden", "");
    dash?.removeAttribute("hidden");

    // Drawer events
    document.getElementById("coach-drawer-close")?.addEventListener("click", closeDrawer);
    document.getElementById("coach-drawer-backdrop")?.addEventListener("click", closeDrawer);
    document.getElementById("coach-drawer-dl-btn")?.addEventListener("click", downloadReport);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && currentDrawerAthleteId) closeDrawer();
    });

    wireLangToggle();
    applyCoachTranslations();
  }

  initCoach();

  // Logout handler
  document.getElementById("coach-logout-btn")?.addEventListener("click", async () => {
    const sb = (window as any).supabaseClient;
    if (sb) await sb.auth.signOut();
    window.location.href = "/";
  });
</script>
