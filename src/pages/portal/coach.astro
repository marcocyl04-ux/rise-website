---
// Coach dashboard — accessible to users with role='coach' or role='founder'.
// All team data fetched client-side, RLS enforces team_id scoping.
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<BaseLayout title="Coach Dashboard" description="RISE coach dashboard — monitor your team's nutrition compliance.">
  <Header slot="header" />

  <!-- Minimal app header (standalone PWA only) -->
  <div class="pwa-app-header" aria-hidden="true">
    <img src="/logo-header.png" alt="RISE" class="pwa-app-header-logo" />
  </div>

  <!-- Floating lang toggle -->
  <button id="portal-lang-toggle" class="portal-lang-toggle" type="button" aria-label="Toggle language">中文</button>

  <section id="coach-loading" class="coach-loading">
    <div class="coach-spinner" aria-hidden="true"></div>
  </section>

  <section id="coach-anon" class="coach-anon section" hidden>
    <div class="container coach-narrow">
      <h1 class="coach-anon-title" data-i18n="coach.anon.title">Sign in to your portal</h1>
      <p class="coach-anon-sub" data-i18n="coach.anon.sub">You need to be logged in as a coach to view this dashboard.</p>
      <div class="coach-anon-actions">
        <button class="btn-primary" type="button" data-open-auth data-i18n="common.login">Log in</button>
        <a class="btn-ghost" href="/" data-i18n="common.backToHome">Back to home</a>
      </div>
    </div>
  </section>

  <section id="coach-not-coach" class="coach-anon section" hidden>
    <div class="container coach-narrow">
      <h1 class="coach-anon-title" data-i18n="coach.notCoach.title">Coach access only</h1>
      <p class="coach-anon-sub" id="coach-not-coach-sub" data-i18n="coach.notCoach.sub" data-i18n-replace>Your account isn't a coach. Head back to your athlete portal.</p>
      <div class="coach-anon-actions">
        <a class="btn-primary" href="/portal" data-i18n="common.backToPortal">Back to portal</a>
      </div>
    </div>
  </section>

  <section id="coach-dashboard" class="coach-dashboard section" hidden>
    <div class="container">

      <header class="coach-header">
        <div class="coach-header-top">
          <p class="coach-eyebrow" data-i18n="coach.eyebrow">RISE Coach</p>
          <button type="button" class="portal-logout-btn" id="coach-logout-btn" data-i18n="common.logout">Log out</button>
        </div>
        <h1 class="coach-title" id="coach-title" data-i18n="coach.title">Coach Dashboard</h1>
        <div class="coach-meta">
          <span class="coach-meta-item" id="coach-team-name" data-i18n-replace>Team</span>
          <span class="coach-meta-sep">•</span>
          <span class="coach-meta-item" id="coach-athlete-count" data-i18n-replace>0 athletes</span>
          <span class="coach-meta-sep">•</span>
          <span class="coach-meta-item" id="coach-today-date">Today</span>
        </div>
      </header>

      <!-- Alerts strip -->
      <div class="coach-alerts" id="coach-alerts" hidden>
        <div class="coach-alerts-head">
          <h2 class="coach-alerts-title" data-i18n="coach.alerts.title">Alerts</h2>
          <button class="coach-alerts-toggle" type="button" id="coach-alerts-toggle" hidden data-i18n-replace>View all</button>
        </div>
        <div class="coach-alerts-list" id="coach-alerts-list" data-i18n-replace></div>
      </div>

      <!-- Athletes table -->
      <div class="coach-table-wrap">
        <div class="coach-table-head">
          <h2 class="coach-table-title" data-i18n="coach.table.title">Athletes</h2>
        </div>
        <div class="coach-table" id="coach-table" data-i18n-replace></div>
        <div class="coach-empty" id="coach-empty" hidden data-i18n="coach.table.empty">No athletes on this team yet.</div>
      </div>
    </div>
  </section>

  <!-- Drill-down panel (slides up on mobile, side modal on desktop) -->
  <div class="coach-drawer" id="coach-drawer" hidden aria-hidden="true">
    <div class="coach-drawer-backdrop" id="coach-drawer-backdrop"></div>
    <div class="coach-drawer-panel" role="dialog" aria-modal="true" aria-labelledby="coach-drawer-name">
      <header class="coach-drawer-head">
        <div>
          <p class="coach-drawer-eyebrow" id="coach-drawer-eyebrow" data-i18n-replace>Athlete</p>
          <h2 class="coach-drawer-name" id="coach-drawer-name" data-i18n-replace>—</h2>
        </div>
        <button class="coach-drawer-close" type="button" id="coach-drawer-close" aria-label="Close" data-i18n-attr="common.close:aria-label">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M6 6l12 12M18 6l-12 12" />
          </svg>
        </button>
      </header>
      <div class="coach-drawer-dl-wrap">
        <button class="coach-drawer-dl-btn" type="button" id="coach-drawer-dl-btn" data-i18n="coach.drawer.downloadReport">Download Report</button>
      </div>
      <div class="coach-drawer-body" id="coach-drawer-body" data-i18n-replace></div>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .coach-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
  }
  .coach-spinner {
    width: 32px;
    height: 32px;
    border: 3px solid var(--rise-neutral-100);
    border-top-color: var(--rise-red);
    border-radius: 50%;
    animation: coach-spin 0.8s linear infinite;
  }
  @keyframes coach-spin { to { transform: rotate(360deg); } }

  .coach-anon {
    min-height: 60vh;
    display: flex;
    align-items: center;
    text-align: center;
  }
  .coach-narrow { max-width: 520px; }
  .coach-anon-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 2.8rem);
    color: var(--rise-black);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 0 0 var(--space-3);
  }
  .coach-anon-sub {
    font-family: var(--font-body);
    color: var(--rise-neutral-500);
    margin: 0 0 var(--space-6);
  }
  .coach-anon-actions {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-primary, .btn-ghost {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    border: 1px solid transparent;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .btn-primary {
    background: var(--rise-red);
    color: var(--rise-white);
  }
  .btn-primary:hover {
    background: var(--rise-red-dark);
    text-decoration: none;
  }
  .btn-ghost {
    background: transparent;
    color: var(--rise-neutral-700);
    border-color: var(--rise-neutral-200);
  }
  .btn-ghost:hover {
    border-color: var(--rise-red);
    color: var(--rise-red);
    text-decoration: none;
  }

  .coach-dashboard {
    padding: var(--space-8) 0 var(--space-12);
  }

  .coach-header {
    margin-bottom: var(--space-7);
  }
  .coach-header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-2);
  }
  .coach-eyebrow {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--rise-red);
    margin: 0;
  }
  .portal-logout-btn {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--rise-neutral-500);
    background: none;
    border: 1px solid var(--rise-neutral-200);
    border-radius: 999px;
    padding: 4px 12px;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }
  .portal-logout-btn:hover {
    color: var(--rise-red);
    border-color: var(--rise-red);
  }
  .coach-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 700;
    color: var(--rise-black);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 0 0 var(--space-2);
  }
  .coach-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--rise-neutral-500);
  }
  .coach-meta-sep { color: var(--rise-neutral-300); }

  .coach-alerts {
    background: var(--rise-white);
    border: 1px solid var(--rise-neutral-100);
    border-radius: 12px;
    padding: var(--space-4) var(--space-5);
    margin-bottom: var(--space-6);
  }
  .coach-alerts-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-3);
  }
  .coach-alerts-title {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
    color: var(--rise-black);
  }
  .coach-alerts-toggle {
    background: transparent;
    border: none;
    color: var(--rise-red);
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    padding: 0;
  }
  .coach-alerts-toggle:hover { text-decoration: underline; }
  .coach-alerts-list {
    display: grid;
    gap: var(--space-2);
  }

  .coach-table-wrap {
    background: var(--rise-white);
    border: 1px solid var(--rise-neutral-100);
    border-radius: 12px;
    overflow: hidden;
  }
  .coach-table-head {
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--rise-neutral-100);
  }
  .coach-table-title {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
    color: var(--rise-black);
  }
  .coach-empty {
    padding: var(--space-8) var(--space-5);
    text-align: center;
    color: var(--rise-neutral-400);
    font-family: var(--font-body);
    font-size: 0.95rem;
  }

  .portal-lang-toggle {
    position: fixed;
    top: 12px;
    right: 12px;
    z-index: 50;
    background: var(--rise-white);
    border: 1px solid var(--rise-neutral-200);
    color: var(--rise-neutral-700);
    border-radius: 999px;
    padding: 6px 12px;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    box-shadow: 0 2px 6px rgba(0,0,0,0.06);
    transition: border-color 0.15s, color 0.15s;
  }
  .portal-lang-toggle:hover {
    border-color: var(--rise-red);
    color: var(--rise-red);
  }
  @media (min-width: 640px) {
    .portal-lang-toggle { top: 16px; right: 16px; }
  }
</style>

<!-- Global styles for JS-created elements (Astro CSS scoping pitfall). -->
<style is:global>
  /* Hide Header lang toggle — portal pages use their own floating toggle */
  .lang-toggle { display: none !important; }
  /* Alert cards */
  .coach-alert {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 8px;
    border: 1px solid transparent;
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.4;
  }
  .coach-alert-red {
    background: rgba(211, 25, 31, 0.06);
    border-color: rgba(211, 25, 31, 0.2);
    color: #6b1216;
  }
  .coach-alert-yellow {
    background: rgba(214, 158, 46, 0.08);
    border-color: rgba(214, 158, 46, 0.25);
    color: #6b4d11;
  }
  .coach-alert-dot {
    flex-shrink: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-top: 6px;
  }
  .coach-alert-red .coach-alert-dot { background: #D3191F; }
  .coach-alert-yellow .coach-alert-dot { background: #D69E2E; }
  .coach-alert-body { flex: 1; min-width: 0; }
  .coach-alert-name {
    font-weight: 600;
    color: var(--rise-black);
  }
  .coach-alert-msg {
    color: var(--rise-neutral-500);
    font-size: 0.825rem;
    margin-top: 2px;
  }

  /* Athlete row */
  .coach-row {
    display: grid;
    grid-template-columns: 1.4fr 0.5fr 0.7fr 0.9fr 0.9fr 0.8fr;
    gap: 12px;
    align-items: center;
    padding: 14px var(--space-5);
    border-bottom: 1px solid var(--rise-neutral-100);
    background: var(--rise-white);
    cursor: pointer;
    transition: background 0.12s;
    text-align: left;
    border-left: none;
    border-right: none;
    border-top: none;
    width: 100%;
    font-family: var(--font-body);
  }
  .coach-row:last-child { border-bottom: none; }
  .coach-row:hover { background: var(--rise-neutral-50); }
  .coach-row-name {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--rise-black);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .coach-row-status {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .coach-status-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .coach-status-green { background: #2F855A; }
  .coach-status-yellow { background: #D69E2E; }
  .coach-status-red { background: #D3191F; }
  .coach-row-label {
    font-size: 0.875rem;
    color: var(--rise-neutral-500);
  }
  .coach-row-strong {
    font-weight: 600;
    color: var(--rise-black);
  }
  .coach-row-secondary {
    color: var(--rise-neutral-400);
    font-size: 0.75rem;
  }
  .coach-trend-up { color: #2F855A; }
  .coach-trend-down { color: #D3191F; }
  .coach-trend-flat { color: var(--rise-neutral-400); }

  .coach-table-headers {
    display: grid;
    grid-template-columns: 1.4fr 0.5fr 0.7fr 0.9fr 0.9fr 0.8fr;
    gap: 12px;
    padding: 10px var(--space-5);
    background: var(--rise-neutral-50);
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--rise-neutral-400);
    border-bottom: 1px solid var(--rise-neutral-100);
  }

  @media (max-width: 640px) {
    .coach-row, .coach-table-headers {
      grid-template-columns: 1.2fr 0.4fr 0.6fr 0.8fr;
    }
    .coach-row-col-weight,
    .coach-row-col-last,
    .coach-table-headers > .coach-header-weight,
    .coach-table-headers > .coach-header-last {
      display: none;
    }
  }

  /* Drawer */
  .coach-drawer {
    position: fixed;
    inset: 0;
    z-index: 70;
  }
  .coach-drawer[hidden] { display: none; }
  .coach-drawer-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(18, 18, 18, 0.4);
    animation: coach-fade 0.18s ease;
  }
  @keyframes coach-fade { from { opacity: 0; } to { opacity: 1; } }
  .coach-drawer-panel {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: min(560px, 100%);
    background: var(--rise-white);
    box-shadow: -8px 0 32px rgba(18, 18, 18, 0.12);
    display: flex;
    flex-direction: column;
    animation: coach-slide 0.22s ease;
    overflow: hidden;
  }
  @keyframes coach-slide { from { transform: translateX(8%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
  @media (max-width: 640px) {
    .coach-drawer-panel {
      top: auto;
      right: 0;
      left: 0;
      bottom: 0;
      width: 100%;
      max-height: 92vh;
      border-top-left-radius: 16px;
      border-top-right-radius: 16px;
      animation: coach-slideup 0.22s ease;
    }
    @keyframes coach-slideup { from { transform: translateY(8%); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
  }
  .coach-drawer-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: var(--space-5);
    border-bottom: 1px solid var(--rise-neutral-100);
  }
  .coach-drawer-dl-wrap {
    padding: 10px var(--space-5);
    border-bottom: 1px solid var(--rise-neutral-100);
  }
  .coach-drawer-dl-btn {
    background: var(--rise-red);
    color: var(--rise-white);
    border: none;
    padding: 8px 14px;
    border-radius: 6px;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s;
    width: 100%;
  }
  .coach-drawer-dl-btn:hover {
    background: #b0151a;
  }
  .coach-drawer-eyebrow {
    font-family: var(--font-body);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--rise-red);
    font-weight: 600;
    margin: 0 0 4px;
  }
  .coach-drawer-name {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--rise-black);
    margin: 0;
  }
  .coach-drawer-close {
    background: transparent;
    border: none;
    color: var(--rise-neutral-400);
    cursor: pointer;
    padding: 4px;
    border-radius: 6px;
  }
  .coach-drawer-close:hover {
    background: var(--rise-neutral-50);
    color: var(--rise-black);
  }
  .coach-drawer-body {
    padding: var(--space-5);
    overflow-y: auto;
    flex: 1;
    font-family: var(--font-body);
  }

  .coach-drawer-section {
    margin-bottom: var(--space-6);
  }
  .coach-drawer-section:last-child { margin-bottom: 0; }
  .coach-section-title {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--rise-neutral-400);
    margin: 0 0 var(--space-3);
  }

  /* 7-day compliance grid (GitHub style) */
  .coach-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 6px;
  }
.coach-grid-cell {
    border-radius: 6px;
    background: var(--rise-neutral-100);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 0.65rem;
    color: var(--rise-neutral-400);
    padding: 4px 2px;
    min-height: 62px;
    cursor: pointer;
    border: none;
    transition: transform 0.1s, box-shadow 0.1s;
  }
  .coach-grid-cell:hover {
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }
  .coach-grid-cell:focus-visible {
    outline: 2px solid var(--rise-red);
    outline-offset: 2px;
  }
  .coach-grid-cell strong {
    font-size: 0.85rem;
    color: var(--rise-black);
    font-family: var(--font-heading);
    font-weight: 600;
    line-height: 1;
  }
  .coach-grid-cell-date {
    font-size: 0.57rem;
    opacity: 0.85;
    margin-top: 1px;
  }
  /* Macro detail popover below grid */
  .coach-grid-macro-detail {
    margin-top: 8px;
    background: var(--rise-white);
    border: 1px solid var(--rise-neutral-100);
    border-radius: 8px;
    padding: 10px 12px;
    font-family: var(--font-body);
    font-size: 0.8rem;
    display: none;
  }
  .coach-grid-macro-detail[data-active] {
    display: block;
  }
  .coach-grid-macro-detail-date {
    font-weight: 600;
    color: var(--rise-black);
    margin-bottom: 6px;
    font-size: 0.825rem;
  }
  .coach-grid-macro-detail-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .coach-grid-macro-detail-item {
    background: var(--rise-neutral-50);
    border-radius: 4px;
    padding: 4px 8px;
    font-size: 0.75rem;
    color: var(--rise-neutral-600);
  }
  .coach-grid-macro-detail-item strong {
    color: var(--rise-black);
    font-weight: 600;
  }
  .coach-grid-l0 { background: var(--rise-neutral-100); }
  .coach-grid-l1 { background: rgba(211, 25, 31, 0.18); }
  .coach-grid-l2 { background: rgba(211, 25, 31, 0.36); color: var(--rise-white); }
  .coach-grid-l2 strong { color: var(--rise-white); }
  .coach-grid-l3 { background: rgba(211, 25, 31, 0.7); color: var(--rise-white); }
  .coach-grid-l3 strong { color: var(--rise-white); }
  .coach-grid-l4 { background: var(--rise-red); color: var(--rise-white); }
  .coach-grid-l4 strong { color: var(--rise-white); }

  /* Weight chart */
  .coach-chart-toggle {
    display: inline-flex;
    background: var(--rise-neutral-50);
    border-radius: 8px;
    padding: 2px;
    gap: 2px;
    margin-bottom: var(--space-3);
  }
  .coach-chart-btn {
    background: transparent;
    border: none;
    padding: 4px 10px;
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--rise-neutral-500);
