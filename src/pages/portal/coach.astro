    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--rise-neutral-400);
    margin-bottom: 2px;
  }
  .coach-baseline-value {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--rise-black);
    font-weight: 600;
  }
  .coach-baseline-unit {
