<script>
  import {
    getMealFeedback,
    getDailySummary,
    type FoodItem,
  } from "../../lib/ai-feedback";
  import { getLang, setLang, getTranslation, translations, type Lang } from "../../lib/i18n";

  // ===== i18n helpers =====
  function t(key: string, params?: Record<string, string | number>): string {
    let s = getTranslation(getLang(), key);
    if (params) {
      for (const k in params) s = s.replace(`{${k}}`, String(params[k]));
    }
    return s;
  }
  function isZh(): boolean { return getLang() === "zh"; }

  // Display name for a food item, preferring zh when lang=zh and name_zh available.
  function foodDisplayName(item: { name: string; name_zh?: string | null }): string {
    if (isZh() && item.name_zh && item.name_zh.trim()) return item.name_zh;
    return item.name;
  }
  (window as any).__riseFoodDisplayName = foodDisplayName;
  (window as any).__riseT = t;

  function applyTrackerTranslations() {
    const lang = getLang();
    (window as any).__t = translations[lang];

    document.querySelectorAll<HTMLElement>("[data-i18n]").forEach((el) => {
      const key = el.getAttribute("data-i18n");
      if (!key) return;
      el.textContent = getTranslation(lang, key);
    });
    document.querySelectorAll<HTMLElement>("[data-i18n-attr]").forEach((el) => {
      const spec = el.getAttribute("data-i18n-attr");
      if (!spec) return;
      spec.split(",").forEach((pair) => {
        const [key, attr] = pair.split(":").map((s) => s.trim());
        if (key && attr) el.setAttribute(attr, getTranslation(lang, key));
      });
    });

    // Lang toggle text
    const toggle = document.getElementById("portal-lang-toggle");
    if (toggle) {
      toggle.textContent = lang === "zh" ? getTranslation("en", "lang.toggle.en") : getTranslation("zh", "lang.toggle.zh");
    }
    document.documentElement.setAttribute("lang", lang === "zh" ? "zh-HK" : "en");

    // Re-render dynamic parts that depend on lang.
    try { rerenderDynamic(); } catch (e) { console.warn("rerenderDynamic", e); }
  }

  function rerenderDynamic() {
    // Welcome line + date (only meaningful when app view is active).
    const hello = document.getElementById("app-hello");
    const firstName = (window as any).__riseFirstName as string | undefined;
    if (hello) {
      const base = t("tracker.welcomeBack");
      hello.textContent = firstName ? `${base}, ${firstName}` : base;
    }
    // Meals section title (today vs other day)
    const mealsTitle = document.getElementById("app-meals-title");
    if (mealsTitle) {
      mealsTitle.textContent = viewingDate === todayISO() ? t("tracker.meals.today") : t("tracker.meals.other");
    }
    // Weight label
    const weightLabel = document.querySelector("#app-weight-card .tk-weight-label") as HTMLElement | null;
    if (weightLabel) {
      weightLabel.textContent = viewingDate === todayISO() ? t("tracker.weight.todayLabel") : t("tracker.weight.label");
    }
    // Weight value (today / no data)
    renderWeightWidget();
    // Meal grid - rebuild so slot names / status reflect current language.
    if (lastRenderedMeals) {
      renderMealGrid(lastRenderedMeals.meals, lastRenderedMeals.yesterday, lastRenderedMeals.readOnly);
    }
  }

  function wireLangToggle() {
    const btn = document.getElementById("portal-lang-toggle");
    if (!btn) return;
    btn.addEventListener("click", () => {
      const next: Lang = getLang() === "zh" ? "en" : "zh";
      setLang(next);
      applyTrackerTranslations();
    });
  }

  // ===== Protein formula (exact, per spec) =====
  const GOAL_FACTORS: Record<string, number> = {
    maintenance: 1.6,
    muscle_gain: 1.8,
    recomposition: 2.0,
    fat_loss: 2.2,
  };
  const GROWTH_ADJUSTMENT: Record<string, number> = {
    fast: 0.2,
    moderate: 0.1,
    slow: 0.0,
  };

  function calculateProteinTarget(weightKg: number, growthRate: string, goal: string): number {
    const goalFactor = GOAL_FACTORS[goal];
    const growthAdj = GROWTH_ADJUSTMENT[growthRate];
    if (goalFactor == null || growthAdj == null) {
      throw new Error("Invalid goal or growth rate");
    }
    let protein = weightKg * (goalFactor + growthAdj);
    const floor = weightKg * 1.6;
    const ceiling = weightKg * 2.4;
    protein = Math.max(floor, Math.min(ceiling, protein));
    protein = Math.min(protein, 200);
    return Math.round(protein * 10) / 10;
  }

  // ===== State =====
  const intakeState = {
    step: 1,
    weight: null as number | null,
    height: null as number | null,
    age: null as number | null,
    growth: null as string | null,
    goal: null as string | null,
    protein: null as number | null,
  };

  const MEAL_SLOTS: Array<{ key: string; i18nKey: string }> = [
    { key: "breakfast", i18nKey: "meal.breakfast" },
    { key: "snack_1", i18nKey: "meal.snack_1" },
    { key: "lunch", i18nKey: "meal.lunch" },
    { key: "snack_2", i18nKey: "meal.snack_2" },
    { key: "dinner", i18nKey: "meal.dinner" },
    { key: "snack_3", i18nKey: "meal.snack_3" },
  ];
  function slotLabel(slot: { i18nKey: string }): string {
    return t(slot.i18nKey);
  }

  // Cached last-rendered meals so a lang toggle can rebuild the grid.
  let lastRenderedMeals: { meals: any[]; yesterday: any[]; readOnly: boolean } | null = null;

  function todayISO() {
    return new Date().toISOString().slice(0, 10);
  }
  function yesterdayISO() {
    const d = new Date();
    d.setDate(d.getDate() - 1);
    return d.toISOString().slice(0, 10);
  }
  function isoToDate(iso: string): Date {
    const [y, m, d] = iso.split("-").map(Number);
    return new Date(y, m - 1, d);
  }
  function dateToISO(d: Date): string {
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, "0");
    const day = String(d.getDate()).padStart(2, "0");
    return `${y}-${m}-${day}`;
  }
  function addDaysISO(iso: string, n: number): string {
    const d = isoToDate(iso);
    d.setDate(d.getDate() + n);
    return dateToISO(d);
  }
  function formatDateLong(date: Date) {
    return date.toLocaleDateString(undefined, {
      weekday: "long",
      month: "short",
      day: "numeric",
    });
  }
  function formatDateShort(date: Date) {
    return date.toLocaleDateString(undefined, {
      weekday: "short",
      month: "short",
      day: "numeric",
    });
  }

  // Current daily target (cached from loadAppShell so the progress bar can
  // re-render after a meal-logged event without re-fetching).
  let currentTarget = 0;

  // Cached context for AI feedback so we don't refetch baseline/profile on
  // every meal log.
  type UserContext = {
    user_id: string;
    full_name: string | null;
    language: string;
    weight_kg: number;
    age: number;
    primary_goal: string;
    growth_rate: string;
    protein_target_g: number;
  };
  let userCtx: UserContext | null = null;

  // Date currently being viewed in the tracker (defaults to today).
  let viewingDate: string = todayISO();
  // Current chart range in days.
  let chartRange: number = 7;
  // Cached daily_weight rows for the active user (keyed by logged_date).
  let weightHistory: Record<string, number> = {};

  // The latest set of meals loaded — used to build the summary context and to
  // decide when to refresh the daily summary card.
  let currentMeals: Array<{
    meal_slot: string;
    total_protein_g: number;
    food_items: FoodItem[];
    ai_feedback?: string | null;
  }> = [];

  // Last AI summary signature (joined slots + total) so we don't refetch when
  // nothing changed.
  let lastSummarySig: string | null = null;

  // ===== View routing =====
  const VIEWS = ["tracker-loading", "tracker-anon", "tracker-intake", "tracker-app"];
  function showView(id: string) {
    VIEWS.forEach((v) => {
      const el = document.getElementById(v);
      if (!el) return;
      el.toggleAttribute("hidden", v !== id);
    });
  }

  // ===== Intake step UI =====
  function showStep(n: number) {
    intakeState.step = n;
    document.querySelectorAll<HTMLElement>("#tracker-intake .tk-step").forEach((el) => {
      el.classList.toggle("active", Number(el.dataset.step) === n);
    });
    document.querySelectorAll<HTMLElement>("#tracker-intake .tk-dot").forEach((dot) => {
      const s = Number(dot.dataset.step);
      dot.classList.toggle("active", s === n);
      dot.classList.toggle("done", s < n);
    });
  }

  function validateStep(n: number): boolean {
    if (n === 1) {
      const v = Number((document.getElementById("intake-weight") as HTMLInputElement).value);
      return v >= 20 && v <= 200;
    }
    if (n === 2) {
      const v = Number((document.getElementById("intake-age") as HTMLInputElement).value);
      return v >= 8 && v <= 25;
    }
    if (n === 3) {
      const v = Number((document.getElementById("intake-height") as HTMLInputElement).value);
      return v >= 100 && v <= 220;
    }
    if (n === 4) return !!intakeState.growth;
    if (n === 5) return !!intakeState.goal;
    return true;
  }

  function refreshNextButtons() {
    const step = intakeState.step;
    const next = document.querySelector<HTMLButtonElement>(
      `#tracker-intake .tk-step[data-step="${step}"] .tk-next-btn`
    );
    if (next) next.disabled = !validateStep(step);
  }

  function resetIntake() {
    intakeState.step = 1;
    intakeState.weight = null;
    intakeState.height = null;
    intakeState.age = null;
    intakeState.growth = null;
    intakeState.goal = null;
    intakeState.protein = null;
    const w = document.getElementById("intake-weight") as HTMLInputElement | null;
    const h = document.getElementById("intake-height") as HTMLInputElement | null;
    const a = document.getElementById("intake-age") as HTMLInputElement | null;
    if (w) w.value = "";
    if (h) h.value = "";
    if (a) a.value = "";
    document.querySelectorAll("#tracker-intake .tk-choice").forEach((b) => b.classList.remove("selected"));
    document.querySelectorAll<HTMLButtonElement>("#tracker-intake .tk-next-btn").forEach((b) => (b.disabled = false));
    refreshNextButtons();
    showStep(1);
  }

  function wireIntake() {
    document.querySelectorAll<HTMLButtonElement>("#tracker-intake .tk-next-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const current = intakeState.step;
        if (!validateStep(current)) return;

        if (current === 1) {
          intakeState.weight = Number((document.getElementById("intake-weight") as HTMLInputElement).value);
        } else if (current === 2) {
          intakeState.age = Number((document.getElementById("intake-age") as HTMLInputElement).value);
        } else if (current === 3) {
          intakeState.height = Number((document.getElementById("intake-height") as HTMLInputElement).value);
        }

        const nextStep = Number(btn.dataset.next);

        if (nextStep === 6) {
          intakeState.protein = calculateProteinTarget(
            intakeState.weight as number,
            intakeState.growth as string,
            intakeState.goal as string
          );
          const proteinEl = document.getElementById("result-protein");
          if (proteinEl) proteinEl.textContent = String(intakeState.protein);
          // Result detail line — short, lang-aware.
          const goalKeyMap: Record<string, string> = {
            muscle_gain: "tracker.intake.goal.muscle",
            maintenance: "tracker.intake.goal.maintain",
            recomposition: "tracker.intake.goal.recomp",
            fat_loss: "tracker.intake.goal.fatLoss",
          };
          const growthKeyMap: Record<string, string> = {
            fast: "coach.growth.fast",
            moderate: "coach.growth.moderate",
            slow: "coach.growth.slow",
          };
          const detail = document.getElementById("result-detail");
          if (detail) {
            const wKg = `${intakeState.weight}${t("tracker.intake.weightUnit")}`;
            const goalText = t(goalKeyMap[intakeState.goal!] || "tracker.intake.goal.muscle");
            const growthText = t(growthKeyMap[intakeState.growth!] || "coach.growth.moderate");
            detail.textContent = isZh()
              ? `根據 ${wKg}、${growthText}、目標:${goalText}。`
              : `Based on ${wKg}, ${growthText.toLowerCase()} growth, goal: ${goalText}.`;
          }
        }

        showStep(nextStep);
      });
    });

    document.querySelectorAll<HTMLButtonElement>("#tracker-intake [data-back]").forEach((btn) => {
      btn.addEventListener("click", () => showStep(Number(btn.dataset.back)));
    });

    ["intake-weight", "intake-age", "intake-height"].forEach((id) => {
      document.getElementById(id)?.addEventListener("input", refreshNextButtons);
    });

    document.querySelectorAll<HTMLButtonElement>("#growth-choices .tk-choice").forEach((btn) => {
      btn.addEventListener("click", () => {
        document.querySelectorAll("#growth-choices .tk-choice").forEach((b) => b.classList.remove("selected"));
        btn.classList.add("selected");
        intakeState.growth = btn.dataset.value as string;
        refreshNextButtons();
      });
    });

    document.querySelectorAll<HTMLButtonElement>("#goal-choices .tk-choice").forEach((btn) => {
      btn.addEventListener("click", () => {
        document.querySelectorAll("#goal-choices .tk-choice").forEach((b) => b.classList.remove("selected"));
        btn.classList.add("selected");
        intakeState.goal = btn.dataset.value as string;
        refreshNextButtons();
      });
    });

    document.getElementById("intake-finish")?.addEventListener("click", async () => {
      const msg = document.getElementById("intake-msg");
      const btn = document.getElementById("intake-finish") as HTMLButtonElement;
      if (!msg || !btn) return;
      msg.textContent = "";
      msg.className = "tk-form-msg";
      btn.disabled = true;

      try {
        const sb = (window as any).supabaseClient;
        const { data: { user } } = await sb.auth.getUser();
        if (!user) throw new Error("Not signed in");

        const { error } = await sb.from("baseline_intake").upsert(
          {
            user_id: user.id,
            weight_kg: intakeState.weight,
            height_cm: intakeState.height,
            age: intakeState.age,
            growth_rate: intakeState.growth,
            primary_goal: intakeState.goal,
            protein_target_g: intakeState.protein,
          },
          { onConflict: "user_id" }
        );
        if (error) throw error;

        await sb.from("daily_weight").upsert(
          {
            user_id: user.id,
            weight_kg: intakeState.weight,
            logged_date: todayISO(),
          },
          { onConflict: "user_id,logged_date" }
        );

        await loadAppShell();
        showView("tracker-app");
      } catch (err: any) {
        console.error(err);
        msg.textContent = err.message || t("tracker.intake.couldNotSave");
        msg.classList.add("error");
        btn.disabled = false;
      }
    });
  }

  function updateProgressBar(currentG: number, targetG: number) {
    const curEl = document.getElementById("app-progress-current");
    const targetEl = document.getElementById("app-progress-target");
    const fillEl = document.getElementById("app-progress-fill") as HTMLElement | null;
    const pctEl = document.getElementById("app-progress-pct");
    const current = Math.round(currentG * 10) / 10;
    const target = Math.max(0, Math.round(targetG * 10) / 10);
    const rawPct = target > 0 ? Math.round((current / target) * 100) : 0;
    const fillPct = Math.min(100, rawPct);
    if (curEl) curEl.textContent = String(current);
    if (targetEl) targetEl.textContent = String(target);
    if (fillEl) fillEl.style.width = fillPct + "%";
    if (pctEl) pctEl.textContent = rawPct + "%";
  }

  function renderMealGrid(loggedMeals: any[], yesterdayMeals: any[] = [], readOnly: boolean = false) {
    lastRenderedMeals = { meals: loggedMeals, yesterday: yesterdayMeals, readOnly };
    const grid = document.getElementById("meal-grid");
    if (!grid) return;
    const loggedBySlot: Record<string, any> = {};
    loggedMeals.forEach((m: any) => { loggedBySlot[m.meal_slot] = m; });
    const yesterdayBySlot: Record<string, any> = {};
    yesterdayMeals.forEach((m: any) => { yesterdayBySlot[m.meal_slot] = m; });

    grid.innerHTML = "";
    MEAL_SLOTS.forEach((slot) => {
      const label = slotLabel(slot);
      const logged = loggedBySlot[slot.key];
      const yesterday = yesterdayBySlot[slot.key];
      const card = document.createElement("div");
      const interactive = !readOnly || !!logged;
      card.className =
        "tk-meal-slot" +
        (logged ? " logged" : "") +
        (readOnly ? " tk-meal-slot-readonly" : "");
      if (interactive) {
        card.setAttribute("role", "button");
        card.setAttribute("tabindex", "0");
      }
      card.setAttribute("aria-label", label);

      const showRepeat =
        !readOnly &&
        !logged &&
        yesterday &&
        Array.isArray(yesterday.food_items) &&
        yesterday.food_items.length > 0;

      const hasFeedback = !!(logged && typeof logged.ai_feedback === "string" && logged.ai_feedback.trim());
      let html = `<span class="tk-slot-name">${label}${hasFeedback ? `<span class="tk-slot-feedback-dot" aria-label="${t("tracker.feedback.coachAriaLabel")}"></span>` : ''}</span>`;
      if (logged) {
        html += `<span class="tk-slot-status">${t("tracker.meal.logged")} · ${logged.total_protein_g || 0}g</span>`;
      } else if (readOnly) {
        html += `<span class="tk-slot-status">${t("tracker.meal.notLogged")}</span>`;
      } else {
        html += `<button class="tk-log-btn" type="button">${t("tracker.meal.logBtn")}</button>`;
        if (showRepeat) {
          const total = Math.round((yesterday.total_protein_g || 0) * 10) / 10;
          html += `<button class="tk-repeat-btn" type="button" data-repeat="${slot.key}">${t("tracker.meal.repeatYesterday")} · ${total}g</button>`;
        }
      }
      card.innerHTML = html;

      const open = (prefill?: any[]) => {
        const fn = (window as any).openMealLog;
        if (typeof fn === "function") fn(slot.key, label, prefill, viewingDate);
      };

      if (interactive) {
        card.addEventListener("click", (e) => {
          const target = e.target as HTMLElement;
          const repeatEl = target.closest("[data-repeat]") as HTMLElement | null;
          if (repeatEl) {
            e.stopPropagation();
            if (!readOnly) open(yesterday?.food_items || []);
            return;
          }
          // Past days are read-only — only allow viewing logged meals.
          if (readOnly && !logged) return;
          open(logged?.food_items || undefined);
        });

        card.addEventListener("keydown", (e) => {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            if (readOnly && !logged) return;
            open(logged?.food_items || undefined);
          }
        });
      }

      grid.appendChild(card);
    });
  }

  function sumMealsProtein(meals: any[]): number {
    return meals.reduce((acc: number, m: any) => acc + (Number(m.total_protein_g) || 0), 0);
  }

  async function loadAppShell() {
    const sb = (window as any).supabaseClient;
    const { data: { user } } = await sb.auth.getUser();
    if (!user) return;

    const today = todayISO();
    const isToday = viewingDate === today;
    // Always reference yesterday relative to the viewing date for the
    // "repeat yesterday" button.
    const yISO = addDaysISO(viewingDate, -1);

    const [
      { data: profile },
      { data: baseline },
      { data: meals },
      { data: yMeals },
      { data: weights },
    ] = await Promise.all([
      sb.from("user_profiles").select("full_name, email, language").eq("id", user.id).maybeSingle(),
      sb.from("baseline_intake")
        .select("protein_target_g, weight_kg, age, primary_goal, growth_rate")
        .eq("user_id", user.id)
        .maybeSingle(),
      sb.from("meal_logs")
        .select("meal_slot, total_protein_g, food_items, ai_feedback")
        .eq("user_id", user.id)
        .eq("logged_date", viewingDate),
      sb.from("meal_logs")
        .select("meal_slot, total_protein_g, food_items")
        .eq("user_id", user.id)
        .eq("logged_date", yISO),
      sb.from("daily_weight")
        .select("logged_date, weight_kg")
        .eq("user_id", user.id)
        .order("logged_date", { ascending: true }),
    ]);

    const name = profile?.full_name
      || user.user_metadata?.full_name
      || (user.email ? user.email.split("@")[0] : "athlete");
    const firstName = String(name).split(" ")[0];
    (window as any).__riseFirstName = firstName;

    const hello = document.getElementById("app-hello");
    const dateEl = document.getElementById("app-date");
    if (hello) hello.textContent = `${t("tracker.welcomeBack")}, ${firstName}`;
    if (dateEl) dateEl.textContent = formatDateShort(isoToDate(viewingDate));

    // Past day badge + disable next arrow when at today.
    const pastBadge = document.getElementById("app-past-badge");
    if (pastBadge) pastBadge.toggleAttribute("hidden", isToday);
    const nextBtn = document.getElementById("app-date-next") as HTMLButtonElement | null;
    if (nextBtn) nextBtn.disabled = isToday;

    // Meals section title reflects the viewing date.
    const mealsTitle = document.getElementById("app-meals-title");
    if (mealsTitle) mealsTitle.textContent = isToday ? t("tracker.meals.today") : t("tracker.meals.other");

    const target = baseline?.protein_target_g || 0;
    currentTarget = target;
    const tEl = document.getElementById("app-protein-target");
    if (tEl) tEl.textContent = String(target);

    userCtx = {
      user_id: user.id,
      full_name: profile?.full_name || null,
      // AI feedback follows the active portal language so the response matches
      // the UI the user is currently looking at.
      language: getLang(),
      weight_kg: Number(baseline?.weight_kg) || 0,
      age: Number(baseline?.age) || 0,
      primary_goal: String(baseline?.primary_goal || "muscle_gain"),
      growth_rate: String(baseline?.growth_rate || "moderate"),
      protein_target_g: Number(target) || 0,
    };

    // Cache weight history and render widget + chart.
    weightHistory = {};
    (weights || []).forEach((row: any) => {
      if (row?.logged_date) weightHistory[row.logged_date] = Number(row.weight_kg);
    });
    renderWeightWidget();
    renderWeightChart();

    const viewMeals = meals || [];
    currentMeals = viewMeals;
    updateProgressBar(sumMealsProtein(viewMeals), target);
    renderMealGrid(viewMeals, yMeals || [], !isToday);

    // Only show / refresh the AI daily summary on today's view. Past days
    // get a static, non-AI experience.
    if (isToday && viewMeals.length >= 3) {
      const sig = viewMeals
        .map((m) => `${m.meal_slot}:${m.total_protein_g}`)
        .sort()
        .join("|");
      if (sig !== lastSummarySig) {
        lastSummarySig = sig;
        refreshDailySummary().catch((e) => console.warn("summary refresh", e));
      }
    } else {
      hideSummaryCard();
      lastSummarySig = null;
    }
  }

  // ===== Weight widget =====
  function setWeightMsg(text: string, kind: "" | "error" | "success" = "") {
    const msg = document.getElementById("app-weight-msg");
    if (!msg) return;
    msg.textContent = text;
    msg.className = "tk-form-msg" + (kind ? ` ${kind}` : "");
  }

  function showWeightNotice(text: string) {
    const el = document.getElementById("app-weight-notice");
    if (!el) return;
    el.textContent = text;
    el.removeAttribute("hidden");
    setTimeout(() => el.setAttribute("hidden", ""), 6000);
  }

  function renderWeightWidget() {
    const card = document.getElementById("app-weight-card");
    const label = card?.querySelector(".tk-weight-label") as HTMLElement | null;
    const inputRow = document.getElementById("app-weight-input-row");
    const loggedRow = document.getElementById("app-weight-logged-row");
    const valueEl = document.getElementById("app-weight-value");
    const input = document.getElementById("app-weight-input") as HTMLInputElement | null;
    const logBtn = document.getElementById("app-weight-log-btn") as HTMLButtonElement | null;
    const editBtn = document.getElementById("app-weight-edit-btn") as HTMLButtonElement | null;
    if (!card || !inputRow || !loggedRow) return;

    const today = todayISO();
    const isToday = viewingDate === today;
    const weight = weightHistory[viewingDate];
    const kg = t("tracker.intake.weightUnit");

    if (label) label.textContent = isToday ? t("tracker.weight.todayLabel") : t("tracker.weight.label");

    // Past days: read-only. Show value if logged, otherwise show empty state.
    if (!isToday) {
      inputRow.setAttribute("hidden", "");
      if (typeof weight === "number") {
        loggedRow.removeAttribute("hidden");
        if (valueEl) valueEl.textContent = `${weight.toFixed(1)} ${kg}`;
        if (editBtn) editBtn.disabled = true;
      } else {
        loggedRow.setAttribute("hidden", "");
      }
      setWeightMsg(typeof weight === "number" ? "" : t("tracker.weight.noneToday"));
      return;
    }

    // Today: editable.
    if (editBtn) editBtn.disabled = false;
    if (typeof weight === "number") {
      inputRow.setAttribute("hidden", "");
      loggedRow.removeAttribute("hidden");
      if (valueEl) valueEl.textContent = t("tracker.weight.valueToday", { n: weight.toFixed(1) });
      if (input) input.value = String(Math.round(weight * 10) / 10);
    } else {
      loggedRow.setAttribute("hidden", "");
      inputRow.removeAttribute("hidden");
      if (input) input.value = "";
    }
    setWeightMsg("");
    if (logBtn) logBtn.disabled = false;
  }

  async function saveWeight(newWeight: number) {
    if (!userCtx) return;
    const sb = (window as any).supabaseClient;
    const logBtn = document.getElementById("app-weight-log-btn") as HTMLButtonElement | null;

    if (!(newWeight >= 20 && newWeight <= 200)) {
      setWeightMsg(t("tracker.weight.enterValid"), "error");
      return;
    }

    if (logBtn) logBtn.disabled = true;
    setWeightMsg(t("common.saving"));

    try {
      // Upsert daily_weight for today.
      const today = todayISO();
      const { error: wErr } = await sb.from("daily_weight").upsert(
        {
          user_id: userCtx.user_id,
          weight_kg: newWeight,
          logged_date: today,
        },
        { onConflict: "user_id,logged_date" }
      );
      if (wErr) throw wErr;

      // If the new weight differs from the baseline weight, recalculate the
      // protein target and update baseline_intake.
      const baselineWeight = Number(userCtx.weight_kg) || 0;
      let newTarget = userCtx.protein_target_g;
      let recalculated = false;
      if (Math.abs(newWeight - baselineWeight) >= 0.05) {
        newTarget = calculateProteinTarget(newWeight, userCtx.growth_rate, userCtx.primary_goal);
        recalculated = true;

        const { error: bErr } = await sb.from("baseline_intake").upsert(
          {
            user_id: userCtx.user_id,
            weight_kg: newWeight,
            age: userCtx.age,
            growth_rate: userCtx.growth_rate,
            primary_goal: userCtx.primary_goal,
            protein_target_g: newTarget,
          },
          { onConflict: "user_id" }
        );
        if (bErr) throw bErr;

        // Update cached context + UI.
        userCtx.weight_kg = newWeight;
        userCtx.protein_target_g = newTarget;
        currentTarget = newTarget;
        const tEl = document.getElementById("app-protein-target");
        if (tEl) tEl.textContent = String(newTarget);
        updateProgressBar(sumMealsProtein(currentMeals), newTarget);
      }

      weightHistory[today] = newWeight;
      renderWeightWidget();
      renderWeightChart();

      if (recalculated) {
        showWeightNotice(t("tracker.weight.targetUpdated", { n: newTarget }));
      } else {
        setWeightMsg(t("tracker.weight.logged"), "success");
        setTimeout(() => setWeightMsg(""), 2500);
      }
    } catch (err: any) {
      console.error(err);
      setWeightMsg(err.message || "Could not save weight.", "error");
    } finally {
      if (logBtn) logBtn.disabled = false;
    }
  }

  function wireWeightWidget() {
    const logBtn = document.getElementById("app-weight-log-btn");
    const input = document.getElementById("app-weight-input") as HTMLInputElement | null;
    const editBtn = document.getElementById("app-weight-edit-btn");

    logBtn?.addEventListener("click", () => {
      const v = Number(input?.value);
      if (!v) {
        setWeightMsg("Enter your weight in kg.", "error");
        return;
      }
      saveWeight(v);
    });

    input?.addEventListener("keydown", (e) => {
      if ((e as KeyboardEvent).key === "Enter") {
        e.preventDefault();
        logBtn?.dispatchEvent(new Event("click"));
      }
    });

    editBtn?.addEventListener("click", () => {
      if (viewingDate !== todayISO()) return;
      const inputRow = document.getElementById("app-weight-input-row");
      const loggedRow = document.getElementById("app-weight-logged-row");
      if (!inputRow || !loggedRow || !input) return;
      loggedRow.setAttribute("hidden", "");
      inputRow.removeAttribute("hidden");
      const today = todayISO();
      const existing = weightHistory[today];
      if (typeof existing === "number") input.value = String(existing);
      input.focus();
      input.select();
    });
  }

  // ===== Weight trend chart =====
  function renderWeightChart() {
    const body = document.getElementById("app-chart-body");
    const empty = document.getElementById("app-chart-empty");
    if (!body || !empty) return;

    // Build the date range ending at today.
    const today = todayISO();
    const days: string[] = [];
    for (let i = chartRange - 1; i >= 0; i--) {
      days.push(addDaysISO(today, -i));
    }
    const points = days
      .map((iso) => ({ iso, w: weightHistory[iso] }))
      .filter((p) => typeof p.w === "number") as Array<{ iso: string; w: number }>;

    if (points.length === 0) {
      body.innerHTML = "";
      empty.removeAttribute("hidden");
      body.appendChild(empty);
      return;
    }

    empty.setAttribute("hidden", "");

    // SVG geometry. The viewBox is fixed; the container scales it to 100%.
    const W = 520;
    const H = 160;
    const padL = 36;
    const padR = 30;
    const padT = 16;
    const padB = 28;
    const innerW = W - padL - padR;
    const innerH = H - padT - padB;

    const weights = points.map((p) => p.w);
    let minW = Math.min(...weights);
    let maxW = Math.max(...weights);
    if (minW === maxW) {
      minW -= 1;
      maxW += 1;
    } else {
      const pad = (maxW - minW) * 0.15;
      minW -= pad;
      maxW += pad;
    }

    const xFor = (iso: string) => {
      const idx = days.indexOf(iso);
      if (days.length === 1) return padL + innerW / 2;
      return padL + (idx / (days.length - 1)) * innerW;
    };
    const yFor = (w: number) => {
      const t = (w - minW) / (maxW - minW);
      return padT + (1 - t) * innerH;
    };

    // Gridlines (3 horizontal).
    const gridLines: string[] = [];
    const labels: string[] = [];
    for (let i = 0; i < 3; i++) {
      const y = padT + (i / 2) * innerH;
      const w = maxW - (i / 2) * (maxW - minW);
      gridLines.push(
        `<line x1="${padL}" y1="${y.toFixed(1)}" x2="${padL + innerW}" y2="${y.toFixed(1)}" stroke="var(--rise-neutral-100)" stroke-width="1" />`
      );
      labels.push(
        `<text x="${padL - 6}" y="${(y + 3).toFixed(1)}" text-anchor="end" font-size="10" font-family="var(--font-body)" fill="var(--rise-neutral-400)">${w.toFixed(1)}</text>`
      );
    }

    // X-axis date labels: first, middle, last.
    const xLabelIndices = days.length <= 2 ? [0, days.length - 1] : [0, Math.floor((days.length - 1) / 2), days.length - 1];
    const xLabels = xLabelIndices.map((idx) => {
      const iso = days[idx];
      const d = isoToDate(iso);
      const text = d.toLocaleDateString(undefined, { month: "short", day: "numeric" });
      const x = xFor(iso);
      return `<text x="${x.toFixed(1)}" y="${H - 8}" text-anchor="middle" font-size="10" font-family="var(--font-body)" fill="var(--rise-neutral-400)">${text}</text>`;
    });

    const path = points
      .map((p, i) => `${i === 0 ? "M" : "L"} ${xFor(p.iso).toFixed(1)} ${yFor(p.w).toFixed(1)}`)
      .join(" ");

    const dots = points
      .map(
        (p) =>
          `<circle cx="${xFor(p.iso).toFixed(1)}" cy="${yFor(p.w).toFixed(1)}" r="3.5" fill="var(--rise-red)" stroke="var(--rise-white)" stroke-width="1.5"><title>${p.iso}: ${p.w.toFixed(1)} kg</title></circle>`
      )
      .join("");

    const svg = `<svg viewBox="0 0 ${W} ${H}" preserveAspectRatio="xMidYMid meet" aria-label="Weight trend chart" role="img">
      ${gridLines.join("")}
      ${labels.join("")}
      <path d="${path}" fill="none" stroke="var(--rise-red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      ${dots}
      ${xLabels.join("")}
    </svg>`;

    body.innerHTML = svg;
  }

  function wireChartToggle() {
    document.querySelectorAll<HTMLButtonElement>(".tk-chart-toggle-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".tk-chart-toggle-btn").forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        chartRange = Number(btn.dataset.range) || 7;
        renderWeightChart();
      });
    });
  }

  // ===== Date navigation =====
  function wireDateNav() {
    document.getElementById("app-date-prev")?.addEventListener("click", () => {
      viewingDate = addDaysISO(viewingDate, -1);
      loadAppShell().catch((e) => console.warn("loadAppShell prev", e));
    });
    document.getElementById("app-date-next")?.addEventListener("click", () => {
      const next = addDaysISO(viewingDate, 1);
      if (next > todayISO()) return;
      viewingDate = next;
      loadAppShell().catch((e) => console.warn("loadAppShell next", e));
    });
  }

  // ===== AI feedback card =====
  let feedbackDismissTimer: ReturnType<typeof setTimeout> | null = null;

  function hideFeedbackCard(animate = true) {
    const card = document.getElementById("app-feedback-card");
    if (!card) return;
    if (feedbackDismissTimer) {
      clearTimeout(feedbackDismissTimer);
      feedbackDismissTimer = null;
    }
    if (animate && !card.hasAttribute("hidden")) {
      card.classList.add("tk-dismissing");
      setTimeout(() => {
        card.classList.remove("tk-dismissing", "tk-feedback-loading");
        card.setAttribute("hidden", "");
      }, 200);
    } else {
      card.classList.remove("tk-dismissing", "tk-feedback-loading");
      card.setAttribute("hidden", "");
    }
  }

  function showFeedbackCard(text: string, mock: boolean) {
    const card = document.getElementById("app-feedback-card");
    const textEl = document.getElementById("app-feedback-text");
    const mockEl = document.getElementById("app-feedback-mock");
    if (!card || !textEl || !mockEl) return;
    card.classList.remove("tk-dismissing", "tk-feedback-loading");
    textEl.textContent = text;
    mockEl.setAttribute("hidden", "");
    card.removeAttribute("hidden");
    card.scrollIntoView({ behavior: "smooth", block: "nearest" });

    if (feedbackDismissTimer) clearTimeout(feedbackDismissTimer);
    feedbackDismissTimer = setTimeout(() => hideFeedbackCard(true), 10000);
  }

  function showFeedbackLoading() {
    const card = document.getElementById("app-feedback-card");
    const textEl = document.getElementById("app-feedback-text");
    const mockEl = document.getElementById("app-feedback-mock");
    if (!card || !textEl || !mockEl) return;
    if (feedbackDismissTimer) {
      clearTimeout(feedbackDismissTimer);
      feedbackDismissTimer = null;
    }
    textEl.textContent = t("tracker.feedback.thinking");
    mockEl.setAttribute("hidden", "");
    card.classList.add("tk-feedback-loading");
    card.classList.remove("tk-dismissing");
    card.removeAttribute("hidden");
  }

  // ===== AI daily summary card =====
  function hideSummaryCard() {
    const card = document.getElementById("app-summary-card");
    if (card) card.setAttribute("hidden", "");
  }

  function renderSummaryCard(result: { summary: string; highlight: string; tip: string; mock: boolean }) {
    const card = document.getElementById("app-summary-card");
    const textEl = document.getElementById("app-summary-text");
    const highlightRow = document.getElementById("app-summary-highlight-row");
    const highlightEl = document.getElementById("app-summary-highlight");
    const tipRow = document.getElementById("app-summary-tip-row");
    const tipEl = document.getElementById("app-summary-tip");
    const mockEl = document.getElementById("app-summary-mock");
    if (!card || !textEl || !highlightRow || !highlightEl || !tipRow || !tipEl || !mockEl) return;

    textEl.textContent = result.summary;
    if (result.highlight) {
      highlightEl.textContent = result.highlight;
      highlightRow.removeAttribute("hidden");
    } else {
      highlightRow.setAttribute("hidden", "");
    }
    if (result.tip) {
      tipEl.textContent = result.tip;
      tipRow.removeAttribute("hidden");
    } else {
      tipRow.setAttribute("hidden", "");
    }
    mockEl.setAttribute("hidden", "");
    card.removeAttribute("hidden");
  }

  async function refreshDailySummary() {
    if (!userCtx) return;
    if (currentMeals.length < 3) return;
    const ctx = {
      meals: currentMeals.map((m) => ({
        meal_slot: m.meal_slot,
        food_items: (m.food_items || []) as FoodItem[],
        total_protein_g: Number(m.total_protein_g) || 0,
      })),
      daily_total_g: sumMealsProtein(currentMeals),
      protein_target_g: userCtx.protein_target_g,
      weight_kg: userCtx.weight_kg,
      age: userCtx.age,
      primary_goal: userCtx.primary_goal,
      language: userCtx.language,
      full_name: userCtx.full_name || undefined,
    };
    try {
      const result = await getDailySummary(ctx);
      renderSummaryCard(result);
    } catch (err) {
      console.warn("daily-summary failed:", err);
    }
  }

  function timeOfDay(): string {
    const d = new Date();
    return `${String(d.getHours()).padStart(2, "0")}:${String(d.getMinutes()).padStart(2, "0")}`;
  }

  async function handleMealLogged(detail: {
    slot: string;
    total: number;
    items: FoodItem[];
  }) {
    // Always refresh grid + progress bar first so the user sees the result of
    // their save immediately.
    await loadAppShell();

    if (!userCtx) return;
    if (!detail?.slot) return;

    showFeedbackLoading();

    const daily_total_g = sumMealsProtein(currentMeals);
    const ctx = {
      meal_slot: detail.slot,
      food_items: detail.items || [],
      total_protein_g: Number(detail.total) || 0,
      daily_total_g,
      protein_target_g: userCtx.protein_target_g,
      weight_kg: userCtx.weight_kg,
      age: userCtx.age,
      primary_goal: userCtx.primary_goal,
      time_of_day: timeOfDay(),
      language: userCtx.language,
      full_name: userCtx.full_name || undefined,
    };

    let result: { feedback: string; mock: boolean };
    try {
      result = await getMealFeedback(ctx);
    } catch (err) {
      console.warn("ai-feedback failed:", err);
      hideFeedbackCard(false);
      return;
    }

    showFeedbackCard(result.feedback, result.mock);

    // Persist the feedback text on the meal_logs row so it survives reloads.
    try {
      const sb = (window as any).supabaseClient;
      await sb
        .from("meal_logs")
        .update({ ai_feedback: result.feedback })
        .eq("user_id", userCtx.user_id)
        .eq("meal_slot", detail.slot)
        .eq("logged_date", viewingDate);
    } catch (err) {
      console.warn("persist ai_feedback failed:", err);
    }

    // If 3+ meals are logged now, refresh the summary card. Force refresh
    // because the new meal changed the picture even if the signature happens
    // to repeat.
    if (currentMeals.length >= 3) {
      lastSummarySig = null;
      await refreshDailySummary();
    }
  }

  // Refresh the grid + progress bar (and AI feedback) when a meal is logged.
  window.addEventListener("meal-logged", (e: Event) => {
    const detail = (e as CustomEvent).detail || {};
    handleMealLogged({
      slot: detail.slot,
      total: Number(detail.total) || 0,
      items: Array.isArray(detail.items) ? detail.items : [],
    });
  });

  function wireFeedbackCardControls() {
    document.getElementById("app-feedback-close")?.addEventListener("click", () => hideFeedbackCard(true));
  }

  async function ensureProfile(user: any) {
    const sb = (window as any).supabaseClient;
    const { data: existing } = await sb
      .from("user_profiles")
      .select("id")
      .eq("id", user.id)
      .maybeSingle();
    if (existing) return;
    const full_name =
      (user.user_metadata && (user.user_metadata.full_name || user.user_metadata.name)) || null;
    await sb.from("user_profiles").insert({
      id: user.id,
      email: user.email,
      full_name,
      role: "athlete",
      team_id: "rise-hk",
    });
  }

  async function hasBaseline(userId: string): Promise<boolean> {
    const sb = (window as any).supabaseClient;
    const { data } = await sb
      .from("baseline_intake")
      .select("id")
      .eq("user_id", userId)
      .maybeSingle();
    return !!data;
  }

  async function routeTracker() {
    const sb = (window as any).supabaseClient;
    if (!sb) {
      setTimeout(routeTracker, 100);
      return;
    }

    const { data: { session } } = await sb.auth.getSession();
    if (!session) {
      showView("tracker-anon");
      sb.auth.onAuthStateChange((_e: string, s: any) => {
        if (s) window.location.reload();
      });
      return;
    }

    await ensureProfile(session.user);
    const done = await hasBaseline(session.user.id);

    if (!done) {
      resetIntake();
      showView("tracker-intake");
      return;
    }

    await loadAppShell();
    showView("tracker-app");
  }

  wireIntake();
  wireFeedbackCardControls();
  wireWeightWidget();
  wireChartToggle();
  wireDateNav();
  wireLangToggle();
  routeTracker();
</script>
