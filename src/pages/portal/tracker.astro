---
// Nutrition Tracker — Day 1 intake + meal grid + photo meal logging.
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import MealLogModal from "../../components/MealLogModal.astro";
---

<BaseLayout title="Nutrition Tracker" description="Track your daily protein and meals — RISE Nutrition Tracker.">
  <Header slot="header" />

  <!-- Minimal app header (standalone PWA only) -->
  <div class="pwa-app-header" aria-hidden="true">
    <img src="/logo-header.png" alt="RISE" class="pwa-app-header-logo" />
  </div>

  <!-- Floating lang toggle -->
  <button id="portal-lang-toggle" class="portal-lang-toggle" type="button" aria-label="Toggle language">中文</button>

  <section class="tracker-page">
    <div class="tracker-shell">
      <!-- Loading -->
      <div id="tracker-loading" class="tracker-view loading-view">
        <div class="tracker-spinner" aria-hidden="true"></div>
      </div>

      <!-- Unauthed -->
      <section id="tracker-anon" class="tracker-view tracker-anon" hidden>
        <h2 class="tracker-anon-title" data-i18n="tracker.anon.title">Sign in to start tracking</h2>
        <p class="tracker-anon-sub" data-i18n="tracker.anon.sub">Your protein target and meals live with your account.</p>
        <button class="tk-btn tk-btn-primary" type="button" data-open-auth data-i18n="common.signupOrLogin">Log in / Sign up</button>
        <a class="tk-btn tk-btn-ghost" href="/portal" data-i18n="common.backToPortal">Back to portal</a>
      </section>

      <!-- INTAKE VIEW: Day 1 -->
      <section id="tracker-intake" class="tracker-view" hidden>
        <header class="tk-topbar">
          <h2 class="tk-h2" data-i18n="tracker.intake.title">Day 1 Setup</h2>
          <div class="tk-progress">
            <span class="tk-dot" data-step="1"></span>
            <span class="tk-dot" data-step="2"></span>
            <span class="tk-dot" data-step="3"></span>
            <span class="tk-dot" data-step="4"></span>
            <span class="tk-dot" data-step="5"></span>
            <span class="tk-dot" data-step="6"></span>
          </div>
        </header>

        <div class="tk-intake-wrap">
          <!-- Step 1: weight -->
          <div class="tk-step active" data-step="1">
            <h3 class="tk-h3" data-i18n="tracker.intake.weightQ">What's your weight?</h3>
            <p class="tk-sub" data-i18n="tracker.intake.weightSub">In kilograms</p>
            <div class="tk-number-input">
              <input type="number" id="intake-weight" min="20" max="200" step="0.1" placeholder="60" inputmode="decimal" />
              <span class="tk-unit" data-i18n="tracker.intake.weightUnit">kg</span>
            </div>
            <button class="tk-btn tk-btn-primary tk-next-btn" data-next="2" type="button" data-i18n="common.next">Next</button>
          </div>

          <!-- Step 2: age -->
          <div class="tk-step" data-step="2">
            <h3 class="tk-h3" data-i18n="tracker.intake.ageQ">How old are you?</h3>
            <p class="tk-sub" data-i18n="tracker.intake.ageSub">Years</p>
            <div class="tk-number-input">
              <input type="number" id="intake-age" min="8" max="25" step="1" placeholder="15" inputmode="numeric" />
              <span class="tk-unit" data-i18n="tracker.intake.ageUnit">yrs</span>
            </div>
            <div class="tk-row">
              <button class="tk-btn tk-btn-ghost" data-back="1" type="button" data-i18n="common.back">Back</button>
              <button class="tk-btn tk-btn-primary tk-next-btn" data-next="3" type="button" data-i18n="common.next">Next</button>
            </div>
          </div>

          <!-- Step 3: height -->
          <div class="tk-step" data-step="3">
            <h3 class="tk-h3">How tall are you?</h3>
            <p class="tk-sub">In centimeters</p>
            <div class="tk-number-input">
              <input type="number" id="intake-height" min="100" max="220" step="0.1" placeholder="170" inputmode="decimal" />
              <span class="tk-unit">cm</span>
            </div>
            <div class="tk-row">
              <button class="tk-btn tk-btn-ghost" data-back="2" type="button" data-i18n="common.back">Back</button>
              <button class="tk-btn tk-btn-primary tk-next-btn" data-next="4" type="button" data-i18n="common.next">Next</button>
            </div>
          </div>

          <!-- Step 4: growth -->
          <div class="tk-step" data-step="4">
            <h3 class="tk-h3" data-i18n="tracker.intake.growthQ">How fast are you growing?</h3>
            <p class="tk-sub" data-i18n="tracker.intake.growthSub">How much have you grown in the last year?</p>
            <div class="tk-choice-list" id="growth-choices">
              <button class="tk-choice" data-value="fast" type="button">
                <strong data-i18n="tracker.intake.growth.fast">Growing fast</strong>
                <small data-i18n="tracker.intake.growth.fastSub">5+ cm/yr</small>
              </button>
              <button class="tk-choice" data-value="moderate" type="button">
                <strong data-i18n="tracker.intake.growth.moderate">Moderate</strong>
                <small data-i18n="tracker.intake.growth.moderateSub">2-5 cm/yr</small>
              </button>
              <button class="tk-choice" data-value="slow" type="button">
                <strong data-i18n="tracker.intake.growth.slow">Slow</strong>
                <small data-i18n="tracker.intake.growth.slowSub">Less than 2 cm/yr</small>
              </button>
            </div>
            <div class="tk-row">
              <button class="tk-btn tk-btn-ghost" data-back="3" type="button" data-i18n="common.back">Back</button>
              <button class="tk-btn tk-btn-primary tk-next-btn" data-next="5" type="button" disabled data-i18n="common.next">Next</button>
            </div>
          </div>

          <!-- Step 5: goal -->
          <div class="tk-step" data-step="5">
            <h3 class="tk-h3" data-i18n="tracker.intake.goalQ">What's your main goal?</h3>
            <p class="tk-sub" data-i18n="tracker.intake.goalSub">Pick one</p>
            <div class="tk-choice-list" id="goal-choices">
              <button class="tk-choice" data-value="muscle_gain" type="button">
                <strong data-i18n="tracker.intake.goal.muscle">Build muscle</strong>
                <small data-i18n="tracker.intake.goal.muscleSub">Add lean mass</small>
              </button>
              <button class="tk-choice" data-value="maintenance" type="button">
                <strong data-i18n="tracker.intake.goal.maintain">Stay the same</strong>
                <small data-i18n="tracker.intake.goal.maintainSub">Maintain weight</small>
              </button>
              <button class="tk-choice" data-value="recomposition" type="button">
                <strong data-i18n="tracker.intake.goal.recomp">Lose fat + build muscle</strong>
                <small data-i18n="tracker.intake.goal.recompSub">Body recomposition</small>
              </button>
              <button class="tk-choice" data-value="fat_loss" type="button">
                <strong data-i18n="tracker.intake.goal.fatLoss">Lose fat</strong>
                <small data-i18n="tracker.intake.goal.fatLossSub">Cut down</small>
              </button>
            </div>
            <div class="tk-row">
              <button class="tk-btn tk-btn-ghost" data-back="4" type="button" data-i18n="common.back">Back</button>
              <button class="tk-btn tk-btn-primary tk-next-btn" data-next="6" type="button" disabled data-i18n="common.calculate">Calculate</button>
            </div>
          </div>

          <!-- Step 6: result -->
          <div class="tk-step" data-step="6">
            <h3 class="tk-h3" data-i18n="tracker.intake.result.title">Your daily protein target</h3>
            <div class="tk-result-card">
              <span class="tk-result-number" id="result-protein">0</span>
              <span class="tk-result-unit" data-i18n="tracker.intake.result.unit">g protein / day</span>
            </div>
            <p class="tk-result-detail" id="result-detail"></p>
            <p class="tk-disclaimer" style="font-size:0.78rem;color:var(--rise-neutral-400);line-height:1.4;margin:8px 0;">RISE Nutrition Tracker provides approximate protein estimates based on AI analysis. This is not medical advice. For specific dietary needs, consult a qualified nutritionist or your coach.</p>
            <button class="tk-btn tk-btn-primary" id="intake-finish" type="button" data-i18n="tracker.intake.startTracking">Start tracking</button>
            <p class="tk-form-msg" id="intake-msg"></p>
          </div>
        </div>
      </section>

      <!-- MAIN APP -->
      <section id="tracker-app" class="tracker-view" hidden>
        <header class="tk-topbar tk-app-bar">
          <div class="tk-topbar-main">
            <p class="tk-hello" id="app-hello" data-i18n="tracker.welcomeBack">Welcome back</p>
            <div class="tk-date-nav">
              <button class="tk-date-arrow" type="button" id="app-date-prev" aria-label="Previous day" data-i18n-attr="tracker.dateArrow.prev:aria-label">‹</button>
              <p class="tk-date" id="app-date"></p>
              <button class="tk-date-arrow" type="button" id="app-date-next" aria-label="Next day" disabled data-i18n-attr="tracker.dateArrow.next:aria-label">›</button>
              <span class="tk-past-badge" id="app-past-badge" hidden data-i18n="tracker.pastDay">Past day</span>
            </div>
          </div>
          <a class="tk-btn tk-btn-ghost tk-btn-small" href="/portal" data-i18n="tracker.portal">Portal</a>
        </header>

        <div class="tk-target-card">
          <span class="tk-target-label" data-i18n="tracker.targetLabel">Your target</span>
          <div class="tk-target-row">
            <span class="tk-target-number" id="app-protein-target">0</span>
            <span class="tk-target-unit" data-i18n="tracker.target.unit">g protein / day</span>
          </div>
        </div>

        <div class="tk-progress-card" id="app-progress-card">
          <div class="tk-progress-head">
            <span class="tk-progress-label" data-i18n="tracker.progress.label">Today's progress</span>
            <span class="tk-progress-amounts">
              <strong id="app-progress-current">0</strong>g / <span id="app-progress-target">0</span>g
            </span>
          </div>
          <div class="tk-progress-track">
            <div class="tk-progress-fill" id="app-progress-fill"></div>
          </div>
          <span class="tk-progress-pct" id="app-progress-pct">0%</span>
        </div>

        <div class="tk-weight-card" id="app-weight-card">
          <div class="tk-weight-head">
            <span class="tk-weight-label" data-i18n="tracker.weight.todayLabel">Today's weight</span>
            <span class="tk-weight-notice" id="app-weight-notice" hidden></span>
          </div>
          <div class="tk-weight-body" id="app-weight-body">
            <div class="tk-weight-input-row" id="app-weight-input-row">
              <input
                type="number"
                id="app-weight-input"
                min="20"
                max="200"
                step="0.1"
                inputmode="decimal"
                placeholder="kg"
                data-i18n-attr="tracker.weight.placeholder:placeholder"
              />
              <button class="tk-weight-log-btn" id="app-weight-log-btn" type="button" data-i18n="tracker.weight.log">Log weight</button>
            </div>
            <div class="tk-weight-logged-row" id="app-weight-logged-row" hidden>
              <span class="tk-weight-value" id="app-weight-value">— kg today</span>
              <button class="tk-weight-edit-btn" id="app-weight-edit-btn" type="button" aria-label="Edit weight">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 20h9"></path>
                  <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4z"></path>
                </svg>
                <span data-i18n="tracker.weight.edit">Edit</span>
              </button>
            </div>
            <p class="tk-form-msg" id="app-weight-msg"></p>
          </div>
        </div>

        <div class="tk-chart-card" id="app-chart-card">
          <div class="tk-chart-head">
            <span class="tk-chart-label" data-i18n="tracker.chart.label">Weight trend</span>
            <div class="tk-chart-toggle">
              <button class="tk-chart-toggle-btn active" type="button" data-range="7" data-i18n="tracker.chart.7d">7 days</button>
              <button class="tk-chart-toggle-btn" type="button" data-range="30" data-i18n="tracker.chart.30d">30 days</button>
            </div>
          </div>
          <div class="tk-chart-body" id="app-chart-body">
            <p class="tk-chart-empty" id="app-chart-empty" data-i18n="tracker.chart.empty">Log your weight daily to see trends</p>
          </div>
        </div>

        <div class="tk-summary-card" id="app-summary-card" hidden>
          <div class="tk-summary-head">
            <span class="tk-summary-label" data-i18n="tracker.summary.label">Coach's daily read</span>
            <span class="tk-summary-mock" id="app-summary-mock" hidden data-i18n="tracker.summary.demo">Demo</span>
          </div>
          <p class="tk-summary-text" id="app-summary-text"></p>
          <div class="tk-summary-row" id="app-summary-highlight-row" hidden>
            <span class="tk-summary-row-label" data-i18n="tracker.summary.bestMeal">Best meal</span>
            <p class="tk-summary-row-text" id="app-summary-highlight"></p>
          </div>
          <div class="tk-summary-row" id="app-summary-tip-row" hidden>
            <span class="tk-summary-row-label" data-i18n="tracker.summary.tryThis">Try this</span>
            <p class="tk-summary-row-text" id="app-summary-tip"></p>
          </div>
        </div>

        <h3 class="tk-section-title" id="app-meals-title" data-i18n="tracker.meals.today">Today's meals</h3>
        <div class="tk-meal-grid" id="meal-grid"></div>

        <div class="tk-feedback-card" id="app-feedback-card" hidden role="status" aria-live="polite">
          <button class="tk-feedback-close" type="button" id="app-feedback-close" aria-label="Dismiss">×</button>
          <div class="tk-feedback-icon" aria-hidden="true">💬</div>
          <div class="tk-feedback-body">
            <div class="tk-feedback-meta">
              <span class="tk-feedback-title" data-i18n="tracker.feedback.coach">Coach</span>
              <span class="tk-feedback-mock" id="app-feedback-mock" hidden data-i18n="tracker.feedback.demo">Demo feedback</span>
            </div>
            <p class="tk-feedback-text" id="app-feedback-text"></p>
          </div>
        </div>
      </section>
    </div>
  </section>

  <MealLogModal />

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* Scoped light-theme tracker styles, matched to the RISE portal aesthetic.
     Prefixed with .tk- / tracker- to avoid collisions with the surrounding site. */
  .tracker-page {
    background: var(--rise-white);
    color: var(--rise-black);
    font-family: var(--font-body);
    min-height: calc(100vh - 6rem);
    padding: var(--space-8) var(--space-4);
  }
  .tracker-shell {
    width: 100%;
    max-width: 520px;
    margin: 0 auto;
  }

  .tracker-view {
    background: transparent;
  }
  .tracker-view[hidden] { display: none !important; }

  .loading-view {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 50vh;
  }
  .tracker-spinner {
    width: 36px;
    height: 36px;
    border: 3px solid var(--rise-neutral-100);
    border-top-color: var(--rise-red);
    border-radius: 50%;
    animation: tk-spin 0.8s linear infinite;
  }
  @keyframes tk-spin { to { transform: rotate(360deg); } }

  .tracker-anon {
    text-align: center;
    padding: var(--space-8) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: center;
  }
  .tracker-anon-title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--rise-black);
    margin: 0;
  }
  .tracker-anon-sub {
    color: var(--rise-neutral-500);
    margin: 0 0 var(--space-3);
  }

  /* ----- Typography ----- */
  .tk-h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0;
    color: var(--rise-black);
  }
  .tk-h3 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--rise-black);
    margin: var(--space-3) 0 0;
  }
  .tk-sub {
    color: var(--rise-neutral-500);
    font-family: var(--font-body);
    font-size: 0.9rem;
    margin: 0 0 var(--space-3);
  }

  /* ----- Topbar ----- */
  .tk-topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-5);
    gap: var(--space-3);
  }
  .tk-app-bar { margin-bottom: var(--space-6); }
  .tk-hello {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 0;
    color: var(--rise-black);
  }
  .tk-date {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--rise-neutral-500);
    margin: 2px 0 0;
  }

  .tk-progress { display: flex; gap: 6px; }
  .tk-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--rise-neutral-200);
    transition: background 0.2s, transform 0.2s;
  }
  .tk-dot.active { background: var(--rise-red); transform: scale(1.2); }
  .tk-dot.done { background: var(--rise-red-dark); }

  /* ----- Buttons ----- */
  .tk-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 18px;
    border-radius: 10px;
    border: 1px solid transparent;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s, transform 0.05s;
    width: 100%;
    text-decoration: none;
  }
  .tk-btn:active { transform: scale(0.98); }
  .tk-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .tk-btn-primary {
    background: var(--rise-red);
    color: var(--rise-white);
  }
  .tk-btn-primary:hover:not(:disabled) { background: var(--rise-red-dark); }
  .tk-btn-ghost {
    background: transparent;
    color: var(--rise-neutral-700);
    border-color: var(--rise-neutral-200);
  }
  .tk-btn-ghost:hover:not(:disabled) {
    border-color: var(--rise-red);
    color: var(--rise-red);
  }
  .tk-btn-small {
    padding: 8px 14px;
    font-size: 0.85rem;
    width: auto;
  }
  .tk-row {
    display: flex;
    gap: 10px;
  }
  .tk-row .tk-btn { flex: 1; }

  /* ----- Intake steps ----- */
  .tk-intake-wrap {
    display: flex;
    flex-direction: column;
  }
  .tk-step {
    display: none;
    flex-direction: column;
    gap: 16px;
    animation: tk-fade 0.2s ease;
  }
  .tk-step.active { display: flex; }
  @keyframes tk-fade {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .tk-number-input {
    display: flex;
    align-items: center;
    background: var(--rise-white);
    border: 1px solid var(--rise-neutral-200);
    border-radius: 12px;
    padding: 0 18px;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .tk-number-input:focus-within {
    border-color: var(--rise-red);
    box-shadow: 0 0 0 3px var(--rise-red-light);
  }
  .tk-number-input input {
    flex: 1;
    background: transparent;
    border: 0;
    padding: 22px 0;
    font-family: var(--font-heading);
    font-size: 2.4rem;
    font-weight: 700;
    text-align: center;
    color: var(--rise-black);
    outline: none;
    width: 100%;
    -moz-appearance: textfield;
  }
  .tk-number-input input::-webkit-outer-spin-button,
  .tk-number-input input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .tk-unit {
    color: var(--rise-neutral-400);
    font-size: 1rem;
    font-weight: 600;
  }

  .tk-choice-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .tk-choice {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    background: var(--rise-white);
    border: 1px solid var(--rise-neutral-200);
    border-radius: 12px;
    padding: 16px 18px;
    color: var(--rise-black);
    cursor: pointer;
    font-family: var(--font-body);
    transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
  }
  .tk-choice strong { font-size: 1.05rem; font-weight: 600; }
  .tk-choice small {
    color: var(--rise-neutral-500);
    font-size: 0.85rem;
    margin-top: 2px;
  }
  .tk-choice:hover {
    border-color: var(--rise-red);
    box-shadow: 0 4px 12px rgba(18, 18, 18, 0.06);
  }
  .tk-choice.selected {
    border-color: var(--rise-red);
    background: var(--rise-red-light);
  }
  .tk-choice.selected:hover { border-color: var(--rise-red); }

  /* ----- Result ----- */
  .tk-result-card {
    background: var(--rise-white);
    border: 1px solid var(--rise-neutral-100);
    border-radius: 12px;
    padding: 32px 20px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    box-shadow: 0 8px 20px rgba(18, 18, 18, 0.06);
  }
  .tk-result-number {
    font-family: var(--font-heading);
    font-size: 4rem;
    font-weight: 700;
    color: var(--rise-red);
    line-height: 1;
  }
  .tk-result-unit {
    color: var(--rise-neutral-500);
    font-size: 0.95rem;
  }
  .tk-result-detail {
    text-align: center;
    color: var(--rise-neutral-500);
    font-size: 0.9rem;
  }
  .tk-form-msg {
    font-size: 0.9rem;
    text-align: center;
    margin: 0;
    min-height: 1.2em;
    color: var(--rise-neutral-500);
  }
  .tk-form-msg.error { color: var(--rise-red-dark); }
  .tk-form-msg.success { color: #15803d; }

  /* ----- App shell ----- */
  .tk-target-card {
    background: linear-gradient(135deg, var(--rise-red), var(--rise-red-dark));
