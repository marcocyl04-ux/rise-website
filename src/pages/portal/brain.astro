    // ── Health ────────────────────────────────────────────────
    async function loadHealth() {
      try {
        const health = await brainFetch("/analyst/health");

        $("#brain-health-outcomes").textContent = health.total_outcomes || 0;
        $("#brain-health-content-count").textContent = health.total_content || 0;
        $("#brain-health-missing").textContent = (health.missing_outcomes || []).length;

        const coverage = health.total_content > 0
          ? Math.round(((health.total_content - (health.missing_outcomes || []).length) / health.total_content) * 100)
          : 0;
        $("#brain-health-coverage").textContent = coverage + "%";

        // Confidence breakdown (simplified)
        const lastOutcome = health.last_outcome_at ? new Date(health.last_outcome_at) : null;
        const daysSince = lastOutcome ? Math.floor((Date.now() - lastOutcome.getTime()) / 86400000) : 999;
        const recencyPct = daysSince <= 2 ? 90 : daysSince <= 7 ? 70 : 40;
        $("#brain-conf-recency-fill").style.width = recencyPct + "%";
        $("#brain-conf-recency-detail").textContent = lastOutcome ? daysSince + " days ago" : "No outcomes yet";

        const volumePct = Math.min(100, (health.total_outcomes || 0) * 4);
        $("#brain-conf-volume-fill").style.width = volumePct + "%";
        $("#brain-conf-volume-detail").textContent = (health.total_outcomes || 0) + " outcomes";

        // Variety and bias (simplified)
        $("#brain-conf-variety-fill").style.width = "80%";
        $("#brain-conf-variety-detail").textContent = "Multiple content types";

        const biasWarning = health.bias_warning || "";
        const biasPct = biasWarning ? 60 : 100;
        $("#brain-conf-bias-fill").style.width = biasPct + "%";
        $("#brain-conf-bias-detail").textContent = biasWarning || "No bias detected";

      } catch (e) {
        console.error("Health load failed:", e);
      }
    }

    // ── Distillation ──────────────────────────────────────────
    async function loadDistillation() {
      try {
        const data = await brainFetch("/distill/status");
        $("#brain-distill-total").textContent = data.total_outcomes || 0;
        $("#brain-distill-done").textContent = data.distilled_outcomes || 0;
        $("#brain-distill-pending").textContent = data.undistilled_outcomes || 0;
        $("#brain-distill-knowledge").textContent = data.distilled_knowledge_nodes || 0;

        const btn = $("#brain-distill-btn");
        if (data.ready_for_distillation) {
          btn.disabled = false;
          btn.textContent = "Run Distillation";
        } else {
          btn.disabled = true;
          btn.textContent = "Not enough outcomes (need 3+)";
        }
      } catch {}
    }

    async function triggerDistillation() {
      const btn = $("#brain-distill-btn");
      const status = $("#brain-distill-status");

      btn.disabled = true;
      btn.textContent = "Running...";
      status.textContent = "Analyzing outcome patterns...";

      try {
        const data = await brainFetch("/distill", { method: "POST" });
        status.textContent = data.patterns_found + " patterns found, " + data.knowledge_nodes_created + " knowledge nodes created.";
        loadDistillation();
      } catch (e) {
        status.textContent = "Failed: " + e.message;
        btn.disabled = false;
        btn.textContent = "Retry";
      }
    }

    const distillBtn = document.getElementById("brain-distill-btn");
    if (distillBtn) distillBtn.addEventListener("click", triggerDistillation);

