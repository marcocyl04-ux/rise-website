    // ── Flash ─────────────────────────────────────────────────
    function showFlash(msg) {
      // Create flash element if it doesn't exist
      let flash = document.getElementById("brain-flash");
      if (!flash) {
        flash = document.createElement("div");
        flash.id = "brain-flash";
        flash.className = "brain-flash";
        document.body.appendChild(flash);
      }
      flash.textContent = msg;
      flash.classList.add("visible");
      setTimeout(() => flash.classList.remove("visible"), 3000);
    }

    // ── Nudge (conditional) ───────────────────────────────────
    function checkNudge() {
      // Show nudge if there are pending outcomes
      const nudgeBanner = $("#brain-nudge-banner");
      const nudgeText = $("#brain-nudge-text");
      if (nudgeBanner && nudgeText) {
        // This would be based on actual data health check
        // For now, show a generic nudge after 1.5s
        setTimeout(() => {
          nudgeText.innerHTML = '<strong>I need your data.</strong> Report outcomes on your recent posts so I can improve your briefs. Without this data, my confidence in recommendations will drop.';
          nudgeBanner.classList.remove("hidden");
        }, 1500);
      }
    }

    // ── Boot ──────────────────────────────────────────────────
    initBrain();
    setupTabs();
    setupFeed();
    setupConsult();
    setupOnboarding();
    checkNudge();
  </script>
</BaseLayout>

