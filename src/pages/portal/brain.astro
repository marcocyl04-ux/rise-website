<style>
  /* ── Layout ────────────────────────────────────────────── */
  .brain-loading {
    display: flex; align-items: center; justify-content: center; min-height: 60vh;
  }
  .brain-spinner {
    width: 32px; height: 32px; border: 3px solid var(--rise-neutral-100);
