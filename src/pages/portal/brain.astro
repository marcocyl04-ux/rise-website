---
// /portal/brain — RISE Marketing Brain (founder-only)
// Authenticates via Supabase, checks role, talks to Brain API.
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

// Brain API URL — set PUBLIC_BRAIN_API_URL in .env for production.
// Falls back to localhost for local dev.
const BRAIN_API = import.meta.env.PUBLIC_BRAIN_API_URL || "http://localhost:8000";
---

<BaseLayout title="Marketing Brain" description="RISE strategic marketing intelligence engine.">
  <Header slot="header" />

  <!-- PWA app header -->
  <div class="pwa-app-header" aria-hidden="true">
    <img src="/logo-header.png" alt="RISE" class="pwa-app-header-logo" />
  </div>

  <!-- Loading -->
  <section id="brain-loading" class="brain-loading">
    <div class="brain-spinner" aria-hidden="true"></div>
  </section>

  <!-- Not logged in -->
  <section id="brain-anon" class="brain-anon section" hidden>
    <div class="container brain-narrow">
      <h1 class="brain-anon-title">Sign in to your portal</h1>
      <p class="brain-anon-sub">You need to be logged in to access the Marketing Brain.</p>
      <div class="brain-anon-actions">
        <button class="btn-primary" type="button" data-open-auth>Log in</button>
        <a class="btn-ghost" href="/">Back to home</a>
      </div>
    </div>
  </section>

  <!-- Wrong role -->
  <section id="brain-denied" class="brain-anon section" hidden>
    <div class="container brain-narrow">
      <h1 class="brain-anon-title">Founders only</h1>
      <p class="brain-anon-sub">The Marketing Brain is only accessible to RISE founders.</p>
      <div class="brain-anon-actions">
        <a class="btn-primary" href="/portal">Back to portal</a>
      </div>
    </div>
  </section>

  <!-- ── Brain Dashboard ──────────────────────────────────────── -->
  <section id="brain-dashboard" class="brain-dashboard section" hidden>
    <div class="container brain-container">

      <!-- Header -->
      <header class="brain-header">
        <div class="brain-header-top">
          <p class="brain-eyebrow">RISE Brain</p>
          <div class="brain-stats">
            <span class="brain-stat" id="brain-node-count">— nodes</span>
            <span class="brain-stat-sep">&middot;</span>
            <span class="brain-stat" id="brain-budget">—</span>
          </div>
        </div>
        <h1 class="brain-title">Marketing Brain</h1>
        <p class="brain-sub">Strategic marketing intelligence engine</p>
      </header>

      <!-- Tab Nav — Briefs FIRST as default -->
      <nav class="brain-tabs">
        <button class="brain-tab active" data-tab="briefs">Briefs</button>
        <button class="brain-tab" data-tab="consult">Consult</button>
        <button class="brain-tab" data-tab="research">Research</button>
        <button class="brain-tab" data-tab="strategy">Strategy</button>
        <button class="brain-tab" data-tab="health">Health</button>
        <button class="brain-tab" data-tab="setup" id="brain-tab-setup">Setup</button>
      </nav>

      <!-- ── Briefs Tab (DEFAULT LANDING) ─────────────────── -->
      <div class="brain-panel active" id="panel-briefs">

        <!-- Week header -->
        <div class="brain-week-header" id="brain-week-header">
          <h2 class="brain-week-title" id="brain-week-title">This Week</h2>
          <p class="brain-week-date" id="brain-week-date"></p>
        </div>

        <!-- Generate button (when no briefs) -->
        <div class="brain-generate-section hidden" id="brain-generate-section">
          <p class="brain-empty-state">No briefs yet this week.</p>
          <button class="btn-primary brain-generate-btn" id="brain-generate-btn">Generate this week's briefs</button>
        </div>

        <!-- Loading -->
        <div class="brain-loading-inline hidden" id="brain-briefs-loading">
          <div class="brain-loading-bar"><div class="brain-loading-bar-fill"></div></div>
          <span>Generating briefs...</span>
        </div>

        <!-- Briefs list -->
        <div class="brain-briefs-container" id="brain-briefs-container"></div>

        <!-- Error -->
        <div class="brain-error-card hidden" id="brain-briefs-error">
          <p class="brain-error-text" id="brain-briefs-error-text"></p>
        </div>
      </div>

      <!-- ── Consult Tab (was Ask) ─────────────────────────── -->
      <div class="brain-panel" id="panel-consult">
        <form class="brain-query-form" id="brain-query-form">
          <input type="text" class="brain-query-input" id="brain-query-input"
            placeholder="Ask the brain anything..." autocomplete="off" autofocus />
          <button type="submit" class="brain-query-btn" id="brain-query-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </button>
        </form>

        <!-- Empty state -->
        <div class="brain-empty-state" id="brain-empty-state">
          <p>Ask a question to get a strategic analysis with<br/>consequence chains, confidence levels, and knowledge gaps.</p>
        </div>

        <!-- Loading -->
        <div class="brain-loading-inline hidden" id="brain-ask-loading">
          <div class="brain-loading-bar"><div class="brain-loading-bar-fill"></div></div>
          <span>Thinking...</span>
        </div>

        <!-- Result Card -->
        <div class="brain-result-card hidden" id="brain-result-card">
          <section class="brain-section brain-section-position">
            <h2 class="brain-section-label">Position</h2>
            <p class="brain-position-text" id="brain-position-text"></p>
          </section>
          <section class="brain-section" id="brain-chain-section">
            <h2 class="brain-section-label">Consequence Chain</h2>
            <div class="brain-chain" id="brain-chain"></div>
          </section>
          <section class="brain-section">
            <h2 class="brain-section-label">Reasoning</h2>
            <p class="brain-reasoning-text" id="brain-reasoning-text"></p>
          </section>
          <section class="brain-section hidden" id="brain-gaps-section">
            <h2 class="brain-section-label">Knowledge Gaps <span class="brain-gap-count" id="brain-gap-count"></span></h2>
            <div class="brain-gaps-list" id="brain-gaps-list"></div>
          </section>
          <footer class="brain-result-meta">
            <span class="brain-confidence" id="brain-confidence">—</span>
            <span class="brain-meta-sep">&middot;</span>
            <span id="brain-sources">No sources</span>
            <span class="brain-meta-sep">&middot;</span>
            <span id="brain-model"></span>
          </footer>
        </div>

        <!-- Error -->
        <div class="brain-error-card hidden" id="brain-error-card">
          <p class="brain-error-text" id="brain-error-text"></p>
        </div>
      </div>

      <!-- ── Research Tab ────────────────────────────────── -->
      <div class="brain-panel" id="panel-research">

        <!-- Scout Signals -->
        <section class="brain-section" id="brain-scout-section">
          <h2 class="brain-section-label">Scout Signals <span class="brain-gap-count" id="brain-scout-count"></span></h2>
          <div class="brain-loading-inline hidden" id="brain-scout-loading">
            <div class="brain-loading-bar"><div class="brain-loading-bar-fill"></div></div>
            <span>Loading signals...</span>
          </div>
          <div id="brain-scout-list"></div>
        </section>

        <div style="border-top:1px solid var(--rise-neutral-100);margin:16px 0;padding-top:16px;">
          <p class="brain-research-intro">Tell the brain a topic to research. It will find relevant knowledge and propose nodes for the graph.</p>
        </div>

        <form class="brain-query-form" id="brain-research-form">
          <input type="text" class="brain-query-input" id="brain-research-input"
            placeholder="e.g. youth hockey social media best practices..." autocomplete="off" />
          <button type="submit" class="brain-query-btn" id="brain-research-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </button>
        </form>

        <div class="brain-loading-inline hidden" id="brain-research-loading">
          <div class="brain-loading-bar"><div class="brain-loading-bar-fill"></div></div>
          <span>Researching...</span>
        </div>

        <div class="brain-research-results hidden" id="brain-research-results">
          <section class="brain-section brain-section-position">
            <h2 class="brain-section-label">Summary</h2>
            <p class="brain-position-text" id="brain-research-summary"></p>
          </section>
          <section class="brain-section" id="brain-research-findings-section">
            <h2 class="brain-section-label">Findings</h2>
            <div class="brain-findings-list" id="brain-research-findings"></div>
          </section>
          <section class="brain-section hidden" id="brain-research-actions-section">
            <h2 class="brain-section-label">Action Items</h2>
            <div class="brain-action-list" id="brain-research-actions"></div>
          </section>
          <section class="brain-section" id="brain-research-nodes-section">
            <h2 class="brain-section-label">Knowledge to Add <span class="brain-gap-count" id="brain-research-node-count"></span></h2>
            <div class="brain-findings-list" id="brain-research-nodes"></div>
            <div class="brain-approve-row">
              <button class="btn-primary brain-approve-btn" id="brain-approve-research-btn">Approve into graph</button>
            </div>
          </section>
          <section class="brain-section hidden" id="brain-research-gaps-section">
            <h2 class="brain-section-label">Gaps</h2>
            <div class="brain-gaps-list" id="brain-research-gaps"></div>
          </section>
        </div>

        <div class="brain-error-card hidden" id="brain-research-error">
          <p class="brain-error-text" id="brain-research-error-text"></p>
        </div>

        <div class="brain-flash hidden" id="brain-research-flash">
          <span class="brain-flash-icon">&#10003;</span>
          <span class="brain-flash-text" id="brain-research-flash-text"></span>
        </div>
      </div>

      <!-- ── Strategy Tab ──────────────────────────────────── -->
      <div class="brain-panel" id="panel-strategy">
        <div class="brain-loading-inline hidden" id="brain-strategy-loading">
          <div class="brain-loading-bar"><div class="brain-loading-bar-fill"></div></div>
          <span>Loading strategy...</span>
        </div>

        <div class="brain-empty-state hidden" id="brain-strategy-empty">
          <p>No strategy document yet. Generate one to get started.</p>
          <button class="btn-primary" id="brain-generate-strategy-btn" style="margin-top:12px">Generate strategy</button>
        </div>

        <div class="hidden" id="brain-strategy-content">
          <div class="brain-strategy-header">
            <span class="brain-strategy-version" id="brain-strategy-version"></span>
            <span class="brain-strategy-status" id="brain-strategy-status"></span>
          </div>

          <section class="brain-section">
            <h2 class="brain-section-label">Positioning</h2>
            <p class="brain-position-text" id="brain-strategy-positioning"></p>
          </section>

          <section class="brain-section">
            <h2 class="brain-section-label">Target Audience</h2>
            <p class="brain-position-text" id="brain-strategy-audience"></p>
          </section>

          <section class="brain-section">
            <h2 class="brain-section-label">Content Pillars</h2>
            <div class="brain-tag-list" id="brain-strategy-pillars"></div>
          </section>

          <section class="brain-section">
            <h2 class="brain-section-label">Growth Levers</h2>
            <div class="brain-tag-list" id="brain-strategy-levers"></div>
          </section>

          <section class="brain-section">
            <h2 class="brain-section-label">Current Priorities</h2>
            <div class="brain-priority-list" id="brain-strategy-priorities"></div>
          </section>

          <section class="brain-section hidden" id="brain-strategy-refinement-section">
            <h2 class="brain-section-label">Refinement Notes</h2>
            <p class="brain-position-text" id="brain-strategy-refinement"></p>
          </section>

          <footer class="brain-result-meta">
            <span id="brain-strategy-updated"></span>
          </footer>
        </div>

        <div class="brain-error-card hidden" id="brain-strategy-error">
          <p class="brain-error-text" id="brain-strategy-error-text"></p>
        </div>
      </div>

      <!-- ── Health Tab ─────────────────────────────────────── -->
      <div class="brain-panel" id="panel-health">
        <div class="brain-loading-inline hidden" id="brain-health-loading">
          <div class="brain-loading-bar"><div class="brain-loading-bar-fill"></div></div>
          <span>Checking data health...</span>
        </div>

        <div class="hidden" id="brain-health-content">
          <!-- Status banner -->
          <div class="brain-health-status" id="brain-health-status-banner">
            <span class="brain-health-status-icon" id="brain-health-status-icon"></span>
            <span class="brain-health-status-text" id="brain-health-status-text"></span>
          </div>

          <!-- Stats grid -->
          <div class="brain-health-grid">
            <div class="brain-health-card">
              <span class="brain-health-card-value" id="brain-health-outcomes">0</span>
              <span class="brain-health-card-label">Outcomes tracked</span>
            </div>
            <div class="brain-health-card">
              <span class="brain-health-card-value" id="brain-health-content-count">0</span>
              <span class="brain-health-card-label">Content pieces</span>
            </div>
            <div class="brain-health-card">
              <span class="brain-health-card-value" id="brain-health-missing">0</span>
              <span class="brain-health-card-label">Missing outcomes</span>
            </div>
            <div class="brain-health-card">
              <span class="brain-health-card-value" id="brain-health-stale">0</span>
              <span class="brain-health-card-label">Stale outcomes</span>
            </div>
          </div>

          <!-- Bias warning -->
          <section class="brain-section hidden" id="brain-health-bias-section">
            <h2 class="brain-section-label">Bias Warning</h2>
            <div class="brain-health-warning" id="brain-health-bias"></div>
          </section>

          <!-- Missing outcomes list -->
          <section class="brain-section hidden" id="brain-health-missing-section">
            <h2 class="brain-section-label">Missing Outcomes</h2>
            <div id="brain-health-missing-list"></div>
          </section>

          <!-- Suggested messages -->
          <section class="brain-section hidden" id="brain-health-messages-section">
            <h2 class="brain-section-label">Suggested for Ryan</h2>
            <div id="brain-health-messages"></div>
          </section>

          <!-- Insights -->
          <section class="brain-section" id="brain-health-insights-section">
            <h2 class="brain-section-label">Performance Insights <span class="brain-gap-count" id="brain-health-insight-count"></span></h2>
            <div class="brain-loading-inline hidden" id="brain-insights-loading">
              <div class="brain-loading-bar"><div class="brain-loading-bar-fill"></div></div>
              <span>Analyzing patterns...</span>
            </div>
            <div id="brain-health-insights"></div>
          </section>

          <!-- Distillation -->
          <section class="brain-section" id="brain-distill-section">
            <h2 class="brain-section-label">Distillation</h2>
            <p class="brain-section-desc" style="font-size:0.82rem;color:var(--rise-neutral-500);margin:0 0 12px;">Turns outcome patterns into reusable knowledge. Runs automatically every 6 hours.</p>
            <div class="brain-health-grid">
              <div class="brain-health-card">
                <span class="brain-health-card-value" id="brain-distill-total">0</span>
                <span class="brain-health-card-label">Total outcomes</span>
              </div>
              <div class="brain-health-card">
                <span class="brain-health-card-value" id="brain-distill-done">0</span>
                <span class="brain-health-card-label">Distilled</span>
              </div>
              <div class="brain-health-card">
                <span class="brain-health-card-value" id="brain-distill-pending">0</span>
                <span class="brain-health-card-label">Pending</span>
              </div>
              <div class="brain-health-card">
                <span class="brain-health-card-value" id="brain-distill-knowledge">0</span>
                <span class="brain-health-card-label">Knowledge nodes</span>
              </div>
            </div>
            <div style="display:flex;gap:10px;align-items:center;margin-top:12px;">
              <button class="btn-primary" id="brain-distill-btn" style="font-size:0.82rem;padding:8px 18px;">Run Distillation</button>
              <span id="brain-distill-status" style="font-size:0.82rem;color:var(--rise-neutral-500);"></span>
            </div>
            <div id="brain-distill-results" style="margin-top:12px;"></div>
          </section>

          <footer class="brain-result-meta">
            <span id="brain-health-last-outcome"></span>
          </footer>
        </div>

        <div class="brain-error-card hidden" id="brain-health-error">
          <p class="brain-error-text" id="brain-health-error-text"></p>
        </div>
      </div>

      <!-- ── Setup / Onboarding Tab ──────────────────────── -->
      <div class="brain-panel" id="panel-setup">

        <!-- Welcome screen (first visit) -->
        <div class="brain-welcome hidden" id="brain-welcome-screen">
          <h2 class="brain-welcome-title">Welcome to your Marketing Brain</h2>
          <p class="brain-welcome-sub">Let's get to know your business. Answer a few questions so the brain can start generating strategic insights.</p>
          <button class="btn-primary" id="brain-welcome-start">Get started</button>
        </div>

        <!-- Onboarding flow -->
        <div id="brain-onboarding-flow">
          <!-- Progress -->
          <div class="brain-onboarding-progress">
            <div class="brain-onboarding-bar">
              <div class="brain-onboarding-bar-fill" id="brain-onboarding-fill"></div>
            </div>
            <div class="brain-onboarding-meta">
              <span id="brain-onboarding-pct">0%</span>
              <span id="brain-onboarding-step">Setup</span>
            </div>
          </div>
          <div class="brain-milestone hidden" id="brain-milestone"></div>

          <!-- Current question -->
          <div class="brain-onboarding-question hidden" id="brain-onboarding-question">
            <p class="brain-onboarding-q-text" id="brain-onboarding-q-text"></p>
            <p class="brain-onboarding-q-context" id="brain-onboarding-q-context"></p>
            <textarea class="brain-onboarding-answer" id="brain-onboarding-answer" rows="3" placeholder="Your answer..."></textarea>
            <div class="brain-onboarding-actions">
              <button class="btn-primary" id="brain-onboarding-submit" onclick="window._brainSubmitAnswer()">Submit</button>
              <button class="btn-ghost" onclick="window._brainSkipQuestion()">Skip for now</button>
            </div>
          </div>

          <!-- Status (when no question) -->
          <div class="brain-empty-state hidden" id="brain-onboarding-empty">
            <p id="brain-onboarding-status-text">Loading...</p>
          </div>

          <!-- Completion state -->
          <div class="brain-completion hidden" id="brain-completion">
            <h2 class="brain-welcome-title">Your brain is ready</h2>
            <p class="brain-welcome-sub">Here's what it knows so far:</p>
            <div id="brain-completion-stats"></div>
            <button class="btn-primary" style="margin-top: var(--space-4)" onclick="window._brainSwitchTab('ask')">Start asking questions</button>
          </div>

          <!-- Result flash -->
          <div class="brain-flash hidden" id="brain-onboarding-result">
            <span class="brain-flash-icon">&#10003;</span>
            <span class="brain-flash-text" id="brain-onboarding-result-text"></span>
          </div>

          <!-- Skipped questions -->
          <section class="brain-section hidden" id="brain-skipped-section">
            <h2 class="brain-section-label">Skipped questions</h2>
            <div id="brain-skipped-list"></div>
          </section>

          <!-- History -->
          <section class="brain-section" id="brain-onboarding-history-section">
            <h2 class="brain-section-label">Answered questions</h2>
            <div id="brain-onboarding-history"></div>
          </section>
        </div>
      </div>

    </div>
  </section>

  <Footer slot="footer" />

  <!-- ── Auth + Boot ─────────────────────────────────────────── -->
  <script is:inline define:vars={{ BRAIN_API }}>
    const API = BRAIN_API;

    // ── Auth check ────────────────────────────────────────────
    async function initBrain() {
      const sb = window.supabaseClient;
      if (!sb) { setTimeout(initBrain, 100); return; }

      const loading = document.getElementById("brain-loading");
      const anon = document.getElementById("brain-anon");
      const denied = document.getElementById("brain-denied");
      const dash = document.getElementById("brain-dashboard");

      const { data: { session } } = await sb.auth.getSession();

      if (!session) {
        loading.setAttribute("hidden", "");
        anon.removeAttribute("hidden");
        sb.auth.onAuthStateChange((_e, s) => { if (s) window.location.reload(); });
        return;
      }

      const user = session.user;

      // Check role
      const { data: profile } = await sb
        .from("user_profiles")
        .select("role")
        .eq("id", user.id)
        .maybeSingle();

      const role = profile?.role || "athlete";
      if (role !== "coach" && role !== "founder") {
        loading.setAttribute("hidden", "");
        denied.removeAttribute("hidden");
        return;
      }

      // Store session token for API calls
      window._brainToken = session.access_token;

      loading.setAttribute("hidden", "");
      dash.removeAttribute("hidden");
      brainInit();
    }

    // ── API helper (with auth header) ─────────────────────────
    async function brainFetch(path, opts = {}) {
      const headers = { "Content-Type": "application/json", ...(opts.headers || {}) };
      if (window._brainToken) {
        headers["Authorization"] = "Bearer " + window._brainToken;
      }
      const resp = await fetch(API + path, { ...opts, headers });
      if (!resp.ok) {
        const err = await resp.json().catch(() => ({ detail: resp.statusText }));
        throw new Error(err.detail || "HTTP " + resp.status);
      }
      return resp.json();
    }

    // ── DOM helpers ───────────────────────────────────────────
    const $ = (s) => document.querySelector(s);
    const $$ = (s) => document.querySelectorAll(s);

    function esc(str) {
      const d = document.createElement("div");
      d.textContent = str || "";
      return d.innerHTML;
    }

    // ── Tabs ──────────────────────────────────────────────────
    function setupTabs() {
      $$(".brain-tab").forEach((tab) => {
        tab.addEventListener("click", () => {
          const target = tab.dataset.tab;
          $$(".brain-tab").forEach((t) => t.classList.toggle("active", t === tab));
          $$(".brain-panel").forEach((p) => p.classList.toggle("active", p.id === "panel-" + target));
          if (target === "briefs") { loadBriefs(); }
          if (target === "setup") loadOnboarding();
          if (target === "strategy") loadStrategy();
          if (target === "health") loadHealth();
          if (target === "research") loadScoutSignals();
        });
      });
    }

    window._brainSwitchTab = function(name) {
      const tab = document.querySelector('[data-tab="' + name + '"]');
      if (tab) tab.click();
    };

    // ── Health / Stats ────────────────────────────────────────
    async function loadStats() {
      try {
        const data = await brainFetch("/health");
        $("#brain-node-count").textContent = (data.graph_nodes || 0) + " nodes";
        if (data.budget_remaining !== undefined) {
          $("#brain-budget").textContent = "$" + data.budget_remaining.toFixed(2) + " left";
        }
      } catch {
        $("#brain-node-count").textContent = "offline";
        $("#brain-budget").textContent = "\u2014";
      }
    }

    // ── Brain Init (called after auth passes) ─────────────────
    function brainInit() {
      loadStats();
      setWeekHeader();
      loadCampaignCache().then(() => loadBriefs());
    }

    // ── Ask Tab ───────────────────────────────────────────────
    let askLoading = false;

    function showAskState(state) {
      $("#brain-empty-state").classList.toggle("hidden", state !== "empty");
      $("#brain-ask-loading").classList.toggle("hidden", state !== "loading");
      $("#brain-result-card").classList.toggle("hidden", state !== "result");
      $("#brain-error-card").classList.toggle("hidden", state !== "error");
    }

    async function submitQuery(query) {
      if (askLoading || !query.trim()) return;
      askLoading = true;
      $("#brain-query-btn").disabled = true;
      showAskState("loading");
      try {
        const data = await brainFetch("/reason", {
          method: "POST",
          body: JSON.stringify({ query: query.trim() }),
        });
        renderResult(data);
        showAskState("result");
      } catch (e) {
        $("#brain-error-text").textContent = e.message;
        showAskState("error");
      } finally {
        askLoading = false;
        $("#brain-query-btn").disabled = false;
      }
    }

    function renderResult(data) {
      $("#brain-position-text").textContent = data.position || "No position.";
      $("#brain-reasoning-text").textContent = data.reasoning || "No reasoning.";
      if (data.consequence_chain) { renderChain(data.consequence_chain); $("#brain-chain-section").classList.remove("hidden"); }
      else { $("#brain-chain-section").classList.add("hidden"); }
      if (data.gaps?.length > 0) { renderGaps(data.gaps); $("#brain-gaps-section").classList.remove("hidden"); }
      else { $("#brain-gaps-section").classList.add("hidden"); }
      const conf = (data.confidence || "MEDIUM").toLowerCase();
      $("#brain-confidence").textContent = data.confidence || "MEDIUM";
      $("#brain-confidence").className = "brain-confidence " + conf;
      $("#brain-sources").textContent = data.sources?.length > 0 ? data.sources.length + " source" + (data.sources.length > 1 ? "s" : "") + " cited" : "No sources";
      $("#brain-model").textContent = data.model_used || "";
    }

    function renderChain(chain) {
      const levels = [{ key: "action", label: "Action" }, { key: "direct", label: "Direct" }, { key: "secondary", label: "Secondary" }, { key: "strategic", label: "Strategic" }];
      let html = "";
      for (let i = 0; i < levels.length; i++) {
        const { key, label } = levels[i];
        const node = chain[key];
        if (!node) continue;
        const conf = (node.confidence || "MEDIUM").toLowerCase();
        html += '<div class="brain-chain-node"><div class="brain-chain-connector"><span class="brain-chain-level">' + label + '</span>' + (i < levels.length - 1 ? '<span class="brain-chain-arrow">&darr;</span>' : '') + '</div><span class="brain-chain-claim">' + esc(node.claim) + '</span><span class="brain-chain-confidence ' + conf + '">' + node.confidence + '</span></div>';
      }
      $("#brain-chain").innerHTML = html;
    }

    function renderGaps(gaps) {
      $("#brain-gap-count").textContent = "(" + gaps.length + ")";
      const icons = { human: "\u26A0", researchable: "\u25CE", testable: "\u25C8" };
      let html = "";
      for (const g of gaps) {
        const cat = (g.category || "HUMAN").toLowerCase();
        html += '<div class="brain-gap-item"><span class="brain-gap-icon ' + cat + '">' + (icons[cat] || "\u2022") + '</span><div class="brain-gap-content"><div class="brain-gap-question">' + esc(g.question) + '</div>' + (g.impact ? '<div class="brain-gap-impact">' + esc(g.impact) + '</div>' : '') + '</div></div>';
      }
      $("#brain-gaps-list").innerHTML = html;
    }

    $("#brain-query-form").addEventListener("submit", (e) => { e.preventDefault(); submitQuery($("#brain-query-input").value); });

    // ── Briefs Tab (Brief-First) ──────────────────────────────
    let expandedBriefs = new Set();

    function setWeekHeader() {
      const now = new Date();
      const options = { month: "long", day: "numeric", year: "numeric" };
      const $date = $("#brain-week-date");
      const $title = $("#brain-week-title");
      if ($date) $date.textContent = now.toLocaleDateString("en-US", options);
      if ($title) {
        const day = now.getDay();
        const diff = now.getDate() - day + (day === 0 ? -6 : 1);
        const monday = new Date(now.getFullYear(), now.getMonth(), diff);
        $title.textContent = "Week of " + monday.toLocaleDateString("en-US", { month: "short", day: "numeric" });
      }
    }

    async function loadBriefs() {
      const $container = $("#brain-briefs-container");
      const $genSection = $("#brain-generate-section");
      const $loading = $("#brain-briefs-loading");
      const $error = $("#brain-briefs-error");
      const $errorText = $("#brain-briefs-error-text");

      if (!$container) return;
      $container.innerHTML = "";
      if ($genSection) $genSection.classList.add("hidden");
      if ($loading) $loading.classList.remove("hidden");
      if ($error) $error.classList.add("hidden");

      try {
        const data = await brainFetch("/briefs?limit=10");
        const briefs = data.briefs || [];
        if ($loading) $loading.classList.add("hidden");

        if (briefs.length === 0) {
          if ($genSection) $genSection.classList.remove("hidden");
          return;
        }

        for (const brief of briefs) {
          $container.appendChild(createBriefCard(brief));
        }
      } catch (err) {
        if ($loading) $loading.classList.add("hidden");
        if ($error) {
          $error.classList.remove("hidden");
          if ($errorText) $errorText.textContent = "Failed to load briefs: " + err.message;
        }
      }
    }

    function createBriefCard(brief) {
      const card = document.createElement("div");
      card.className = "brain-brief-expandable";
      card.dataset.id = brief.id;

      const content = brief.content || {};
      const isExpanded = expandedBriefs.has(brief.id);
      const confClass = (content.confidence || brief.confidence || "MEDIUM").toLowerCase();

      const statusBadge = brief.status !== "PENDING"
        ? '<span class="brain-brief-status-tag brain-brief-status-' + brief.status.toLowerCase() + '">' + brief.status + '</span>'
        : "";

      const hashtags = content.hashtags || [];
      const hashtagHtml = hashtags.length > 0
        ? '<div class="brain-brief-hashtags">' + hashtags.map(function(h) { return '<span class="brain-hashtag">' + esc(h) + '</span>'; }).join("") + '</div>'
        : "";

      const chain = content.consequence_chain || "";
      const chainHtml = chain
        ? '<div class="brain-brief-chain"><div class="brain-brief-chain-label">What happens when you post this</div><div class="brain-brief-chain-text">' + formatBriefChain(chain) + '</div></div>'
        : "";

      let html = '<div class="brain-brief-header" onclick="window._brainToggleBrief(\'' + brief.id + '\')">';
      html += '<div class="brain-brief-header-left">';
      html += '<span class="brain-brief-conf brain-conf-' + confClass + '">' + (content.confidence || brief.confidence || "\u2014") + '</span>';
      html += '<span class="brain-brief-topic-text">' + esc(brief.topic) + '</span>';
      html += getCampaignBadge(brief);
      html += '</div>';
      html += '<div class="brain-brief-header-right">';
      html += statusBadge;
      html += '<span class="brain-brief-expand">' + (isExpanded ? "\u25BE" : "\u25B8") + '</span>';
      html += '</div></div>';

      if (isExpanded) {
        html += '<div class="brain-brief-body">';

        if (content.what_to_post) {
          html += '<div class="brain-brief-section"><div class="brain-brief-section-label">What to post</div><div class="brain-brief-section-text">' + formatBriefText(content.what_to_post) + '</div></div>';
        }
        if (content.how_to_fil) {
          html += '<div class="brain-brief-section"><div class="brain-brief-section-label">How to film it</div><div class="brain-brief-section-text">' + formatBriefText(content.how_to_fil) + '</div></div>';
        }
        if (content.why_it_matters) {
          html += '<div class="brain-brief-section"><div class="brain-brief-section-label">Why it matters</div><div class="brain-brief-section-text">' + formatBriefText(content.why_it_matters) + '</div></div>';
        }
        if (content.caption) {
          html += '<div class="brain-brief-section brain-brief-caption-section"><div class="brain-brief-section-label">Caption (ready to copy)</div><div class="brain-brief-caption" onclick="window._brainCopyCaption(this)" title="Click to copy">' + esc(content.caption) + '</div></div>';
        }

        html += hashtagHtml;
        html += chainHtml;

        html += '<div class="brain-brief-actions">';
        if (brief.status === "PENDING") {
          html += '<button class="btn-primary brain-brief-action-btn" onclick="window._brainApproveBrief(\'' + brief.id + '\')">Approve</button>';
          html += '<button class="btn-ghost brain-brief-action-btn" onclick="window._brainRejectBrief(\'' + brief.id + '\')">Reject</button>';
        } else {
          html += '<span class="brain-brief-status-label">' + brief.status + '</span>';
        }
        html += '</div>';

        html += '</div>';
      }

      card.innerHTML = html;
      return card;
    }

    window._brainToggleBrief = function(id) {
      if (expandedBriefs.has(id)) {
        expandedBriefs.delete(id);
      } else {
        expandedBriefs.add(id);
      }
      loadBriefs();
    };

    window._brainCopyCaption = function(el) {
      const text = el.textContent.trim();
      navigator.clipboard.writeText(text).then(function() {
        const orig = el.style.background;
        el.style.background = "var(--rise-red)";
        el.style.color = "#fff";
        setTimeout(function() { el.style.background = orig; el.style.color = ""; }, 800);
      });
    };

    function formatBriefChain(chain) {
      if (typeof chain === "string") {
        return chain.split("\n").map(function(line) {
          var parts = line.split(":");
          if (parts.length >= 2) {
            return '<div class="brain-chain-step"><span class="brain-chain-step-label">' + esc(parts[0].trim()) + ':</span> ' + esc(parts.slice(1).join(":").trim()) + '</div>';
          }
          return '<div class="brain-chain-step">' + esc(line) + '</div>';
        }).join("");
      }
      return esc(JSON.stringify(chain));
    }

    function formatBriefText(text) {
      if (!text) return "";
      return esc(text).replace(/\n/g, "<br>");
    }

    // Generate weekly button
    const $genBtn = $("#brain-generate-btn");
    if ($genBtn) {
      $genBtn.addEventListener("click", async function() {
        const $genSection = $("#brain-generate-section");
        const $loading = $("#brain-briefs-loading");
        const $error = $("#brain-briefs-error");
        const $errorText = $("#brain-briefs-error-text");

        if ($genSection) $genSection.classList.add("hidden");
        if ($loading) $loading.classList.remove("hidden");
        if ($error) $error.classList.add("hidden");

        try {
          const data = await brainFetch("/briefs/generate-weekly", { method: "POST" });
          if ($loading) $loading.classList.add("hidden");
          loadBriefs();
        } catch (err) {
          if ($loading) $loading.classList.add("hidden");
          if ($error) {
            $error.classList.remove("hidden");
            if ($errorText) $errorText.textContent = "Generation failed: " + err.message;
          }
          if ($genSection) $genSection.classList.remove("hidden");
        }
      });
    }

    // Approve / Reject
    window._brainApproveBrief = async function(id) {
      try {
        await brainFetch("/briefs/" + id + "/approve", { method: "POST", body: JSON.stringify({ notes: "" }) });
        loadBriefs();
      } catch (err) { alert("Failed to approve."); }
    };

    window._brainRejectBrief = async function(id) {
      const notes = prompt("Why reject this brief? (optional)") || "";
      try {
        await brainFetch("/briefs/" + id + "/reject", { method: "POST", body: JSON.stringify({ notes: notes }) });
        loadBriefs();
      } catch (err) { alert("Failed to reject."); }
    };

    // ── Research Tab ──────────────────────────────────────────
    let researchData = null;

    $("#brain-research-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      const topic = $("#brain-research-input").value.trim();
      if (!topic) return;

      $("#brain-research-btn").disabled = true;
      $("#brain-research-loading").classList.remove("hidden");
      $("#brain-research-results").classList.add("hidden");
      $("#brain-research-error").classList.add("hidden");
      $("#brain-research-flash").classList.add("hidden");

      try {
        const data = await brainFetch("/research", {
          method: "POST",
          body: JSON.stringify({ topic }),
        });
        researchData = data;
        renderResearchResults(data);
        $("#brain-research-results").classList.remove("hidden");
      } catch (e) {
        $("#brain-research-error-text").textContent = e.message;
        $("#brain-research-error").classList.remove("hidden");
      } finally {
        $("#brain-research-btn").disabled = false;
        $("#brain-research-loading").classList.add("hidden");
      }
    });

    function renderResearchResults(data) {
      $("#brain-research-summary").textContent = data.summary || "No summary.";
      // Findings
      let findingsHtml = "";
      for (const f of (data.findings || [])) {
        findingsHtml += '<div class="brain-finding-item"><div class="brain-finding-title">' + esc(f.title || f.claim || "") + '</div><div class="brain-finding-desc">' + esc(f.description || f.detail || "") + '</div>' + (f.relevance ? '<div class="brain-finding-relevance">' + esc(f.relevance) + '</div>' : '') + '</div>';
      }
      $("#brain-research-findings").innerHTML = findingsHtml || '<div class="brain-empty-state"><p>No findings.</p></div>';
      // Actions
      if (data.action_items?.length > 0) {
        let actionsHtml = "";
        for (const a of data.action_items) {
          actionsHtml += '<div class="brain-gap-item"><span class="brain-gap-icon" style="color:var(--rise-red)">&rarr;</span><div class="brain-gap-content"><div class="brain-gap-question">' + esc(typeof a === "string" ? a : a.action || a.description || "") + '</div></div></div>';
        }
        $("#brain-research-actions").innerHTML = actionsHtml;
        $("#brain-research-actions-section").classList.remove("hidden");
      } else {
        $("#brain-research-actions-section").classList.add("hidden");
      }
      // Nodes
      const nodes = data.proposed_nodes || data.nodes || [];
      $("#brain-research-node-count").textContent = "(" + nodes.length + ")";
      let nodesHtml = "";
      for (const n of nodes) {
        nodesHtml += '<div class="brain-finding-item"><div class="brain-finding-title">' + esc(n.label || n.name || "") + '</div><div class="brain-finding-desc">' + esc(n.description || n.detail || "") + '</div><div class="brain-finding-relevance">Type: ' + esc(n.type || "unknown") + '</div></div>';
      }
      $("#brain-research-nodes").innerHTML = nodesHtml || '<div class="brain-empty-state"><p>No nodes proposed.</p></div>';
      // Gaps
      if (data.gaps?.length > 0) {
        const icons = { human: "\u26A0", researchable: "\u25CE", testable: "\u25C8" };
        let gapsHtml = "";
        for (const g of data.gaps) {
          const cat = (g.category || "HUMAN").toLowerCase();
          gapsHtml += '<div class="brain-gap-item"><span class="brain-gap-icon ' + cat + '">' + (icons[cat] || "\u2022") + '</span><div class="brain-gap-content"><div class="brain-gap-question">' + esc(g.question || g) + '</div></div></div>';
        }
        $("#brain-research-gaps").innerHTML = gapsHtml;
        $("#brain-research-gaps-section").classList.remove("hidden");
      } else {
        $("#brain-research-gaps-section").classList.add("hidden");
      }
    }

    $("#brain-approve-research-btn").addEventListener("click", async () => {
      if (!researchData) return;
      const btn = $("#brain-approve-research-btn");
      btn.disabled = true;
      try {
        const nodes = researchData.proposed_nodes || researchData.nodes || [];
        const edges = researchData.proposed_edges || researchData.edges || [];
        const result = await brainFetch("/research/approve", {
          method: "POST",
          body: JSON.stringify({ nodes, edges }),
        });
        $("#brain-research-flash-text").textContent = "Approved " + (result.nodes_added || nodes.length) + " nodes into the graph.";
        $("#brain-research-flash").classList.remove("hidden");
        researchData = null;
        loadStats();
      } catch (e) {
        alert("Failed: " + e.message);
      } finally {
        btn.disabled = false;
      }
    });

    // ── Onboarding ────────────────────────────────────────────
    let currentQuestion = null;
    const WELCOME_KEY = "rise-brain-seen-welcome";

    async function loadOnboarding() {
      let progress;
      try {
        progress = await brainFetch("/onboarding/progress");
      } catch {
        $("#brain-onboarding-empty").classList.remove("hidden");
        $("#brain-onboarding-status-text").textContent = "Failed to load. Is the Brain API running?";
        return;
      }
      const pct = progress.percent_complete || 0;
      const total = progress.total || 0;
      const answered = progress.answered || 0;
      const skipped = progress.skipped || 0;
      const completed = pct >= 100;

      if (completed) {
        $("#brain-tab-setup").textContent = "Settings";
      }

      const seenWelcome = localStorage.getItem(WELCOME_KEY);
      if (pct === 0 && !seenWelcome) {
        $("#brain-welcome-screen").classList.remove("hidden");
        $("#brain-onboarding-flow").style.display = "none";
        return;
      }

      $("#brain-welcome-screen").classList.add("hidden");
      $("#brain-onboarding-flow").style.display = "";
      $("#brain-onboarding-fill").style.width = pct + "%";
      $("#brain-onboarding-pct").textContent = pct + "%";
      const step = answered + skipped + 1;
      if (total > 0 && !completed) {
        $("#brain-onboarding-step").textContent = "Question " + Math.min(step, total) + " of " + total;
      } else if (completed) {
        $("#brain-onboarding-step").textContent = "Complete";
      }

      if (completed) {
        showCompletion(progress);
      } else {
        $("#brain-completion").classList.add("hidden");
        loadNextQuestion();
      }
      loadSkipped();
      loadHistory();
    }

    async function showCompletion(progress) {
      $("#brain-onboarding-question").classList.add("hidden");
      $("#brain-onboarding-empty").classList.add("hidden");
      $("#brain-completion").classList.remove("hidden");
      try {
        const stats = await brainFetch("/graph/stats");
        const nodes = stats.nodes || {};
        const total = nodes.total || 0;
        const byType = nodes.by_type || {};
        let html = '<div class="brain-stat-grid">';
        html += '<div class="brain-stat-item"><span class="brain-stat-num">' + total + '</span><span class="brain-stat-lbl">total</span></div>';
        for (const [type, count] of Object.entries(byType)) {
          if (count > 0) html += '<div class="brain-stat-item"><span class="brain-stat-num">' + count + '</span><span class="brain-stat-lbl">' + type.toLowerCase() + '</span></div>';
        }
        html += '</div>';
        $("#brain-completion-stats").innerHTML = html;
      } catch {
        $("#brain-completion-stats").innerHTML = '<p class="brain-reasoning-text">Stats unavailable.</p>';
      }
    }

    async function loadNextQuestion() {
      try {
        const data = await brainFetch("/onboarding/next");
        if (data.status === "complete") {
          $("#brain-onboarding-question").classList.add("hidden");
          $("#brain-onboarding-empty").classList.remove("hidden");
          $("#brain-onboarding-status-text").textContent = "\u2713 Onboarding complete!";
          $("#brain-tab-setup").textContent = "Settings";
          return;
        }
        currentQuestion = data;
        $("#brain-onboarding-q-text").textContent = data.question;
        $("#brain-onboarding-q-context").textContent = data.context ? "Why this matters: " + data.context : "";
        $("#brain-onboarding-question").classList.remove("hidden");
        $("#brain-onboarding-empty").classList.add("hidden");
        $("#brain-onboarding-answer").value = "";
        $("#brain-onboarding-answer").focus();
      } catch {
        $("#brain-onboarding-empty").classList.remove("hidden");
        $("#brain-onboarding-status-text").textContent = "Failed to load question.";
      }
    }

    window._brainSubmitAnswer = async function() {
      if (!currentQuestion) return;
      const answer = $("#brain-onboarding-answer").value.trim();
      if (!answer) return;
      $("#brain-onboarding-submit").disabled = true;
      try {
        const data = await brainFetch("/onboarding/answer", {
          method: "POST",
          body: JSON.stringify({ question_id: currentQuestion.id, answer }),
        });
        flash("brain-onboarding-result", "brain-onboarding-result-text",
          "Got it \u2014 added " + data.nodes_created + " " + (data.nodes_created === 1 ? "thing" : "things") + " to the brain.");
        currentQuestion = null;
        setTimeout(() => loadOnboarding(), 1200);
      } catch (e) {
        alert("Failed: " + e.message);
      } finally {
        $("#brain-onboarding-submit").disabled = false;
      }
    };

    window._brainSkipQuestion = async function() {
      if (!currentQuestion) return;
      try {
        await brainFetch("/onboarding/skip", {
          method: "POST",
          body: JSON.stringify({ question_id: currentQuestion.id }),
        });
        flash("brain-onboarding-result", "brain-onboarding-result-text", "No worries \u2014 you can come back to this later.");
        currentQuestion = null;
        setTimeout(() => loadOnboarding(), 1200);
      } catch {}
    };

    async function loadSkipped() {
      try {
        const data = await brainFetch("/onboarding/history");
        const skipped = (data.questions || []).filter(q => q.status === "SKIPPED");
        if (skipped.length === 0) { $("#brain-skipped-section").classList.add("hidden"); return; }
        $("#brain-skipped-section").classList.remove("hidden");
        let html = "";
        for (const q of skipped) {
          html += '<div class="brain-brief-card" style="cursor:default"><div class="brain-brief-card-header"><span class="brain-brief-card-topic">' + esc(q.question) + '</span></div><button class="btn-ghost" style="margin-top:8px" onclick="window._brainAnswerSkipped(\'' + q.id + '\')">Answer now</button></div>';
        }
        $("#brain-skipped-list").innerHTML = html;
      } catch {}
    }

    window._brainAnswerSkipped = async function(qid) {
      try {
        const data = await brainFetch("/onboarding/history");
        const q = (data.questions || []).find(x => x.id === qid);
        if (!q) return;
        currentQuestion = { id: q.id, question: q.question, context: "" };
        $("#brain-onboarding-q-text").textContent = q.question;
        $("#brain-onboarding-q-context").textContent = "";
        $("#brain-onboarding-question").classList.remove("hidden");
        $("#brain-completion").classList.add("hidden");
        $("#brain-skipped-section").classList.add("hidden");
        $("#brain-onboarding-answer").value = "";
        $("#brain-onboarding-answer").focus();
      } catch {}
    };

    async function loadHistory() {
      try {
        const data = await brainFetch("/onboarding/history");
        const answered = (data.questions || []).filter(q => q.status === "ANSWERED");
        if (answered.length === 0) {
          $("#brain-onboarding-history").innerHTML = '<div class="brain-empty-state"><p>No questions answered yet.</p></div>';
          return;
        }
        let html = "";
        for (const q of answered) {
          html += '<div class="brain-brief-card" style="cursor:default"><div class="brain-brief-card-header"><span class="brain-brief-card-topic" style="color:#2F855A">\u2713 ' + esc(q.question) + '</span></div>' + (q.answer ? '<div class="brain-brief-card-position">&ldquo;' + esc(q.answer) + '&rdquo;</div>' : '') + (q.nodes_created ? '<div class="brain-brief-card-meta"><span>' + q.nodes_created + ' nodes created</span></div>' : '') + '</div>';
        }
        $("#brain-onboarding-history").innerHTML = html;
      } catch {}
    }

    // Welcome start
    $("#brain-welcome-start").addEventListener("click", () => {
      localStorage.setItem(WELCOME_KEY, "true");
      $("#brain-welcome-screen").classList.add("hidden");
      $("#brain-onboarding-flow").style.display = "";
      loadOnboarding();
    });

    // ── Helpers ───────────────────────────────────────────────
    function flash(containerId, textId, msg) {
      const el = document.getElementById(containerId);
      const txt = document.getElementById(textId);
      txt.textContent = msg;
      el.classList.remove("hidden");
      setTimeout(() => el.classList.add("hidden"), 1500);
    }

    // ── Campaign Cache (for brief context) ───────────────────
    let campaignCache = {};

    async function loadCampaignCache() {
      try {
        const campaigns = await brainFetch("/campaigns");
        campaignCache = {};
        for (const c of campaigns) {
          campaignCache[c.id] = c;
        }
      } catch { campaignCache = {}; }
    }

    // ── Scout Signals ────────────────────────────────────────
    async function loadScoutSignals() {
      const $list = $("#brain-scout-list");
      const $loading = $("#brain-scout-loading");
      const $count = $("#brain-scout-count");
      if (!$list) return;

      $loading.classList.remove("hidden");
      $list.innerHTML = "";

      try {
        const data = await brainFetch("/scout/signals");
        const signals = data.signals || [];
        $loading.classList.add("hidden");

        const pending = signals.filter(s => s.status === "PENDING");
        $count.textContent = pending.length > 0 ? "(" + pending.length + ")" : "";

        if (signals.length === 0) {
          $list.innerHTML = '<div class="brain-empty-state"><p>No scout signals yet. Signals appear when the brain detects market intelligence.</p></div>';
          return;
        }

        let html = "";
        for (const s of signals) {
          const statusClass = s.status.toLowerCase();
          const relevanceClass = (s.relevance || "medium").toLowerCase();
          html += '<div class="brain-signal-card">';
          html += '<div class="brain-signal-header">';
          html += '<span class="brain-signal-topic">' + esc(s.topic) + '</span>';
          html += '<span class="brain-signal-status brain-signal-' + statusClass + '">' + s.status + '</span>';
          html += '</div>';
          html += '<p class="brain-signal-summary">' + esc(s.summary) + '</p>';
          html += '<div class="brain-signal-meta">';
          html += '<span class="brain-signal-source">' + esc(s.source_type) + '</span>';
          html += '<span class="brain-signal-relevance brain-relevance-' + relevanceClass + '">' + esc(s.relevance) + '</span>';
          html += '</div>';
          if (s.status === "PENDING") {
            html += '<div class="brain-signal-actions">';
            html += '<button class="btn-primary brain-signal-btn" onclick="window._brainApproveSignal(\'' + s.id + '\')">Approve</button>';
            html += '<button class="btn-ghost brain-signal-btn" onclick="window._brainDismissSignal(\'' + s.id + '\')">Dismiss</button>';
            html += '</div>';
          }
          html += '</div>';
        }
        $list.innerHTML = html;
      } catch (e) {
        $loading.classList.add("hidden");
        $list.innerHTML = '<div class="brain-empty-state"><p>Could not load signals.</p></div>';
      }
    }

    window._brainApproveSignal = async function(id) {
      try {
        await brainFetch("/scout/signals/" + id + "/approve", { method: "POST" });
        loadScoutSignals();
        loadStats();
      } catch (e) { alert("Failed: " + e.message); }
    };

    window._brainDismissSignal = async function(id) {
      try {
        await brainFetch("/scout/signals/" + id + "/dismiss", { method: "POST" });
        loadScoutSignals();
      } catch (e) { alert("Failed: " + e.message); }
    };

    // ── Strategy Tab ─────────────────────────────────────────
    async function loadStrategy() {
      const $loading = $("#brain-strategy-loading");
      const $empty = $("#brain-strategy-empty");
      const $content = $("#brain-strategy-content");
      const $error = $("#brain-strategy-error");
      const $errorText = $("#brain-strategy-error-text");

      $loading.classList.remove("hidden");
      $empty.classList.add("hidden");
      $content.classList.add("hidden");
      $error.classList.add("hidden");

      try {
        const data = await brainFetch("/strategy");
        $loading.classList.add("hidden");

        if (!data || !data.positioning) {
          $empty.classList.remove("hidden");
          return;
        }

        // Version + status
        $("#brain-strategy-version").textContent = "v" + (data.version || 1);
        const statusEl = $("#brain-strategy-status");
        statusEl.textContent = data.status || "ACTIVE";
        statusEl.className = "brain-strategy-status brain-strat-" + (data.status || "active").toLowerCase();

        // Core fields
        $("#brain-strategy-positioning").textContent = data.positioning || "";
        $("#brain-strategy-audience").textContent = data.target_audience || "";

        // Content pillars (tags)
        const pillars = data.content_pillars || [];
        let pillarsHtml = "";
        for (const p of pillars) {
          pillarsHtml += '<span class="brain-tag">' + esc(p) + '</span>';
        }
        $("#brain-strategy-pillars").innerHTML = pillarsHtml || '<span class="brain-empty-text">None defined</span>';

        // Growth levers (tags)
        const levers = data.growth_levers || [];
        let leversHtml = "";
        for (const l of levers) {
          leversHtml += '<span class="brain-tag">' + esc(l) + '</span>';
        }
        $("#brain-strategy-levers").innerHTML = leversHtml || '<span class="brain-empty-text">None defined</span>';

        // Current priorities (numbered list)
        const priorities = data.current_priorities || [];
        let priHtml = "";
        for (let i = 0; i < priorities.length; i++) {
          priHtml += '<div class="brain-priority-item"><span class="brain-priority-num">' + (i + 1) + '</span><span class="brain-priority-text">' + esc(priorities[i]) + '</span></div>';
        }
        $("#brain-strategy-priorities").innerHTML = priHtml || '<span class="brain-empty-text">None defined</span>';

        // Refinement notes
        if (data.refinement_notes) {
          $("#brain-strategy-refinement").textContent = data.refinement_notes;
          $("#brain-strategy-refinement-section").classList.remove("hidden");
        } else {
          $("#brain-strategy-refinement-section").classList.add("hidden");
        }

        // Updated at
        if (data.updated_at) {
          const d = new Date(data.updated_at);
          $("#brain-strategy-updated").textContent = "Last updated " + d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
        }

        $content.classList.remove("hidden");
      } catch (e) {
        $loading.classList.add("hidden");
        $errorText.textContent = e.message;
        $error.classList.remove("hidden");
      }
    }

    // Generate strategy button
    const $genStratBtn = $("#brain-generate-strategy-btn");
    if ($genStratBtn) {
      $genStratBtn.addEventListener("click", async function() {
        $genStratBtn.disabled = true;
        $genStratBtn.textContent = "Generating...";
        try {
          await brainFetch("/strategy/generate", { method: "POST" });
          loadStrategy();
        } catch (e) {
          alert("Failed to generate strategy: " + e.message);
        } finally {
          $genStratBtn.disabled = false;
          $genStratBtn.textContent = "Generate strategy";
        }
      });
    }

    // ── Health Tab ───────────────────────────────────────────
    async function loadHealth() {
      const $loading = $("#brain-health-loading");
      const $content = $("#brain-health-content");
      const $error = $("#brain-health-error");
      const $errorText = $("#brain-health-error-text");

      $loading.classList.remove("hidden");
      $content.classList.add("hidden");
      $error.classList.add("hidden");

      try {
        const health = await brainFetch("/analyst/health");
        $loading.classList.add("hidden");

        // Status banner
        const statusIcon = $("#brain-health-status-icon");
        const statusText = $("#brain-health-status-text");
        const statusBanner = $("#brain-health-status-banner");
        const st = (health.status || "unknown").toLowerCase();
        statusBanner.className = "brain-health-status brain-health-" + st;
        if (st === "healthy" || st === "good") {
          statusIcon.textContent = "\u2713";
          statusText.textContent = "Data health looks good";
        } else if (st === "warning" || st === "needs_attention") {
          statusIcon.textContent = "\u26A0";
          statusText.textContent = "Some data needs attention";
        } else {
          statusIcon.textContent = "\u25CE";
          statusText.textContent = "Data health: " + (health.status || "unknown");
        }

        // Stats grid
        $("#brain-health-outcomes").textContent = health.total_outcomes || 0;
        $("#brain-health-content-count").textContent = health.total_content || 0;
        $("#brain-health-missing").textContent = (health.missing_outcomes || []).length;
        $("#brain-health-stale").textContent = (health.stale_outcomes || []).length;

        // Bias warning
        if (health.bias_warning) {
          $("#brain-health-bias").innerHTML = '<div class="brain-health-warning-text">' + esc(health.bias_warning) + '</div>';
          $("#brain-health-bias-section").classList.remove("hidden");
        } else {
          $("#brain-health-bias-section").classList.add("hidden");
        }

        // Missing outcomes
        const missing = health.missing_outcomes || [];
        if (missing.length > 0) {
          let missHtml = "";
          for (const m of missing) {
            missHtml += '<div class="brain-gap-item"><span class="brain-gap-icon" style="color:#C05621">\u25CB</span><div class="brain-gap-content"><div class="brain-gap-question">' + esc(m) + '</div></div></div>';
          }
          $("#brain-health-missing-list").innerHTML = missHtml;
          $("#brain-health-missing-section").classList.remove("hidden");
        } else {
          $("#brain-health-missing-section").classList.add("hidden");
        }

        // Suggested messages
        const messages = health.suggested_messages || [];
        if (messages.length > 0) {
          let msgHtml = "";
          for (const m of messages) {
            msgHtml += '<div class="brain-gap-item"><span class="brain-gap-icon" style="color:var(--rise-red)">&rarr;</span><div class="brain-gap-content"><div class="brain-gap-question">' + esc(m) + '</div></div></div>';
          }
          $("#brain-health-messages").innerHTML = msgHtml;
          $("#brain-health-messages-section").classList.remove("hidden");
        } else {
          $("#brain-health-messages-section").classList.add("hidden");
        }

        // Last outcome
        if (health.last_outcome_at) {
          const d = new Date(health.last_outcome_at);
          $("#brain-health-last-outcome").textContent = "Last outcome: " + d.toLocaleDateString("en-US", { month: "short", day: "numeric" });
        }

        $content.classList.remove("hidden");

        // Load insights separately (may take longer)
        loadInsights();
        loadDistillation();
      } catch (e) {
        $loading.classList.add("hidden");
        $errorText.textContent = e.message;
        $error.classList.remove("hidden");
      }
    }

    async function loadInsights() {
      const $loading = $("#brain-insights-loading");
      const $list = $("#brain-health-insights");
      const $count = $("#brain-health-insight-count");

      $loading.classList.remove("hidden");
      $list.innerHTML = "";

      try {
        const data = await brainFetch("/analyst/insights");
        $loading.classList.add("hidden");

        const insights = data || [];
        $count.textContent = insights.length > 0 ? "(" + insights.length + ")" : "";

        if (insights.length === 0) {
          $list.innerHTML = '<div class="brain-empty-state"><p>No insights yet. Insights appear after recording outcomes and analyzing patterns.</p></div>';
          return;
        }

        let html = "";
        for (const ins of insights) {
          const conf = (ins.confidence || "MEDIUM").toLowerCase();
          html += '<div class="brain-insight-card">';
          html += '<div class="brain-insight-header">';
          html += '<span class="brain-insight-pattern">' + esc(ins.pattern) + '</span>';
          html += '<span class="brain-confidence ' + conf + '">' + (ins.confidence || "MEDIUM") + '</span>';
          html += '</div>';
          if (ins.impact_estimate) {
            html += '<p class="brain-insight-impact">' + esc(ins.impact_estimate) + '</p>';
          }
          html += '</div>';
        }
        $list.innerHTML = html;
      } catch {
        $loading.classList.add("hidden");
        $list.innerHTML = '<div class="brain-empty-state"><p>Could not load insights.</p></div>';
      }
    }

    // ── Distillation ──────────────────────────────────────────
    async function loadDistillation() {
      try {
        const data = await brainFetch("/distill/status");
        $("#brain-distill-total").textContent = data.total_outcomes || 0;
        $("#brain-distill-done").textContent = data.distilled_outcomes || 0;
        $("#brain-distill-pending").textContent = data.undistilled_outcomes || 0;
        $("#brain-distill-knowledge").textContent = data.distilled_knowledge_nodes || 0;

        const btn = $("#brain-distill-btn");
        if (data.ready_for_distillation) {
          btn.disabled = false;
          btn.textContent = "Run Distillation";
        } else {
          btn.disabled = true;
          btn.textContent = "Not enough outcomes (need 3+)";
        }
      } catch {
        // Silently fail — distillation section is non-critical
      }
    }

    async function triggerDistillation() {
      const btn = $("#brain-distill-btn");
      const status = $("#brain-distill-status");
      const results = $("#brain-distill-results");

      btn.disabled = true;
      btn.textContent = "Running...";
      status.textContent = "Analyzing outcome patterns...";
      results.innerHTML = "";

      try {
        const data = await brainFetch("/distill", { method: "POST" });
        status.textContent = "Done";

        let html = '<div class="brain-insight-card">';
        html += '<div class="brain-insight-header"><span class="brain-insight-pattern">Distillation Complete</span></div>';
        html += '<p style="font-size:0.82rem;color:var(--rise-neutral-600);margin:6px 0 0;">';
        html += data.groups_analyzed + " groups analyzed, " + data.patterns_found + " patterns found, " + data.knowledge_nodes_created + " knowledge nodes created.";
        html += '</p></div>';

        if (data.details && data.details.length > 0) {
          for (const d of data.details) {
            const color = d.status === "distilled" ? "#2F855A" : d.status === "skipped" ? "#B7791F" : "#C05621";
            html += '<div class="brain-gap-item"><span class="brain-gap-icon" style="color:' + color + '">';
            html += d.status === "distilled" ? "\u2713" : d.status === "skipped" ? "\u25CB" : "\u2717";
            html += '</span><div class="brain-gap-content"><div class="brain-gap-question">';
            html += esc(d.group) + ": " + esc(d.status);
            if (d.reason) html += " (" + esc(d.reason) + ")";
            if (d.patterns) html += " \u2014 " + d.patterns + " patterns";
            html += '</div></div></div>';
          }
        }

        results.innerHTML = html;
        loadDistillation(); // Refresh stats
      } catch (e) {
        status.textContent = "Failed: " + e.message;
        btn.disabled = false;
        btn.textContent = "Retry";
      }
    }

    // Wire distillation button
    const distillBtn = document.getElementById("brain-distill-btn");
    if (distillBtn) distillBtn.addEventListener("click", triggerDistillation);

    // ── Brief campaign context (rendered in createBriefCard) ──
    function getCampaignBadge(brief) {
      if (!brief.campaign_id || !campaignCache[brief.campaign_id]) return "";
      const c = campaignCache[brief.campaign_id];
      return '<span class="brain-brief-campaign-tag" title="' + esc(c.theme || "") + '">' + esc(c.name) + '</span>';
    }

    // ── Boot ──────────────────────────────────────────────────
    initBrain();
    setupTabs();
  </script>
</BaseLayout>

<!-- ── Styles ──────────────────────────────────────────────────── -->
