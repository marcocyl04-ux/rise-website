---
// /portal/brain — RISE Marketing Brain (founder-only)
// Authenticates via Supabase, checks role, talks to Brain API.
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

// Brain API URL
const BRAIN_API = import.meta.env.PUBLIC_BRAIN_API_URL || "http://localhost:8000";
---

<BaseLayout title="Marketing Brain" description="RISE strategic marketing intelligence engine.">
  <Header slot="header" />

  <!-- PWA app header -->
  <div class="pwa-app-header" aria-hidden="true">
    <img src="/logo-header.png" alt="RISE" class="pwa-app-header-logo" />
  </div>

  <!-- Loading -->
  <section id="brain-loading" class="brain-loading">
    <div class="brain-spinner" aria-hidden="true"></div>
  </section>

  <!-- Not logged in -->
  <section id="brain-anon" class="brain-anon section" hidden>
    <div class="container brain-narrow">
      <h1 class="brain-anon-title">Sign in to your portal</h1>
      <p class="brain-anon-sub">You need to be logged in to access the Marketing Brain.</p>
      <div class="brain-anon-actions">
        <button class="btn-primary" type="button" data-open-auth>Log in</button>
        <a class="btn-ghost" href="/">Back to home</a>
      </div>
    </div>
  </section>

  <!-- Wrong role -->
  <section id="brain-denied" class="brain-anon section" hidden>
    <div class="container brain-narrow">
      <h1 class="brain-anon-title">Founders only</h1>
      <p class="brain-anon-sub">The Marketing Brain is only accessible to RISE founders.</p>
      <div class="brain-anon-actions">
        <a class="btn-primary" href="/portal">Back to portal</a>
      </div>
    </div>
  </section>

  <!-- ── Brain Dashboard ──────────────────────────────────────── -->
  <section id="brain-dashboard" class="brain-dashboard section" hidden>
    <div class="container brain-container">

      <!-- Header -->
      <header class="brain-header">
        <div class="brain-header-top">
          <p class="brain-eyebrow">RISE Brain</p>
          <div class="brain-stats">
            <span class="brain-stat" id="brain-node-count">— nodes</span>
            <span class="brain-stat-sep">&middot;</span>
            <span class="brain-stat" id="brain-budget">—</span>
          </div>
        </div>
        <h1 class="brain-title">Marketing Brain</h1>
        <p class="brain-sub">Strategic marketing intelligence engine</p>
      </header>

      <!-- Tab Nav — 3 workflow-centric tabs -->
      <nav class="brain-tabs">
        <button class="brain-tab active" data-tab="week">This Week</button>
        <button class="brain-tab" data-tab="intel">Intelligence</button>
        <button class="brain-tab" data-tab="settings">Settings</button>
      </nav>

      <!-- ── Tab 1: This Week (the hub) ──────────────────────── -->
      <div class="brain-panel active" id="panel-week">

        <!-- Week Summary (the anchor / 中心思想) -->
        <div class="brain-week-summary" id="brain-week-summary">
          <div class="brain-week-campaign">
            <span class="brain-week-campaign-tag" id="brain-week-campaign-tag">Campaign</span>
            <span class="brain-week-campaign-name" id="brain-week-campaign-name">Loading...</span>
          </div>
          <h2 class="brain-week-goal" id="brain-week-goal">Loading this week's plan...</h2>
          <p class="brain-week-reasoning" id="brain-week-reasoning"></p>

          <!-- Evidence trail -->
          <div class="brain-evidence-trail" id="brain-week-evidence">
            <div class="brain-evidence-label">Why this direction</div>
            <div id="brain-week-evidence-items"></div>
          </div>

          <!-- Progress -->
          <div class="brain-week-progress">
            <div class="brain-progress-bar-wrap">
              <div class="brain-progress-bar-fill" id="brain-week-progress-fill" style="width:0%"></div>
            </div>
            <span class="brain-progress-label" id="brain-week-progress-label">0 of 0 completed</span>
          </div>
        </div>

        <!-- Nudge (conditional) -->
        <div class="brain-nudge hidden" id="brain-nudge-banner">
          <span class="brain-nudge-icon">!</span>
          <div class="brain-nudge-text" id="brain-nudge-text"></div>
        </div>

        <!-- Briefs Section -->
        <div class="brain-section-header">
          <span class="brain-section-title">This Week's Briefs</span>
          <span class="brain-section-count" id="brain-brief-count">0 briefs</span>
        </div>

        <!-- Generate button (when no briefs) -->
        <div class="brain-generate-section hidden" id="brain-generate-section">
          <p class="brain-empty-state">No briefs yet this week.</p>
          <button class="btn-primary brain-generate-btn" id="brain-generate-btn">Generate this week's briefs</button>
        </div>

        <!-- Loading -->
        <div class="brain-loading-inline hidden" id="brain-briefs-loading">
          <div class="brain-loading-bar"><div class="brain-loading-bar-fill"></div></div>
          <span>Generating briefs...</span>
        </div>

        <!-- Briefs container -->
        <div class="brain-briefs-container" id="brain-briefs-container"></div>

        <!-- Error -->
        <div class="brain-error-card hidden" id="brain-briefs-error">
          <p class="brain-error-text" id="brain-briefs-error-text"></p>
        </div>

        <!-- Feed the Brain -->
        <div class="brain-feed-section">
          <div class="brain-section-header">
            <span class="brain-section-title">Feed the Brain</span>
          </div>

          <div class="brain-feed-input-area">
            <div class="brain-feed-type-row">
              <button class="brain-feed-type-btn active" data-feed="event">Event</button>
              <button class="brain-feed-type-btn" data-feed="competitor">Competitor</button>
              <button class="brain-feed-type-btn" data-feed="note">Note</button>
              <button class="brain-feed-type-btn" data-feed="idea">Idea</button>
            </div>
            <textarea class="brain-feed-textarea" id="brain-feed-input" placeholder="e.g. HK Youth Tournament is July 15-17, 12 teams registered..."></textarea>
            <div class="brain-feed-actions">
              <span class="brain-feed-hint">The brain uses this to improve your briefs and strategy.</span>
              <button class="btn-primary" id="brain-feed-submit">Submit</button>
            </div>
          </div>

          <!-- Feed History -->
          <div class="brain-feed-history" id="brain-feed-history"></div>
        </div>

        <!-- What the Brain Learned -->
        <div class="brain-insights-section">
          <div class="brain-section-header">
            <span class="brain-section-title">What the Brain Learned</span>
          </div>
          <div id="brain-insights-container"></div>
        </div>
      </div>

      <!-- ── Tab 2: Intelligence ──────────────────────────────── -->
      <div class="brain-panel" id="panel-intel">

        <!-- Ask the Brain -->
        <div class="brain-section-header">
          <span class="brain-section-title">Ask the Brain</span>
        </div>

        <form class="brain-consult-form" id="brain-consult-form">
          <input type="text" class="brain-consult-input" id="brain-consult-input"
            placeholder="What should I post about for the summer tournament season?" autocomplete="off" />
        </form>

        <div class="brain-consult-suggestions" id="brain-consult-suggestions">
          <span class="brain-suggestion" data-query="What content is working best right now?">What content is working best right now?</span>
          <span class="brain-suggestion" data-query="Should we pivot our strategy?">Should we pivot our strategy?</span>
          <span class="brain-suggestion" data-query="What are competitors doing?">What are competitors doing?</span>
          <span class="brain-suggestion" data-query="How do I reach more parents?">How do I reach more parents?</span>
        </div>

        <!-- Loading -->
        <div class="brain-loading-inline hidden" id="brain-consult-loading">
          <div class="brain-loading-bar"><div class="brain-loading-bar-fill"></div></div>
          <span>Thinking...</span>
        </div>

        <!-- Result Card -->
        <div class="brain-consult-result hidden" id="brain-consult-result">
          <section class="brain-consult-section">
            <h3 class="brain-consult-label">Position</h3>
            <p class="brain-consult-text" id="brain-consult-position"></p>
          </section>
          <section class="brain-consult-section" id="brain-consult-chain-section">
            <h3 class="brain-consult-label">Consequence Chain</h3>
            <div id="brain-consult-chain"></div>
          </section>
          <section class="brain-consult-section">
            <h3 class="brain-consult-label">Reasoning</h3>
            <p class="brain-consult-text" id="brain-consult-reasoning"></p>
          </section>
          <section class="brain-consult-section hidden" id="brain-consult-gaps-section">
            <h3 class="brain-consult-label">Knowledge Gaps</h3>
            <div id="brain-consult-gaps"></div>
          </section>
          <footer class="brain-consult-meta">
            <span class="brain-confidence" id="brain-consult-confidence">—</span>
            <span class="brain-meta-sep">&middot;</span>
            <span id="brain-consult-sources">No sources</span>
            <span class="brain-meta-sep">&middot;</span>
            <span id="brain-consult-model"></span>
          </footer>
        </div>

        <!-- Error -->
        <div class="brain-error-card hidden" id="brain-consult-error">
          <p class="brain-error-text" id="brain-consult-error-text"></p>
        </div>

        <!-- Current Strategy -->
        <div class="brain-section-header" style="margin-top:32px">
          <span class="brain-section-title">Current Strategy</span>
          <span class="brain-section-count" id="brain-strategy-version">—</span>
        </div>
        <div class="brain-strategy-grid" id="brain-strategy-grid">
          <div class="brain-strategy-card">
            <div class="brain-strategy-card-title">Positioning</div>
            <div class="brain-strategy-card-content" id="brain-strategy-positioning">Loading...</div>
          </div>
          <div class="brain-strategy-card">
            <div class="brain-strategy-card-title">Target Audience</div>
            <div class="brain-strategy-card-content" id="brain-strategy-audience">Loading...</div>
          </div>
          <div class="brain-strategy-card">
            <div class="brain-strategy-card-title">Content Pillars</div>
            <div class="brain-strategy-card-content" id="brain-strategy-pillars">Loading...</div>
          </div>
          <div class="brain-strategy-card">
            <div class="brain-strategy-card-title">Growth Levers</div>
            <div class="brain-strategy-card-content" id="brain-strategy-levers">Loading...</div>
          </div>
        </div>

        <!-- Market Signals -->
        <div class="brain-section-header">
          <span class="brain-section-title">Market Signals</span>
          <span class="brain-section-count" id="brain-signal-count">—</span>
        </div>
        <div class="brain-signals-container" id="brain-signals-container"></div>

        <!-- Knowledge Gaps -->
        <div class="brain-section-header" style="margin-top:32px">
          <span class="brain-section-title">What the Brain Needs</span>
          <span class="brain-section-count" id="brain-gap-count">—</span>
        </div>
        <div id="brain-gaps-container"></div>
      </div>

      <!-- ── Tab 3: Settings ──────────────────────────────────── -->
      <div class="brain-panel" id="panel-settings">

        <!-- Data Health -->
        <div class="brain-section-header">
          <span class="brain-section-title">Data Health</span>
        </div>
        <div class="brain-health-grid">
          <div class="brain-health-stat">
            <div class="brain-health-stat-value" id="brain-health-outcomes">0</div>
            <div class="brain-health-stat-label">Outcomes tracked</div>
          </div>
          <div class="brain-health-stat">
            <div class="brain-health-stat-value" id="brain-health-content-count">0</div>
            <div class="brain-health-stat-label">Content pieces</div>
          </div>
          <div class="brain-health-stat">
            <div class="brain-health-stat-value brain-amber" id="brain-health-missing">0</div>
            <div class="brain-health-stat-label">Missing outcomes</div>
          </div>
          <div class="brain-health-stat">
            <div class="brain-health-stat-value brain-green" id="brain-health-coverage">0%</div>
            <div class="brain-health-stat-label">Data coverage</div>
          </div>
        </div>

        <!-- Confidence Breakdown -->
        <div class="brain-section-header">
          <span class="brain-section-title">Confidence Breakdown</span>
        </div>
        <div class="brain-confidence-card" id="brain-confidence-card">
          <div class="brain-confidence-row">
            <div class="brain-confidence-row-header">
              <span class="brain-confidence-label">Recency</span>
              <span class="brain-confidence-detail" id="brain-conf-recency-detail">—</span>
            </div>
            <div class="brain-confidence-bar"><div class="brain-confidence-fill" id="brain-conf-recency-fill" style="width:0%"></div></div>
          </div>
          <div class="brain-confidence-row">
            <div class="brain-confidence-row-header">
              <span class="brain-confidence-label">Volume</span>
              <span class="brain-confidence-detail" id="brain-conf-volume-detail">—</span>
            </div>
            <div class="brain-confidence-bar"><div class="brain-confidence-fill" id="brain-conf-volume-fill" style="width:0%"></div></div>
          </div>
          <div class="brain-confidence-row">
            <div class="brain-confidence-row-header">
              <span class="brain-confidence-label">Variety</span>
              <span class="brain-confidence-detail" id="brain-conf-variety-detail">—</span>
            </div>
            <div class="brain-confidence-bar"><div class="brain-confidence-fill" id="brain-conf-variety-fill" style="width:0%"></div></div>
          </div>
          <div class="brain-confidence-row">
            <div class="brain-confidence-row-header">
              <span class="brain-confidence-label">Bias</span>
              <span class="brain-confidence-detail" id="brain-conf-bias-detail">—</span>
            </div>
            <div class="brain-confidence-bar"><div class="brain-confidence-fill" id="brain-conf-bias-fill" style="width:0%"></div></div>
          </div>
        </div>

        <!-- Distillation -->
        <div class="brain-section-header" style="margin-top:32px">
          <span class="brain-section-title">Distillation</span>
        </div>
        <div class="brain-distill-card">
          <div class="brain-health-grid">
            <div class="brain-health-stat">
              <div class="brain-health-stat-value" id="brain-distill-total">0</div>
              <div class="brain-health-stat-label">Total outcomes</div>
            </div>
            <div class="brain-health-stat">
              <div class="brain-health-stat-value brain-green" id="brain-distill-done">0</div>
              <div class="brain-health-stat-label">Distilled</div>
            </div>
            <div class="brain-health-stat">
              <div class="brain-health-stat-value brain-amber" id="brain-distill-pending">0</div>
              <div class="brain-health-stat-label">Pending</div>
            </div>
            <div class="brain-health-stat">
              <div class="brain-health-stat-value" id="brain-distill-knowledge">0</div>
              <div class="brain-health-stat-label">Knowledge nodes</div>
            </div>
          </div>
          <div class="brain-distill-actions">
            <button class="btn-primary" id="brain-distill-btn" style="font-size:0.82rem;padding:8px 18px;">Run Distillation</button>
            <span id="brain-distill-status" class="brain-distill-status-text"></span>
          </div>
          <div id="brain-distill-results" style="margin-top:12px;"></div>
        </div>

        <!-- Learning Rules -->
        <div class="brain-section-header" style="margin-top:32px">
          <span class="brain-section-title">Learning Rules</span>
          <span class="brain-section-count" id="brain-rules-count">—</span>
        </div>
        <div class="brain-rules-card" id="brain-rules-container"></div>

        <!-- Onboarding -->
        <div class="brain-section-header" style="margin-top:32px">
          <span class="brain-section-title">Onboarding</span>
        </div>
        <div id="brain-onboarding-container">
          <div class="brain-empty-state">
            <p>Onboarding helps the brain learn about your business. Answer questions to improve your briefs.</p>
            <button class="btn-primary" id="brain-onboarding-start" style="margin-top:12px">Start onboarding</button>
          </div>
        </div>
      </div>

    </div>
  </section>

  <Footer slot="footer" />

  <!-- ── Auth + Boot ─────────────────────────────────────────── -->
  <script is:inline define:vars={{ BRAIN_API }}>
    const API = BRAIN_API;

    // ── Auth check ────────────────────────────────────────────
    async function initBrain() {
      const sb = window.supabaseClient;
      if (!sb) { setTimeout(initBrain, 100); return; }

      const loading = document.getElementById("brain-loading");
      const anon = document.getElementById("brain-anon");
      const denied = document.getElementById("brain-denied");
      const dash = document.getElementById("brain-dashboard");

      const { data: { session } } = await sb.auth.getSession();

      if (!session) {
        loading.setAttribute("hidden", "");
        anon.removeAttribute("hidden");
        sb.auth.onAuthStateChange((_e, s) => { if (s) window.location.reload(); });
        return;
      }

      const user = session.user;

      // Check role
      const { data: profile } = await sb
        .from("user_profiles")
        .select("role")
        .eq("id", user.id)
        .maybeSingle();

      const role = profile?.role || "athlete";
      if (role !== "coach" && role !== "founder") {
        loading.setAttribute("hidden", "");
        denied.removeAttribute("hidden");
        return;
      }

      // Store session token for API calls
      window._brainToken = session.access_token;

      loading.setAttribute("hidden", "");
      dash.removeAttribute("hidden");
      brainInit();
    }

    // ── API helper (with auth header) ─────────────────────────
    async function brainFetch(path, opts = {}) {
      const headers = { "Content-Type": "application/json", ...(opts.headers || {}) };
      if (window._brainToken) {
        headers["Authorization"] = "Bearer " + window._brainToken;
      }
      const resp = await fetch(API + path, { ...opts, headers });
      if (!resp.ok) {
        const err = await resp.json().catch(() => ({ detail: resp.statusText }));
        throw new Error(err.detail || "HTTP " + resp.status);
      }
      return resp.json();
    }

    // ── DOM helpers ───────────────────────────────────────────
    const $ = (s) => document.querySelector(s);
    const $$ = (s) => document.querySelectorAll(s);

    function esc(str) {
      const d = document.createElement("div");
      d.textContent = str || "";
      return d.innerHTML;
    }

    // ── Tabs ──────────────────────────────────────────────────
    function setupTabs() {
      $$(".brain-tab").forEach((tab) => {
        tab.addEventListener("click", () => {
          const target = tab.dataset.tab;
          $$(".brain-tab").forEach((t) => t.classList.toggle("active", t === tab));
          $$(".brain-panel").forEach((p) => p.classList.toggle("active", p.id === "panel-" + target));
          if (target === "week") { loadBriefs(); loadInsights(); }
          if (target === "intel") { loadStrategy(); loadScoutSignals(); loadGaps(); }
          if (target === "settings") { loadHealth(); loadDistillation(); loadRules(); }
        });
      });
    }

    // ── Brain Init ────────────────────────────────────────────
    function brainInit() {
      loadStats();
      setWeekHeader();
      loadCampaignCache().then(() => {
        loadBriefs();
        loadInsights();
        loadFeedHistory();
      });
    }

    // ── Stats ─────────────────────────────────────────────────
    async function loadStats() {
      try {
        const data = await brainFetch("/health");
        $("#brain-node-count").textContent = (data.graph_nodes || 0) + " nodes";
        if (data.budget_remaining !== undefined) {
          $("#brain-budget").textContent = "$" + data.budget_remaining.toFixed(2) + " left";
        }
      } catch {
        $("#brain-node-count").textContent = "offline";
        $("#brain-budget").textContent = "\u2014";
      }
    }

    // ── Week Header ───────────────────────────────────────────
    function setWeekHeader() {
      const now = new Date();
      const day = now.getDay();
      const diff = now.getDate() - day + (day === 0 ? -6 : 1);
      const monday = new Date(now.getFullYear(), now.getMonth(), diff);
      // The week header is now part of the week summary card
    }

    // ── Campaign Cache ────────────────────────────────────────
    let campaignCache = {};

    async function loadCampaignCache() {
      try {
        const campaigns = await brainFetch("/campaigns");
        campaignCache = {};
        for (const c of campaigns) {
          campaignCache[c.id] = c;
        }
      } catch { campaignCache = {}; }
    }

    // ── Briefs ────────────────────────────────────────────────
    const expandedBriefs = new Set();

    async function loadBriefs() {
      const $container = $("#brain-briefs-container");
      const $genSection = $("#brain-generate-section");
      const $loading = $("#brain-briefs-loading");
      const $error = $("#brain-briefs-error");
      const $errorText = $("#brain-briefs-error-text");

      if (!$container) return;
      $container.innerHTML = "";
      if ($genSection) $genSection.classList.add("hidden");
      if ($loading) $loading.classList.remove("hidden");
      if ($error) $error.classList.add("hidden");

      try {
        const data = await brainFetch("/briefs?limit=10");
        const briefs = data.briefs || [];
        if ($loading) $loading.classList.add("hidden");

        if (briefs.length === 0) {
          if ($genSection) $genSection.classList.remove("hidden");
          return;
        }

        // Update brief count
        $("#brain-brief-count").textContent = briefs.length + " briefs";

        // Update progress
        const completed = briefs.filter(b => b.status === "REPORTED" || b.status === "APPROVED").length;
        const pct = briefs.length > 0 ? Math.round((completed / briefs.length) * 100) : 0;
        $("#brain-week-progress-fill").style.width = pct + "%";
        $("#brain-week-progress-label").textContent = completed + " of " + briefs.length + " completed";

        for (const brief of briefs) {
          $container.appendChild(createBriefCard(brief));
        }
      } catch (err) {
        if ($loading) $loading.classList.add("hidden");
        if ($error) {
          $error.classList.remove("hidden");
          if ($errorText) $errorText.textContent = "Failed to load briefs: " + err.message;
        }
      }
    }

    function createBriefCard(brief) {
      const card = document.createElement("div");
      card.className = "brain-brief-card";
      card.dataset.id = brief.id;

      const content = brief.content || {};
      const isExpanded = expandedBriefs.has(brief.id);
      const confClass = (content.confidence || brief.confidence || "MEDIUM").toLowerCase();
      const statusClass = brief.status.toLowerCase();

      // Header
      let html = '<div class="brain-brief-header" onclick="window._brainToggleBrief(\'' + brief.id + '\')">';
      html += '<div class="brain-brief-num ' + (brief.status === "REPORTED" ? "done" : "") + '">' + (brief.position || "#") + '</div>';
      html += '<div class="brain-brief-title-wrap">';
      html += '<div class="brain-brief-title">' + esc(brief.topic) + '</div>';
      html += '<div class="brain-brief-subtitle">' + esc(content.what_to_post ? content.what_to_post.substring(0, 60) + "..." : "") + '</div>';
      html += '</div>';
      html += '<span class="brain-brief-badge brain-badge-' + statusClass + '">' + brief.status + '</span>';
      html += '<span class="brain-brief-expand-icon">' + (isExpanded ? "^" : "v") + '</span>';
      html += '</div>';

      // Body (expanded)
      if (isExpanded) {
        html += '<div class="brain-brief-body">';

        // Confidence meter
        html += '<div class="brain-confidence-meter">';
        html += '<span class="brain-confidence-level brain-conf-' + confClass + '">' + (content.confidence || brief.confidence || "MEDIUM") + '</span>';
        html += '<span class="brain-confidence-desc">' + esc(brief.gaps?.length > 0 ? brief.gaps.join("; ") : "Based on available data") + '</span>';
        html += '</div>';

        // What to post
        if (content.what_to_post) {
          html += '<div class="brain-brief-section"><div class="brain-brief-section-label">What to post</div><div class="brain-brief-section-text">' + esc(content.what_to_post) + '</div></div>';
        }
        // Why it matters
        if (content.why_it_matters) {
          html += '<div class="brain-brief-section"><div class="brain-brief-section-label">Why this works</div><div class="brain-brief-section-text">' + esc(content.why_it_matters) + '</div></div>';
        }
        // How to film
        if (content.how_to_fil) {
          html += '<div class="brain-brief-section"><div class="brain-brief-section-label">How to film</div><div class="brain-brief-section-text">' + esc(content.how_to_fil) + '</div></div>';
        }
        // Caption
        if (content.caption) {
          html += '<div class="brain-brief-section"><div class="brain-brief-section-label">Caption (ready to copy)</div><div class="brain-brief-caption" onclick="window._brainCopyCaption(this)" title="Click to copy">' + esc(content.caption) + '</div></div>';
        }
        // Hashtags
        const hashtags = content.hashtags || [];
        if (hashtags.length > 0) {
          html += '<div class="brain-brief-hashtags">' + hashtags.map(h => '<span class="brain-hashtag">' + esc(h) + '</span>').join("") + '</div>';
        }
        // Consequence chain
        if (content.consequence_chain) {
          html += '<div class="brain-brief-section"><div class="brain-brief-section-label">What happens when you post this</div><div class="brain-brief-section-text">' + esc(content.consequence_chain) + '</div></div>';
        }

        // Evidence trail
        html += '<div class="brain-evidence-trail">';
        html += '<div class="brain-evidence-label">Evidence</div>';
        html += '<div class="brain-evidence-item"><span class="brain-evidence-icon">%</span><span class="brain-evidence-text"><strong>Confidence:</strong> ' + esc(content.confidence || brief.confidence || "MEDIUM") + '</span></div>';
        if (brief.sources?.length > 0) {
          html += '<div class="brain-evidence-item"><span class="brain-evidence-icon">%</span><span class="brain-evidence-text"><strong>Sources:</strong> ' + brief.sources.length + ' graph nodes referenced</span></div>';
        }
        html += '</div>';

        // Actions
        html += '<div class="brain-brief-actions">';
        if (brief.status === "PENDING") {
          html += '<button class="btn-primary brain-brief-action-btn" onclick="window._brainApproveBrief(\'' + brief.id + '\')">Approve</button>';
          html += '<button class="btn-ghost brain-brief-action-btn" onclick="window._brainRejectBrief(\'' + brief.id + '\')">Reject</button>';
        } else if (brief.status === "APPROVED") {
          html += '<button class="btn-ghost brain-brief-action-btn" onclick="window._brainShowOutcome(\'' + brief.id + '\')">Report Outcome</button>';
          html += '<span class="brain-brief-status-label">' + brief.status + '</span>';
        } else {
          html += '<span class="brain-brief-status-label">' + brief.status + '</span>';
        }
        html += '</div>';

        // Outcome form (hidden by default)
        html += '<div class="brain-outcome-form hidden" id="brain-outcome-' + brief.id + '">';
        html += '<div class="brain-outcome-form-title">Report Outcome</div>';
        html += '<div class="brain-outcome-grid">';
        html += '<div class="brain-outcome-field"><label>Views</label><input type="number" placeholder="0" id="brain-views-' + brief.id + '"></div>';
        html += '<div class="brain-outcome-field"><label>DMs</label><input type="number" placeholder="0" id="brain-dms-' + brief.id + '"></div>';
        html += '<div class="brain-outcome-field"><label>Saves</label><input type="number" placeholder="0" id="brain-saves-' + brief.id + '"></div>';
        html += '<div class="brain-outcome-field"><label>Comments</label><input type="number" placeholder="0" id="brain-comments-' + brief.id + '"></div>';
        html += '</div>';
        html += '<div class="brain-outcome-actions">';
        html += '<button class="btn-ghost" onclick="window._brainCancelOutcome(\'' + brief.id + '\')">Cancel</button>';
        html += '<button class="btn-primary" onclick="window._brainSubmitOutcome(\'' + brief.id + '\')">Submit</button>';
        html += '</div></div>';

        html += '</div>';
      }

      card.innerHTML = html;
      return card;
    }

    window._brainToggleBrief = function(id) {
      if (expandedBriefs.has(id)) {
        expandedBriefs.delete(id);
      } else {
        expandedBriefs.add(id);
      }
      loadBriefs();
    };

    window._brainCopyCaption = function(el) {
      const text = el.textContent.trim();
      navigator.clipboard.writeText(text).then(function() {
        const orig = el.style.background;
        el.style.background = "var(--brain-green)";
        el.style.color = "#fff";
        setTimeout(function() { el.style.background = orig; el.style.color = ""; }, 800);
      });
    };

    window._brainApproveBrief = async function(id) {
      try {
        await brainFetch("/briefs/" + id + "/approve", { method: "POST", body: JSON.stringify({ notes: "" }) });
        loadBriefs();
        showFlash("Brief approved. Execute the post, then report the outcome here.");
      } catch (err) { alert("Failed to approve."); }
    };

    window._brainRejectBrief = async function(id) {
      const notes = prompt("Why reject this brief? (optional)") || "";
      try {
        await brainFetch("/briefs/" + id + "/reject", { method: "POST", body: JSON.stringify({ notes: notes }) });
        loadBriefs();
        showFlash("Brief rejected.");
      } catch (err) { alert("Failed to reject."); }
    };

    window._brainShowOutcome = function(id) {
      const form = document.getElementById("brain-outcome-" + id);
      if (form) {
        form.classList.remove("hidden");
        const viewsInput = document.getElementById("brain-views-" + id);
        if (viewsInput) viewsInput.focus();
      }
    };

    window._brainCancelOutcome = function(id) {
      const form = document.getElementById("brain-outcome-" + id);
      if (form) form.classList.add("hidden");
    };

    window._brainSubmitOutcome = async function(id) {
      const views = parseInt(document.getElementById("brain-views-" + id)?.value) || 0;
      const dms = parseInt(document.getElementById("brain-dms-" + id)?.value) || 0;
      const saves = parseInt(document.getElementById("brain-saves-" + id)?.value) || 0;
      const comments = parseInt(document.getElementById("brain-comments-" + id)?.value) || 0;

      try {
        await brainFetch("/analyst/outcome", {
          method: "POST",
          body: JSON.stringify({
            content_id: id,
            views: views,
            dms: dms,
            saves: saves,
            comments: comments,
            qualitative_notes: ""
          })
        });
        loadBriefs();
        loadInsights();
        showFlash("Outcome recorded. The brain is learning from this data.");
      } catch (err) {
        alert("Failed to record outcome: " + err.message);
      }
    };

    // Generate weekly button
    const $genBtn = $("#brain-generate-btn");
    if ($genBtn) {
      $genBtn.addEventListener("click", async function() {
        const $genSection = $("#brain-generate-section");
        const $loading = $("#brain-briefs-loading");
        const $error = $("#brain-briefs-error");
        const $errorText = $("#brain-briefs-error-text");

        if ($genSection) $genSection.classList.add("hidden");
        if ($loading) $loading.classList.remove("hidden");
        if ($error) $error.classList.add("hidden");

        try {
          await brainFetch("/briefs/generate-weekly", { method: "POST" });
          if ($loading) $loading.classList.add("hidden");
          loadBriefs();
        } catch (err) {
          if ($loading) $loading.classList.add("hidden");
          if ($error) {
            $error.classList.remove("hidden");
