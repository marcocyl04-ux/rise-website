    // ── Feed the Brain ────────────────────────────────────────
    let feedHistory = [];

    function setupFeed() {
      // Type buttons
      $$(".brain-feed-type-btn").forEach(btn => {
        btn.addEventListener("click", () => {
          $$(".brain-feed-type-btn").forEach(b => b.classList.remove("active"));
          btn.classList.add("active");
          const textarea = $("#brain-feed-input");
          const placeholders = {
            event: "e.g. HK Youth Tournament is July 15-17, 12 teams registered...",
            competitor: "e.g. Ice Academy HK launching summer camp, HKD 8,500...",
            note: "e.g. Parents at the rink asking about summer programs...",
            idea: "e.g. What if we did a live stream from the tournament?"
          };
          textarea.placeholder = placeholders[btn.dataset.feed] || "Tell the brain something...";
        });
      });

      // Submit
      $("#brain-feed-submit").addEventListener("click", submitFeed);
    }

    async function submitFeed() {
      const input = $("#brain-feed-input");
      const text = input.value.trim();
      if (!text) return;

      const activeType = document.querySelector(".brain-feed-type-btn.active");
      const type = activeType ? activeType.dataset.feed : "note";

      try {
        // Use the scout event endpoint
        await brainFetch("/scout/event", {
          method: "POST",
          body: JSON.stringify({
            event_type: type,
            description: text,
            date: new Date().toISOString().split("T")[0],
            relevance: "User-reported " + type,
            source: "ryan"
          })
        });

        input.value = "";
        loadFeedHistory();
        showFlash("Added to the brain. It will use this in future briefs and strategy.");
      } catch (err) {
        alert("Failed to submit: " + err.message);
      }
    }

    async function loadFeedHistory() {
      const container = $("#brain-feed-history");
      if (!container) return;

      try {
        const data = await brainFetch("/scout/signals");
        const signals = data.signals || [];
        feedHistory = signals;

        let html = "";
        for (const s of signals.slice(0, 10)) {
          const typeClass = s.source_type === "ryan" ? "event" : s.source_type === "web" ? "competitor" : "note";
          const icons = { event: "!", competitor: "%", note: "~", idea: "*" };
          const statusText = s.status === "CONFIRMED" ? "Confirmed" : s.status === "PENDING" ? "Proposed" : s.status;

          html += '<div class="brain-feed-item">';
          html += '<div class="brain-feed-item-icon ' + typeClass + '">' + (icons[typeClass] || "~") + '</div>';
          html += '<div class="brain-feed-item-content">';
          html += '<div class="brain-feed-item-text">' + esc(s.topic || s.summary || "") + '</div>';
          html += '<div class="brain-feed-item-meta">' + esc(s.source_type || "unknown") + ' / ' + statusText + '</div>';
          html += '</div></div>';
        }

        container.innerHTML = html || '<div class="brain-empty-state"><p>No feed items yet. Use the input above to feed the brain intel.</p></div>';
      } catch {
        container.innerHTML = '<div class="brain-empty-state"><p>Could not load feed history.</p></div>';
      }
    }

    // ── Insights ──────────────────────────────────────────────
    async function loadInsights() {
      const container = $("#brain-insights-container");
      if (!container) return;

      try {
        const data = await brainFetch("/analyst/insights");
        const insights = data || [];

        if (insights.length === 0) {
          container.innerHTML = '<div class="brain-empty-state"><p>No insights yet. Insights appear after recording outcomes and analyzing patterns.</p></div>';
          return;
        }

        let html = "";
        for (const ins of insights.slice(0, 5)) {
          const conf = (ins.confidence || "MEDIUM").toLowerCase();
          const confDotClass = conf === "verified" ? "verified" : conf === "consistent" ? "verified" : "estimated";

          html += '<div class="brain-insight-card">';
          html += '<div class="brain-insight-header">';
          html += '<span class="brain-insight-icon">%</span>';
          html += '<div class="brain-insight-claim"><strong>' + esc(ins.pattern || "") + '</strong></div>';
          html += '</div>';

          if (ins.impact_estimate) {
            html += '<div class="brain-insight-evidence">';
            html += '<div class="brain-insight-evidence-label">Data</div>';
            html += '<div class="brain-insight-evidence-row">';
            html += '<span class="brain-insight-evidence-stat">' + esc(ins.impact_estimate) + '</span>';
            html += '</div>';
            html += '<div class="brain-insight-confidence">';
            html += '<span class="brain-insight-confidence-dot ' + confDotClass + '"></span>';
            html += '<span class="brain-insight-confidence-label">' + (ins.confidence || "MEDIUM") + '</span>';
            html += '</div></div>';
          }

          html += '</div>';
        }

        container.innerHTML = html;
      } catch {
        container.innerHTML = '<div class="brain-empty-state"><p>Could not load insights.</p></div>';
      }
    }

    // ── Consult ───────────────────────────────────────────────
    let consultLoading = false;

    function setupConsult() {
      $("#brain-consult-form").addEventListener("submit", async (e) => {
        e.preventDefault();
        const query = $("#brain-consult-input").value.trim();
        if (!query || consultLoading) return;
        await submitConsult(query);
      });

      $$(".brain-suggestion").forEach(s => {
        s.addEventListener("click", () => {
          const query = s.dataset.query;
          if (query) {
            $("#brain-consult-input").value = query;
            submitConsult(query);
          }
        });
      });
    }

    async function submitConsult(query) {
      consultLoading = true;
      $("#brain-consult-loading").classList.remove("hidden");
      $("#brain-consult-result").classList.add("hidden");
      $("#brain-consult-error").classList.add("hidden");

      try {
        const data = await brainFetch("/reason", {
          method: "POST",
          body: JSON.stringify({ query: query })
        });

        renderConsultResult(data);
        $("#brain-consult-result").classList.remove("hidden");
      } catch (e) {
        $("#brain-consult-error-text").textContent = e.message;
        $("#brain-consult-error").classList.remove("hidden");
      } finally {
        consultLoading = false;
        $("#brain-consult-loading").classList.add("hidden");
      }
    }

    function renderConsultResult(data) {
      $("#brain-consult-position").textContent = data.position || "No position.";
      $("#brain-consult-reasoning").textContent = data.reasoning || "No reasoning.";

      if (data.consequence_chain) {
        renderConsultChain(data.consequence_chain);
        $("#brain-consult-chain-section").classList.remove("hidden");
      } else {
        $("#brain-consult-chain-section").classList.add("hidden");
      }

      if (data.gaps?.length > 0) {
        renderConsultGaps(data.gaps);
        $("#brain-consult-gaps-section").classList.remove("hidden");
      } else {
        $("#brain-consult-gaps-section").classList.add("hidden");
      }

      const conf = (data.confidence || "MEDIUM").toLowerCase();
      $("#brain-consult-confidence").textContent = data.confidence || "MEDIUM";
      $("#brain-consult-confidence").className = "brain-confidence " + conf;
      $("#brain-consult-sources").textContent = data.sources?.length > 0 ? data.sources.length + " source" + (data.sources.length > 1 ? "s" : "") + " cited" : "No sources";
      $("#brain-consult-model").textContent = data.model_used || "";
    }

    function renderConsultChain(chain) {
      const levels = [{ key: "action", label: "Action" }, { key: "direct", label: "Direct" }, { key: "secondary", label: "Secondary" }, { key: "strategic", label: "Strategic" }];
      let html = "";
      for (let i = 0; i < levels.length; i++) {
        const { key, label } = levels[i];
        const node = chain[key];
        if (!node) continue;
        const conf = (node.confidence || "MEDIUM").toLowerCase();
        html += '<div class="brain-chain-node"><div class="brain-chain-connector"><span class="brain-chain-level">' + label + '</span>' + (i < levels.length - 1 ? '<span class="brain-chain-arrow">&darr;</span>' : '') + '</div><span class="brain-chain-claim">' + esc(node.claim) + '</span><span class="brain-chain-confidence ' + conf + '">' + node.confidence + '</span></div>';
      }
      $("#brain-consult-chain").innerHTML = html;
    }

    function renderConsultGaps(gaps) {
      const icons = { human: "\u26A0", researchable: "\u25CE", testable: "\u25C8" };
      let html = "";
      for (const g of gaps) {
        const cat = (g.category || "HUMAN").toLowerCase();
        html += '<div class="brain-gap-item"><span class="brain-gap-icon ' + cat + '">' + (icons[cat] || "\u2022") + '</span><div class="brain-gap-content"><div class="brain-gap-question">' + esc(g.question || g) + '</div>';
        if (g.impact) html += '<div class="brain-gap-impact">' + esc(g.impact) + '</div>';
        html += '</div></div>';
      }
      $("#brain-consult-gaps").innerHTML = html;
    }

    // ── Strategy ──────────────────────────────────────────────
    async function loadStrategy() {
      try {
        const data = await brainFetch("/strategy/current");
        if (!data || !data.positioning) {
          $("#brain-strategy-positioning").textContent = "No strategy yet. Generate one in Settings.";
          return;
        }

        $("#brain-strategy-version").textContent = "v" + (data.version || 1) + ", " + (data.status || "active").toLowerCase();
        $("#brain-strategy-positioning").textContent = data.positioning || "—";
        $("#brain-strategy-audience").textContent = data.target_audience || "—";

        const pillars = data.content_pillars || [];
        $("#brain-strategy-pillars").innerHTML = pillars.map(p => '<span class="brain-tag">' + esc(p) + '</span>').join("") || "—";

        const levers = data.growth_levers || [];
        $("#brain-strategy-levers").innerHTML = levers.map(l => '<span class="brain-tag">' + esc(l) + '</span>').join("") || "—";
      } catch {
        $("#brain-strategy-positioning").textContent = "Could not load strategy.";
      }
    }

    // ── Scout Signals ─────────────────────────────────────────
    async function loadScoutSignals() {
      const container = $("#brain-signals-container");
      if (!container) return;

      try {
        const data = await brainFetch("/scout/signals");
        const signals = data.signals || [];
        const pending = signals.filter(s => s.status === "PENDING");
        $("#brain-signal-count").textContent = signals.length + " active";

        if (signals.length === 0) {
          container.innerHTML = '<div class="brain-empty-state"><p>No scout signals yet. Signals appear when the brain detects market intelligence.</p></div>';
          return;
        }

        let html = "";
        for (const s of signals) {
          const statusClass = s.status.toLowerCase();
          html += '<div class="brain-signal">';
          html += '<div class="brain-signal-status ' + statusClass + '"></div>';
          html += '<div class="brain-signal-content">';
          html += '<div class="brain-signal-topic">' + esc(s.topic) + '</div>';
          html += '<div class="brain-signal-summary">' + esc(s.summary) + '</div>';
          if (s.status === "PENDING") {
            html += '<div class="brain-signal-actions">';
            html += '<button class="btn-primary brain-signal-btn" onclick="window._brainApproveSignal(\'' + s.id + '\')">Approve</button>';
            html += '<button class="btn-ghost brain-signal-btn" onclick="window._brainDismissSignal(\'' + s.id + '\')">Dismiss</button>';
            html += '</div>';
          } else {
            html += '<div class="brain-signal-actions"><span class="brain-signal-status-label">Confirmed by Ryan</span></div>';
          }
          html += '</div></div>';
        }

        container.innerHTML = html;
      } catch {
        container.innerHTML = '<div class="brain-empty-state"><p>Could not load signals.</p></div>';
      }
    }

    window._brainApproveSignal = async function(id) {
      try {
        await brainFetch("/scout/signals/" + id + "/approve", { method: "POST" });
        loadScoutSignals();
        loadStats();
        showFlash("Signal confirmed.");
