---
// HK Off-Ice Program — EN (dark theme)
import MarketingLayout from "../../layouts/MarketingLayout.astro";
---

<MarketingLayout title="HK Off-Ice Program" description="10-week summer hockey training program in Hong Kong. Gym, shooting, skating, and mental skills. June 8 to August 16, 2026.">

  <section class="mpg-hero">
    <div class="mpg-container">
      <p class="mpg-hero__eyebrow">Summer 2026</p>
      <h1 class="mpg-hero__title">HK Off-Ice <span class="accent">Program</span></h1>
      <p class="mpg-hero__lead">10-week summer training program in Hong Kong. Partnership with EJ Elite Shooting.</p>
      <a href="mailto:riseadvancements@gmail.com?subject=HK Program - Sign Up" class="hp-btn-primary"><span>Sign Up</span></a>
    </div>
  </section>

  <div class="hp-divider"><div class="hp-divider__puck"></div></div>

  <section class="mpg-section mpg-surface">
    <div class="mpg-container">
      <div class="mpg-header-center">
        <div class="mpg-label">Details</div>
        <h2 class="mpg-heading">The Details</h2>
        <p class="mpg-subtitle">June 8 to August 16, 2026. 10 weeks.</p>
      </div>
      <div class="mpg-cards">
        <div class="mpg-card"><h3>ONYX Gym</h3><p>Taikoo Place, Quarry Bay. Strength and conditioning.</p></div>
        <div class="mpg-card"><h3>The Flying Puck</h3><p>Off-ice shooting. Technique, accuracy, release.</p></div>
        <div class="mpg-card"><h3>Quarry Bay Park</h3><p>Outdoor training. Cardio, agility, bodyweight.</p></div>
        <div class="mpg-card"><h3>Discovery Bay Ice Rink / Lohas Park</h3><p>On-ice sessions when available.</p></div>
      </div>
    </div>
  </section>

  <div class="hp-divider"><div class="hp-divider__puck"></div></div>

  <section class="mpg-section">
    <div class="mpg-container mpg-container--narrow">
      <div class="mpg-header-center">
        <h2 class="mpg-heading">Preliminary Weekly Schedule</h2>
      </div>
      <div class="mpg-schedule">
        <div class="mpg-schedule__day"><span class="mpg-schedule__label">Mon</span><span class="mpg-schedule__activity">2.5km run + Gym</span></div>
        <div class="mpg-schedule__day"><span class="mpg-schedule__label">Tue</span><span class="mpg-schedule__activity">3km bike + Game day</span></div>
        <div class="mpg-schedule__day"><span class="mpg-schedule__label">Wed</span><span class="mpg-schedule__activity">Gym + Off-ice shooting</span></div>
        <div class="mpg-schedule__day"><span class="mpg-schedule__label">Thu</span><span class="mpg-schedule__activity">2.5km run + Gym</span></div>
        <div class="mpg-schedule__day"><span class="mpg-schedule__label">Fri</span><span class="mpg-schedule__activity">Gym</span></div>
        <div class="mpg-schedule__day"><span class="mpg-schedule__label">Sat</span><span class="mpg-schedule__activity">Gym + On-ice</span></div>
        <div class="mpg-schedule__day"><span class="mpg-schedule__label">Sun</span><span class="mpg-schedule__activity">Park + Off-ice shooting</span></div>
      </div>
    </div>
  </section>

  <div class="hp-divider"><div class="hp-divider__puck"></div></div>

  <section class="mpg-section">
    <div class="mpg-container mpg-container--narrow">
      <div class="mpg-header-center">
        <h2 class="mpg-heading">Questions</h2>
      </div>
      <div class="mpg-faq__list">
        <div class="mpg-faq-item"><h3>What age group?</h3><p>12-16. Customized by age.</p></div>
        <div class="mpg-faq-item"><h3>Do I need my own equipment?</h3><p>Custom merch included. Bring your own gear for on-ice.</p></div>
        <div class="mpg-faq-item"><h3>Can parents watch?</h3><p>WhatsApp group with daily updates. Park sessions open.</p></div>
      </div>
    </div>
  </section>

  <nav class="mpg-service-nav">
    <a href="/services/the-move">The Move</a>
    <a href="/services/mentoring">Mentoring</a>
    <a href="/services/hk-program" class="active">HK Program</a>
    <a href="/why-us">Why RISE</a>
  </nav>

  <section class="mpg-cta">
    <div class="mpg-container" style="text-align: center;">
      <h2>Summer 2026. Spots are limited.</h2>
      <div class="mpg-cta__buttons">
        <a href="mailto:riseadvancements@gmail.com?subject=HK Program - Sign Up" class="hp-btn-white">Email Us</a>
        <a href="https://wa.me/85290950387" class="hp-btn-ghost">WhatsApp</a>
      </div>
    </div>
  </section>

</MarketingLayout>
