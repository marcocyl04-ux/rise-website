---
// The Move — EN (dark theme)
import MarketingLayout from "../../layouts/MarketingLayout.astro";
---

<MarketingLayout title="The Move" description="Full player placement and transition service from Hong Kong to Canada. Assessment, team placement, and ongoing support for young hockey players.">

  <section class="mpg-hero">
    <div class="mpg-container">
      <p class="mpg-hero__eyebrow">Service</p>
      <h1 class="mpg-hero__title">The <span class="accent">Move</span></h1>
      <p class="mpg-hero__lead">Making a move to a new team or city is one of the biggest decisions in a young player's career. Rise Advancement manages the entire process, from initial assessment to first skate with your new team, so nothing falls through the cracks.</p>
      <a href="mailto:riseadvancements@gmail.com?subject=The Move - Inquiry" class="hp-btn-primary"><span>Get Started</span></a>
    </div>
  </section>

  <div class="hp-divider"><div class="hp-divider__puck"></div></div>

  <section class="mpg-section mpg-surface">
    <div class="mpg-container">
      <div class="mpg-header-center">
        <div class="mpg-label">Process</div>
        <h2 class="mpg-heading">How It Works</h2>
        <p class="mpg-subtitle">Two steps from assessment to placement.</p>
      </div>
      <div class="mpg-steps">
        <div class="mpg-step">
          <div class="mpg-step__number">1</div>
          <h3>Initial Assessment</h3>
          <p>We review your game footage, evaluate your skill level, and sit down with you and your family to understand your goals. Our team determines the right level of play and presents a clear recommendation.</p>
        </div>
        <div class="mpg-step">
          <div class="mpg-step__number">2</div>
          <h3>Team Placement</h3>
          <p>We work our network to identify coaches and teams at the right level, create exposure opportunities, and guide every conversation between your family and coaching staff.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="hp-divider"><div class="hp-divider__puck"></div></div>

  <section class="mpg-section">
    <div class="mpg-container">
      <div class="mpg-header-center">
        <h2 class="mpg-heading">What's Included</h2>
      </div>
      <div class="mpg-checklist">
        <div class="mpg-checklist__item"><span class="mpg-checklist__check">&#10003;</span><span>Thorough evaluation of game footage and skill level</span></div>
        <div class="mpg-checklist__item"><span class="mpg-checklist__check">&#10003;</span><span>Identification of coaches and teams suited to your goals</span></div>
        <div class="mpg-checklist__item"><span class="mpg-checklist__check">&#10003;</span><span>Facilitation of introductions with coaching staff</span></div>
        <div class="mpg-checklist__item"><span class="mpg-checklist__check">&#10003;</span><span>Exposure opportunities at the right level of play</span></div>
        <div class="mpg-checklist__item"><span class="mpg-checklist__check">&#10003;</span><span>Guidance and support at every step of the process</span></div>
      </div>
    </div>
  </section>

  <div class="hp-divider"><div class="hp-divider__puck"></div></div>

  <section class="mpg-section mpg-surface">
    <div class="mpg-container mpg-container--narrow mpg-honest">
      <h2>Our Commitment</h2>
      <p>Rise Advancement's obligation is fulfilled once the player is on the ice with their new team and enrolled in their new school. No hidden steps. Just results.</p>
    </div>
  </section>

  <div class="hp-divider"><div class="hp-divider__puck"></div></div>

  <section class="mpg-section">
    <div class="mpg-container mpg-container--narrow">
      <div class="mpg-header-center">
        <h2 class="mpg-heading">Questions</h2>
      </div>
      <div class="mpg-faq__list">
        <div class="mpg-faq-item">
          <h3>What if you don't find a team?</h3>
          <p>We don't guarantee placement. We'll be honest about your kid's readiness and options from the start.</p>
        </div>
        <div class="mpg-faq-item">
          <h3>What level will my kid play at?</h3>
          <p>Depends on skill, age, and readiness. We evaluate and determine the right level.</p>
        </div>
        <div class="mpg-faq-item">
          <h3>How long does it take?</h3>
          <p>Most placements happen before September. Reach out early.</p>
        </div>
        <div class="mpg-faq-item">
          <h3>Do you handle housing?</h3>
          <p>We help coordinate host families and school boarding programs.</p>
        </div>
      </div>
    </div>
  </section>

  <nav class="mpg-service-nav">
    <a href="/services/the-move" class="active">The Move</a>
    <a href="/services/mentoring">Mentoring</a>
    <a href="/services/hk-program">HK Program</a>
    <a href="/why-us">Why RISE</a>
  </nav>

  <section class="mpg-cta">
    <div class="mpg-container" style="text-align: center;">
      <h2>Ready to explore The Move?</h2>
      <div class="mpg-cta__buttons">
        <a href="mailto:riseadvancements@gmail.com?subject=The Move - Inquiry" class="hp-btn-white">Email Us</a>
        <a href="https://wa.me/85290950387" class="hp-btn-ghost">WhatsApp</a>
      </div>
    </div>
  </section>

</MarketingLayout>
