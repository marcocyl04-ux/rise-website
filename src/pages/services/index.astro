---
// Services overview — EN (dark theme)
import MarketingLayout from "../../layouts/MarketingLayout.astro";
---

<MarketingLayout title="Services" description="RISE Advancement services: player placement to Canada, season-long mentoring, and summer training in Hong Kong.">

  <section class="mpg-hero">
    <div class="mpg-container">
      <p class="mpg-hero__eyebrow">What We Offer</p>
      <h1 class="mpg-hero__title">Our <span class="accent">Services</span></h1>
      <p class="mpg-hero__lead">Three ways we help your kid reach the next level. From full placement to Canada, to season-long development, to off-season training in Hong Kong.</p>
    </div>
  </section>

  <div class="hp-divider"><div class="hp-divider__puck"></div></div>

  <section class="mpg-section">
    <div class="mpg-container">
      <div class="mpg-cards mpg-cards--3">

        <div class="mpg-card">
          <h3>The Move</h3>
          <p style="color: var(--rise-red); font-family: var(--font-heading); font-weight: 600; font-size: 1.1rem; margin-bottom: 1rem;">Contact us</p>
          <p>Full player placement and transition service to Canada. We evaluate, place, and support your kid's move.</p>
          <ul class="hp-service__features" style="margin-top: 1rem;">
            <li>Game footage evaluation</li>
            <li>Level determination (AA/AAA/Elite)</li>
            <li>Team and school placement</li>
            <li>VISA and GTHL transfer support</li>
            <li>Post-move wrap-up</li>
          </ul>
          <a href="/services/the-move" class="hp-service__link" style="margin-top: 1rem;">
            Explore The Move
            <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>

        <div class="mpg-card">
          <h3>Mentoring</h3>
          <p style="color: var(--rise-red); font-family: var(--font-heading); font-weight: 600; font-size: 1.1rem; margin-bottom: 1rem;">Contact us</p>
          <p>Season-long development program. Choose the services your kid needs. Video review, skill skates, nutrition, mental skills.</p>
          <ul class="hp-service__features" style="margin-top: 1rem;">
            <li>Onboarding + weekly check-ins</li>
            <li>Video review sessions</li>
            <li>Skill skates</li>
            <li>Exercise and nutrition plans</li>
            <li>Mental skills coaching</li>
          </ul>
          <a href="/services/mentoring" class="hp-service__link" style="margin-top: 1rem;">
            Explore Mentoring
            <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>

        <div class="mpg-card">
          <h3>HK Off-Ice Program</h3>
          <p style="color: var(--rise-red); font-family: var(--font-heading); font-weight: 600; font-size: 1.1rem; margin-bottom: 1rem;">Summer 2026</p>
          <p>10-week summer training program in Hong Kong. Partnership with EJ Elite Shooting.</p>
          <ul class="hp-service__features" style="margin-top: 1rem;">
            <li>June 8 to August 16</li>
            <li>ONYX Gym, Taikoo Place</li>
            <li>The Flying Puck shooting sessions</li>
            <li>Quarry Bay Park training</li>
            <li>Discovery Bay Ice Rink</li>
            <li>Custom merch included</li>
          </ul>
          <a href="/services/hk-program" class="hp-service__link" style="margin-top: 1rem;">
            Explore HK Program
            <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <div class="hp-divider"><div class="hp-divider__puck"></div></div>

  <section class="mpg-cta" id="contact">
    <div class="mpg-container" style="text-align: center;">
      <h2>Ready to talk?</h2>
      <p>No commitment. Just a conversation about your kid's hockey future.</p>
      <div class="mpg-cta__buttons">
        <a href="mailto:riseadvancements@gmail.com?subject=RISE Inquiry" class="hp-btn-white">Email Us</a>
        <a href="https://wa.me/85290950387" class="hp-btn-ghost">WhatsApp</a>
      </div>
    </div>
  </section>

</MarketingLayout>
