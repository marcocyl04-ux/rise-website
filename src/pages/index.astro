  <!-- ====== PAGE SCRIPTS ====== -->
  <script>
    (function () {
      var isMobile = /Android|iPhone|iPad|iPod|webOS|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent) || window.innerWidth < 768;

      // ——— GSAP SETUP ———
      gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);
      ScrollTrigger.config({ limitCallbacks: true });

      // Native scroll — Lenis removed for performance

      // ——— HERO (the cinematic entrance) ———
      var heroTl = gsap.timeline({ delay: 0.3 });

      // Title chars: split into individual characters for stagger
      document.querySelectorAll('.hp-hero__title .line-inner').forEach(function(el) {
        var text = el.textContent;
        el.innerHTML = '';
        for (var i = 0; i < text.length; i++) {
          var span = document.createElement('span');
          span.className = 'hp-title-char';
          span.textContent = text[i] === ' ' ? '\u00A0' : text[i];
          span.style.display = 'inline-block';
          span.style.opacity = '0';
          span.style.transform = 'translateY(80px) rotateX(40deg)';
          el.appendChild(span);
        }
      });

      heroTl
        .set('.hp-hero__title .line-inner', { y: 0 }) // reset parent
        .to('.hp-hero__eyebrow span', { y: 0, opacity: 1, duration: 0.6, ease: 'power3.out' })
        .to('.hp-title-char', { opacity: 1, y: 0, rotateX: 0, duration: 0.5, stagger: 0.035, ease: 'power3.out' }, '-=0.3')
        .to('.hp-hero__subtitle span', { y: 0, duration: 0.7, ease: 'power3.out' }, '-=0.2')
        .to('.hp-hero__actions', { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, '-=0.3')
        .to('.hp-hero__scroll', { opacity: 1, duration: 0.5 }, '-=0.2');

      // ——— SCROLL REVEALS (IntersectionObserver, no GSAP overhead) ———
      var revealObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08 });
      document.querySelectorAll('[data-reveal]').forEach(function(el) {
        revealObserver.observe(el);
      });

      // ——— ENHANCED HOCKEY RINK (full-page scroll-driven) ———
      (function() {
        var canvas = document.getElementById('hero-canvas');
        if (!canvas) return;
        var renderer = new THREE.WebGLRenderer({ canvas: canvas, antialias: true, alpha: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setClearColor(0x060608, 1);
        renderer.fog = new THREE.FogExp2(0x060608, 0.03);

        var scene = new THREE.Scene();
        scene.fog = renderer.fog;
        var camera = new THREE.PerspectiveCamera(55, window.innerWidth / window.innerHeight, 0.1, 100);
        camera.position.set(0, 3.5, 10);
        camera.lookAt(0, 0, -2);

        var mouse = { x: 0, y: 0 };
        var scrollNorm = 0; // 0 = top, 1 = bottom of page
        var smoothScroll = 0; // smoothed version

        // ICE SURFACE
        var iceMat = new THREE.MeshPhongMaterial({ color: 0x0a0e14, specular: 0x1a2030, shininess: 80, transparent: true, opacity: 0.85, side: THREE.DoubleSide });
        var ice = new THREE.Mesh(new THREE.PlaneGeometry(32, 22), iceMat);
        ice.rotation.x = -Math.PI / 2; ice.position.y = -0.01;
        scene.add(ice);

        // LIGHTING
        scene.add(new THREE.AmbientLight(0x222233, 0.6));
        var dirLight = new THREE.DirectionalLight(0x4488cc, 0.3);
        dirLight.position.set(2, 8, 5); scene.add(dirLight);
        var redPoint = new THREE.PointLight(0xD3191F, 0.4, 20);
        redPoint.position.set(0, 2, 0); scene.add(redPoint);
        var rimLight = new THREE.PointLight(0x4488cc, 0.2, 25);
        rimLight.position.set(-8, 4, -5); scene.add(rimLight);

        // RINK HELPERS
        var lineMat = function(c, o) { return new THREE.LineBasicMaterial({ color: c, transparent: true, opacity: o }); };
        function makeLine(pts, mat) { var g = new THREE.BufferGeometry().setFromPoints(pts); return new THREE.Line(g, mat); }
        function makeDashedLine(pts, c, o, dash, gap) {
          var g = new THREE.BufferGeometry().setFromPoints(pts);
          var l = new THREE.LineDashedMaterial({ color: c, transparent: true, opacity: o, dashSize: dash || 0.3, gapSize: gap || 0.2 });
          var line = new THREE.Line(g, l); line.computeLineDistances(); return line;
        }
        var Y = 0.01;
        var bx = 13, bz = 8.5;

        // BOARDS
        var boardMat = new THREE.LineBasicMaterial({ color: 0x334455, transparent: true, opacity: 0.5 });
        scene.add(makeLine([new THREE.Vector3(-bx,Y,-bz), new THREE.Vector3(bx,Y,-bz)], boardMat));
        scene.add(makeLine([new THREE.Vector3(bx,Y,-bz), new THREE.Vector3(bx,Y,bz)], boardMat));
        scene.add(makeLine([new THREE.Vector3(bx,Y,bz), new THREE.Vector3(-bx,Y,bz)], boardMat));
        scene.add(makeLine([new THREE.Vector3(-bx,Y,bz), new THREE.Vector3(-bx,Y,-bz)], boardMat));
        var wallMat = new THREE.MeshPhongMaterial({ color: 0x111520, transparent: true, opacity: 0.4, emissive: 0xD3191F, emissiveIntensity: 0.03 });
        var wallH = 0.6;
        [[bx*2,0.08,0,wallH/2,-bz],[bx*2,0.08,0,wallH/2,bz],[0.08,bz*2,-bx,wallH/2,0],[0.08,bz*2,bx,wallH/2,0]].forEach(function(d) {
          var m = new THREE.Mesh(new THREE.BoxGeometry(d[0],wallH,d[1]), wallMat);
          m.position.set(d[2],d[3],d[4]); scene.add(m);
        });

        // CENTER LINE + BLUE LINES
        scene.add(makeLine([new THREE.Vector3(0,Y,-bz), new THREE.Vector3(0,Y,bz)], lineMat(0xD3191F, 0.2)));
        scene.add(makeLine([new THREE.Vector3(-6,Y,-bz), new THREE.Vector3(-6,Y,bz)], lineMat(0x4488cc, 0.15)));
        scene.add(makeLine([new THREE.Vector3(6,Y,-bz), new THREE.Vector3(6,Y,bz)], lineMat(0x4488cc, 0.15)));

        // CIRCLES + DOTS
        function makeCircle(cx, cz, r, seg, c, o) {
          var pts = []; for (var i = 0; i <= seg; i++) { var a = (i/seg)*Math.PI*2; pts.push(new THREE.Vector3(cx+Math.cos(a)*r, Y, cz+Math.sin(a)*r)); }
          return makeDashedLine(pts, c, o, 0.3, 0.2);
        }
        scene.add(makeCircle(0,0,3,64,0xD3191F,0.12));
        scene.add(makeCircle(-8,0,2,48,0x4488cc,0.08));
        scene.add(makeCircle(8,0,2,48,0x4488cc,0.08));
        var dotGeo = new THREE.CircleGeometry(0.2, 16);
        var dotMatS = new THREE.MeshBasicMaterial({ color: 0xD3191F, transparent: true, opacity: 0.2 });
        [[-8,-5],[-8,5],[8,-5],[8,5],[0,0]].forEach(function(p) {
          var d = new THREE.Mesh(dotGeo, dotMatS); d.rotation.x = -Math.PI/2; d.position.set(p[0], Y+0.005, p[1]); scene.add(d);
        });

        // GOAL CREASES
        function makeCrease(x) {
          var pts = []; for (var i = 0; i <= 32; i++) { var a = (i/32)*Math.PI; pts.push(new THREE.Vector3(x+Math.cos(a)*1.2, Y, Math.sin(a)*1.2)); }
          scene.add(makeDashedLine(pts, 0xD3191F, 0.1, 0.15, 0.1));
          scene.add(makeLine([new THREE.Vector3(x,Y,-1.5), new THREE.Vector3(x,Y,1.5)], lineMat(0xD3191F, 0.15)));
        }
        makeCrease(-11.5); makeCrease(11.5);

        // ICE PARTICLES
        var pCount = 400;
        var pPos = new Float32Array(pCount*3), pCol = new Float32Array(pCount*3), pVel = new Float32Array(pCount*3);
        var iceC = new THREE.Color(0xB8D4E3), redC = new THREE.Color(0xD3191F), whtC = new THREE.Color(0xE8E8E8);
        for (var i = 0; i < pCount; i++) {
          pPos[i*3] = (Math.random()-0.5)*24; pPos[i*3+1] = Math.random()*3+0.5; pPos[i*3+2] = (Math.random()-0.5)*16;
          pVel[i*3] = (Math.random()-0.5)*0.002; pVel[i*3+1] = (Math.random()-0.5)*0.001; pVel[i*3+2] = (Math.random()-0.5)*0.001;
          var r = Math.random(), c = r < 0.12 ? redC : r < 0.45 ? iceC : whtC;
          pCol[i*3] = c.r; pCol[i*3+1] = c.g; pCol[i*3+2] = c.b;
        }
        var pGeom = new THREE.BufferGeometry();
        pGeom.setAttribute('position', new THREE.BufferAttribute(pPos, 3));
        pGeom.setAttribute('color', new THREE.BufferAttribute(pCol, 3));
        scene.add(new THREE.Points(pGeom, new THREE.PointsMaterial({ size: 0.035, vertexColors: true, transparent: true, opacity: 0.5, sizeAttenuation: true })));

        // PUCKS
        var puckGeo = new THREE.CylinderGeometry(0.19, 0.19, 0.06, 16);
        var pucks = [];
        for (var i = 0; i < 3; i++) {
          var p = new THREE.Mesh(puckGeo, new THREE.MeshPhongMaterial({ color: 0x111111, specular: 0x333333, shininess: 40 }));
          p.position.set((Math.random()-0.5)*16, 0.03, (Math.random()-0.5)*10);
          p.userData = { vx: (Math.random()-0.5)*0.04, vz: (Math.random()-0.5)*0.04, vr: (Math.random()-0.5)*0.03 };
          scene.add(p); pucks.push(p);
        }

        // SKATE TRAIL PARTICLES
        var trailMax = 200, trailPos = new Float32Array(trailMax*3), trailCol = new Float32Array(trailMax*3), trailAlpha = new Float32Array(trailMax), trailIdx = 0;
        var trailGeom = new THREE.BufferGeometry();
        trailGeom.setAttribute('position', new THREE.BufferAttribute(trailPos, 3));
        trailGeom.setAttribute('color', new THREE.BufferAttribute(trailCol, 3));
        scene.add(new THREE.Points(trailGeom, new THREE.PointsMaterial({ size: 0.025, vertexColors: true, transparent: true, opacity: 0.35, sizeAttenuation: true })));

        function spawnTrail(x, z) {
          var idx = trailIdx % trailMax;
          trailPos[idx*3] = x+(Math.random()-0.5)*0.3; trailPos[idx*3+1] = 0.02+Math.random()*0.15; trailPos[idx*3+2] = z+(Math.random()-0.5)*0.3;
          var r = Math.random();
          if (r < 0.6) { trailCol[idx*3] = 0.9; trailCol[idx*3+1] = 0.92; trailCol[idx*3+2] = 0.95; }
          else if (r < 0.85) { trailCol[idx*3] = 0.72; trailCol[idx*3+1] = 0.83; trailCol[idx*3+2] = 0.9; }
          else { trailCol[idx*3] = 0.82; trailCol[idx*3+1] = 0.1; trailCol[idx*3+2] = 0.12; }
          trailAlpha[idx] = 1.0; trailIdx++;
        }

        // Camera keyframes: define camera position/lookAt per scroll zone
        // [scrollStart, scrollEnd, camPos, lookAt]
        var camKeyframes = [
          { s: 0,    e: 0.15, from: { px:0, py:3.5, pz:10, lx:0, ly:0, lz:-2 },    to: { px:0, py:5, pz:12, lx:0, ly:0, lz:-2 } },
          { s: 0.15, e: 0.35, from: { px:0, py:5, pz:12, lx:0, ly:0, lz:-2 },      to: { px:-4, py:6, pz:8, lx:2, ly:0, lz:0 } },
          { s: 0.35, e: 0.55, from: { px:-4, py:6, pz:8, lx:2, ly:0, lz:0 },       to: { px:3, py:4, pz:-6, lx:-2, ly:0, lz:2 } },
          { s: 0.55, e: 0.75, from: { px:3, py:4, pz:-6, lx:-2, ly:0, lz:2 },      to: { px:0, py:8, pz:0, lx:0, ly:0, lz:0 } },
          { s: 0.75, e: 1.0,  from: { px:0, py:8, pz:0, lx:0, ly:0, lz:0 },       to: { px:-2, py:3, pz:10, lx:2, ly:0, lz:-4 } }
        ];

        function lerp(a, b, t) { return a + (b - a) * t; }
        function smoothstep(t) { return t * t * (3 - 2 * t); }

        function getCameraPose(scroll) {
          for (var i = 0; i < camKeyframes.length; i++) {
            var kf = camKeyframes[i];
            if (scroll >= kf.s && scroll <= kf.e) {
              var t = smoothstep((scroll - kf.s) / (kf.e - kf.s));
              return {
                px: lerp(kf.from.px, kf.to.px, t),
                py: lerp(kf.from.py, kf.to.py, t),
                pz: lerp(kf.from.pz, kf.to.pz, t),
                lx: lerp(kf.from.lx, kf.to.lx, t),
                ly: lerp(kf.from.ly, kf.to.ly, t),
                lz: lerp(kf.from.lz, kf.to.lz, t)
              };
            }
          }
          var last = camKeyframes[camKeyframes.length - 1];
          return { px: last.to.px, py: last.to.py, pz: last.to.pz, lx: last.to.lx, ly: last.to.ly, lz: last.to.lz };
        }

        // RENDER LOOP
        function renderRink() {
          // Smooth scroll interpolation
          smoothScroll += (scrollNorm - smoothScroll) * 0.04;

          // Particles
          var pos = pGeom.attributes.position.array;
          for (var i = 0; i < pCount; i++) {
            pos[i*3] += pVel[i*3]; pos[i*3+1] += pVel[i*3+1]; pos[i*3+2] += pVel[i*3+2];
            if (pos[i*3+1] < 0.2) { pos[i*3+1] = 3.5; pos[i*3] = (Math.random()-0.5)*24; }
            if (pos[i*3+1] > 4) pos[i*3+1] = 0.2;
          }
          pGeom.attributes.position.needsUpdate = true;
          // Pucks
          pucks.forEach(function(p) {
            var d = p.userData;
            p.position.x += d.vx; p.position.z += d.vz; p.rotation.y += d.vr;
            var speed = Math.sqrt(d.vx*d.vx + d.vz*d.vz);
            if (speed > 0.01) spawnTrail(p.position.x, p.position.z);
            if (p.position.x > 12.5 || p.position.x < -12.5) { d.vx *= -0.85; p.position.x = Math.max(-12.5, Math.min(12.5, p.position.x)); }
            if (p.position.z > 8 || p.position.z < -8) { d.vz *= -0.85; p.position.z = Math.max(-8, Math.min(8, p.position.z)); }
            d.vx *= 0.998; d.vz *= 0.998; d.vr *= 0.995;
            if (Math.random() < 0.003) { d.vx += (Math.random()-0.5)*0.06; d.vz += (Math.random()-0.5)*0.06; d.vr += (Math.random()-0.5)*0.02; }
          });
          // Trail fade
          var tPos = trailGeom.attributes.position.array;
          for (var i = 0; i < trailMax; i++) { if (trailAlpha[i] > 0) { trailAlpha[i] -= 0.008; tPos[i*3+1] += 0.002; } }
          trailGeom.attributes.position.needsUpdate = true;

          // Camera from keyframes + mouse offset
          var pose = getCameraPose(smoothScroll);
          var mouseOffsetX = mouse.x * 2;
          var mouseOffsetY = mouse.y * 1;
          camera.position.x += (pose.px + mouseOffsetX - camera.position.x) * 0.03;
          camera.position.y += (pose.py - mouseOffsetY - camera.position.y) * 0.03;
          camera.position.z += (pose.pz - camera.position.z) * 0.03;
          camera.lookAt(pose.lx, pose.ly, pose.lz);

          // Red light intensity pulses with scroll
          redPoint.intensity = 0.4 + smoothScroll * 0.4;
          renderer.render(scene, camera);
        }
        gsap.ticker.add(renderRink);

        // Pause Three.js when scrolled past hero
        ScrollTrigger.create({
          trigger: '.hp-hero',
          start: 'top top',
          end: 'bottom top',
          onLeave: function() { gsap.ticker.remove(renderRink); },
          onEnterBack: function() { gsap.ticker.add(renderRink); }
        });

        // Mouse tracking
        window.addEventListener('mousemove', function(e) {
          mouse.x = ((e.clientX) / window.innerWidth) * 2 - 1;
          mouse.y = ((e.clientY) / window.innerHeight) * 2 - 1;
        });

        // Full-page scroll tracking
        window.addEventListener('scroll', function() {
          var docH = document.documentElement.scrollHeight - window.innerHeight;
          scrollNorm = docH > 0 ? Math.min(1, window.scrollY / docH) : 0;
        }, { passive: true });

        window.addEventListener('resize', function() {
          camera.aspect = window.innerWidth / window.innerHeight;
          camera.updateProjectionMatrix();
          renderer.setSize(window.innerWidth, window.innerHeight);
        });
      })();

      // ——— LOADER (smooth exit, no jank) ———
      var loaderEl = document.getElementById('loader');
      if (loaderEl) {
        gsap.timeline()
          .to('#loader-fill', { width: '100%', duration: 0.6, ease: 'power2.inOut' })
          .to(loaderEl, { autoAlpha: 0, duration: 0.5, ease: 'power2.inOut', delay: 0.1,
            onComplete: function() { loaderEl.style.display = 'none'; }
          }, 0.7);
      }

      // ——— NAV SCROLL ———
      ScrollTrigger.create({
        start: 80,
        onUpdate: function(self) {
          document.getElementById('hp-nav').classList.toggle('scrolled', self.progress > 0);
        }
      });

      // ——— PIPELINE STEPS (sequential, not simultaneous) ———
      gsap.utils.toArray('.hp-step').forEach(function(step, i) {
        var marker = step.querySelector('.hp-step__marker');
        gsap.from(step, {
          opacity: 0, y: 50, duration: 0.8, ease: 'power3.out', delay: i * 0.1, immediateRender: false,
          scrollTrigger: { trigger: '.hp-pipeline', start: 'top 80%', toggleActions: 'play none none none' }
        });
        ScrollTrigger.create({
          trigger: '.hp-pipeline',
          start: 'top 80%',
          onEnter: function() {
            gsap.to(marker, { borderColor: 'rgba(211,25,31,0.5)', boxShadow: '0 0 30px rgba(211,25,31,0.15)', duration: 0.5, delay: i * 0.1 });
          }
        });
      });

      // Pipeline line fill (scrub, smooth)
      ScrollTrigger.create({
        trigger: '.hp-pipeline',
        start: 'top 80%',
        end: 'bottom 30%',
        scrub: 0.5,
        onUpdate: function(self) {
          gsap.set('#pipeline-fill', { width: (self.progress * 100) + '%' });
        }
      });

      // ——— SERVICE ROWS (reveal only, NO parallax on rows) ———
      gsap.utils.toArray('.hp-service-row').forEach(function(row, i) {
        var content = row.querySelector('[data-service-content]');
        var visual = row.querySelector('.hp-service__visual');
        // Unified timeline per row — no fighting
        var tl = gsap.timeline({
          scrollTrigger: { trigger: row, start: 'top 85%', toggleActions: 'play none none none' }
        });
        if (visual) {
          tl.from(visual, { opacity: 0, x: -60, duration: 0.8, ease: 'power3.out' }, 0);
        }
        if (content) {
          tl.from(content, { opacity: 0, x: 60, duration: 0.8, ease: 'power3.out' }, 0.08);
        }
      });

      // ——— INTERLUDE (cinematic, slower) ———
      var interTl = gsap.timeline({
        scrollTrigger: { trigger: '.hp-interlude', start: 'top 80%', toggleActions: 'play none none none' }
      });
      interTl
        .from('.hp-interlude h2', { opacity: 0, y: 40, duration: 0.9, ease: 'power3.out' })
        .from('.hp-interlude p', { opacity: 0, y: 30, duration: 0.8, ease: 'power3.out' }, '-=0.5')
        .from('.hp-interlude .hp-btn-outline', { opacity: 0, y: 20, duration: 0.6, ease: 'power3.out' }, '-=0.4');

      // ——— PLAYER CARDS (dramatic, staggered) ———
      var cards = gsap.utils.toArray('[data-player]');
      gsap.from(cards, {
        opacity: 0, y: 60, scale: 0.92, duration: 0.9, ease: 'power3.out', stagger: 0.15, immediateRender: false,
        scrollTrigger: { trigger: '.hp-players__grid', start: 'top 80%', toggleActions: 'play none none none' }
      });

      

      // ——— STATS COUNTERS (elastic, dramatic) ———
      gsap.utils.toArray('[data-count]').forEach(function(el) {
        var target = parseInt(el.dataset.count);
        var obj = { val: 0 };
        ScrollTrigger.create({
          trigger: el,
          start: 'top 90%',
          once: true,
          onEnter: function() {
            gsap.to(obj, {
              val: target, duration: 1.5, ease: 'power2.out',
              onUpdate: function() {
                var v = Math.round(obj.val);
                el.textContent = target >= 100 ? v + '%' : v;
              }
            });
          }
        });
      });

      // ——— JOURNEY ARC ANIMATION (scrub, smooth) ———
      var arcFill = document.querySelector('.hp-journey__arc-fill');
      if (arcFill) {
        ScrollTrigger.create({
          trigger: '.hp-journey',
          start: 'top 70%',
          end: 'bottom 40%',
          scrub: 0.8,
          onUpdate: function(self) {
            gsap.set(arcFill, { strokeDashoffset: 1200 * (1 - self.progress) });
          }
        });
      }

      // Journey plane (scrub, smooth)
      var journeyPlane = document.querySelector('.hp-journey__plane');
      if (journeyPlane) {
        ScrollTrigger.create({
          trigger: '.hp-journey',
          start: 'top 70%',
          end: 'bottom 40%',
          scrub: 0.8,
          onUpdate: function(self) {
            var t = self.progress;
            var x = (1-t)*(1-t)*120 + 2*(1-t)*t*400 + t*t*680;
            var y = (1-t)*(1-t)*200 + 2*(1-t)*t*20 + t*t*180;
            var dx = 2*(1-t)*(400-120) + 2*t*(680-400);
            var dy = 2*(1-t)*(20-200) + 2*t*(180-20);
            var angle = Math.atan2(dy, dx) * (180/Math.PI);
            journeyPlane.setAttribute('transform', 'translate('+x+','+y+') rotate('+angle+')');
          }
        });
      }

      // ——— RINK DIVIDER ANIMATION ———
      gsap.utils.toArray('.hp-rink-divider__line').forEach(function(line) {
        gsap.from(line, {
          scaleX: 0, duration: 1.2, ease: 'power3.inOut', immediateRender: false,
          scrollTrigger: { trigger: line.parentElement, start: 'top 92%', toggleActions: 'play none none none' }
        });
      });

      // ——— CTA (cinematic, coordinated) ———
      var ctaTl = gsap.timeline({
        scrollTrigger: { trigger: '.hp-cta', start: 'top 80%', toggleActions: 'play none none none' }
      });
      ctaTl
        .from('.hp-cta__content h2', { opacity: 0, y: 30, duration: 0.8, ease: 'power3.out' })
        .from('.hp-cta__content p', { opacity: 0, y: 20, duration: 0.7, ease: 'power3.out' }, '-=0.4')
        .from('.hp-cta__buttons', { opacity: 0, y: 20, duration: 0.6, ease: 'power3.out' }, '-=0.3');

      // ——— FAQ ACCORDION ———
      document.querySelectorAll('.hp-faq-item__question').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var item = btn.closest('.hp-faq-item');
          var answer = item.querySelector('.hp-faq-item__answer');
          var isOpen = item.classList.contains('active');

          document.querySelectorAll('.hp-faq-item.active').forEach(function(activeItem) {
            activeItem.classList.remove('active');
            gsap.to(activeItem.querySelector('.hp-faq-item__answer'), { maxHeight: 0, duration: 0.35, ease: 'power2.inOut' });
          });

          if (!isOpen) {
            item.classList.add('active');
            answer.style.maxHeight = 'none';
            var h = answer.scrollHeight;
            answer.style.maxHeight = '0px';
            answer.offsetHeight;
            gsap.to(answer, { maxHeight: h, duration: 0.45, ease: 'power2.out' });
          }
        });
      });

      // ——— SMOOTH SCROLL NAV ———
      document.querySelectorAll('.hp-nav__links a[href^="#"]').forEach(function(a) {
        a.addEventListener('click', function(e) {
          e.preventDefault();
          var target = document.querySelector(a.getAttribute('href'));
          if (target) {
            window.scrollTo({ top: target.offsetTop - 80, behavior: 'smooth' });
          }
        });
      });

      // ——— ICE PARTICLES (CSS DOM) ———
      var iceParticlesEl = document.getElementById('ice-particles');
      if (iceParticlesEl && !isMobile) {
        for (var i = 0; i < 25; i++) {
          var dot = document.createElement('div');
          dot.className = 'hp-ice-dot';
          dot.style.left = Math.random() * 100 + '%';
          dot.style.top = Math.random() * 100 + '%';
          dot.style.animationDelay = Math.random() * 5 + 's';
          dot.style.animationDuration = (4 + Math.random() * 6) + 's';
          dot.style.width = dot.style.height = (1 + Math.random() * 2) + 'px';
          dot.style.opacity = (0.3 + Math.random() * 0.5).toString();
          iceParticlesEl.appendChild(dot);
        }
      }

      // ——— REDUCED MOTION ———
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        ScrollTrigger.getAll().forEach(function(st) { st.kill(); });
        gsap.globalTimeline.progress(1);
        document.querySelectorAll('.hp-service-row, [data-service-content], .hp-service__visual, .hp-player-card, .hp-step, .hp-hero__actions, .hp-hero__scroll, .hp-hero__eyebrow span, .hp-hero__title .line-inner, .hp-hero__subtitle span, .hp-interlude h2, .hp-interlude p, .hp-cta__content h2, .hp-cta__content p, .hp-cta__buttons').forEach(function(el) {
          el.style.opacity = '1';
          el.style.transform = 'none';
        });
        var loader = document.getElementById('loader');
        if (loader) loader.style.display = 'none';
      }
    })();
  </script>
</HomeLayout>
