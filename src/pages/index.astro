---
// Home page — EN (Phase 2: user flow restructure)
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SectionHeader from "../components/SectionHeader.astro";
import PlayerCard from "../components/PlayerCard.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ContactForm from "../components/ContactForm.astro";
---

<BaseLayout title="Home" description="RISE Advancement: elite hockey training and player placement for Hong Kong youth. Summer program, mentoring, and full placement services to Canada.">
  <Header slot="header" />

  <!-- JSON-LD Structured Data -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SportsActivityLocation",
    "name": "RISE Advancement",
    "description": "Elite hockey player development and placement agency. We get young players from Hong Kong onto teams in Canada.",
    "url": "https://riseadvancement.com",
    "email": "riseadvancements@gmail.com",
    "telephone": "+852-9095-0387",
    "areaServed": ["Hong Kong", "Canada"],
    "sport": "Ice Hockey",
    "offers": [
      {
        "@type": "Offer",
        "name": "The Move",
        "description": "Full player placement and transition service to Canada"
      },
      {
        "@type": "Offer",
        "name": "Mentoring",
        "description": "Season-long hockey development program with dedicated mentors"
      },
      {
        "@type": "Offer",
        "name": "HK Off-Ice Summer Program",
        "description": "10-week summer hockey training program in Hong Kong"
      }
    ]
  })} />

  <!-- 1. HERO — What is RISE + off-season program -->
  <section class="hero section">
    <div class="container">
      <div class="hero-content">
        <p class="hero-eyebrow">Hong Kong &bull; Canada</p>
        <h1 class="hero-title">
          RISE <span class="hero-title-red">Advancement</span>
        </h1>
        <p class="hero-lead">
          We get young hockey players from Hong Kong onto teams in Canada.
          We evaluate them, place them, and develop them through the season.
          Founded by players who lived the pipeline themselves.
        </p>
        <div class="hero-actions">
          <a href="/services/hk-program" class="btn-primary">Off-Season Program</a>
          <a href="#contact" class="btn-secondary">Talk to Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 1b. OFF-SEASON PROGRAM -->
  <section class="section" style="background-color: var(--rise-neutral-50);">
    <div class="container" style="max-width: 720px; text-align: center;">
      <h2 style="margin-bottom: var(--space-4);">Not just a program.</h2>
      <p style="font-size: var(--text-base); color: var(--rise-neutral-500); line-height: 1.7; margin-bottom: var(--space-6);">
        Our off-season program is 10 weeks of elite training in Hong Kong. Gym, shooting, skating, and mental skills. June 8 to August 16. It's also the first step into the RISE ecosystem, where players get evaluated, developed, and placed on teams in Canada.
      </p>
      <a href="/why-us" class="btn-secondary">Why RISE?</a>
    </div>
  </section>

  <!-- 2. HOW IT WORKS — How does it work? -->
  <section id="how-it-works" class="section" style="background-color: var(--rise-neutral-50);">
    <div class="container">
      <SectionHeader
        title="How It Works"
        subtitle="Four steps from Hong Kong to the ice in Canada."
      />
      <div class="steps-grid">
        <div class="step">
          <div class="step-number">1</div>
          <h3>We Evaluate</h3>
          <p>Game footage, skill assessment, level determination. We figure out where your kid fits: AA, AAA, or Elite.</p>
        </div>
        <div class="step">
          <div class="step-number">2</div>
          <h3>We Match</h3>
          <p>We find the right team and school. We know the coaches, the programs, and the levels across Canada.</p>
        </div>
        <div class="step">
          <div class="step-number">3</div>
          <h3>We Move</h3>
          <p>VISA, GTHL transfers, school enrollment, introductions. We handle the logistics so you don't have to.</p>
        </div>
        <div class="step">
          <div class="step-number">4</div>
          <h3>We Develop</h3>
          <p>Weekly check-ins, video review, skill skates, nutrition, mental skills. Your kid is never alone.</p>
        </div>
      </div>
    </div>
    <div class="mid-cta">
      <a href="#contact" class="btn-primary">Talk to Us</a>
    </div>
  </section>

  <!-- 3. SERVICES — What can you do for my kid? -->
  <section id="services" class="section">
    <div class="container">
      <SectionHeader
        title="Our Services"
        subtitle="Three ways we help. Each one designed for a different stage of the journey."
      />
      <div class="services-grid">
        <ServiceCard
          title="The Move"
          description="Full player placement and transition service. We manage the entire process, from initial assessment to first skate with your new team, so nothing falls through the cracks."
          price="Contact us"
          features={[
            "Thorough evaluation of game footage and skill level",
            "Identification of coaches and teams suited to your goals",
            "Facilitation of introductions with coaching staff",
            "Exposure opportunities at the right level of play",
            "Guidance and support at every step of the process",
          ]}
          ctaText="Learn More"
          ctaLink="/services/the-move"
        />
        <ServiceCard
          title="Mentoring"
          description="Season-long development program. You choose the services that fit your game and your goals. Every engagement starts with an onboarding session, goal-setting, and regular check-ins throughout."
          price="Contact us"
          features={[
            "Weekly check-ins with your dedicated mentor",
            "One-on-one video review sessions",
            "In-person skill skates with your Rise mentor",
            "Custom exercise and nutrition plans",
            "Mental skills coaching with a professional",
          ]}
          ctaText="Learn More"
          ctaLink="/services/mentoring"
        />
        <ServiceCard
          title="HK Off-Ice Program"
          description="10-week summer training program in Hong Kong. Partnership with EJ Elite Shooting. Gym, off-ice shooting, park training, on-ice sessions."
          price="Summer 2026"
          features={[
            "June 8 to August 16",
            "ONYX Gym, Taikoo Place",
            "The Flying Puck shooting sessions",
            "Quarry Bay Park training",
            "Discovery Bay Ice Rink",
            "Custom merch included",
          ]}
          ctaText="Learn More"
          ctaLink="/services/hk-program"
        />
      </div>
    </div>
  </section>

  <!-- 4. PLAYERS — Has it worked for others? -->
  <section id="players" class="section" style="background-color: var(--rise-neutral-50);">
    <div class="container">
      <SectionHeader
        title="Our Players"
        subtitle="Real kids. Real teams. Real progress."
      />
      <div class="players-grid">
        <PlayerCard
          number="#7"
          name="Wilshere Tung"
          position='Defenceman — "A" Alternate Captain'
          team="Toronto Red Wings"
        />
        <PlayerCard
          number="#12"
          name="Felix Lloren"
          position="Defenceman"
          team="Upper Canada College U15AAA"
        />
        <PlayerCard
          number="#29"
          name="Marcus Nuyen"
          position="Forward"
          team="HK RISE Elite"
        />
      </div>
    </div>
    <div class="mid-cta">
      <a href="#contact" class="btn-primary">Start Your Kid's Journey</a>
    </div>
  </section>

  <!-- 5. FAQ — What about my concerns? -->
  <section id="faq" class="section">
    <div class="container" style="max-width: 640px;">
      <SectionHeader
        title="Questions Parents Ask"
        subtitle="The honest answers."
      />
      <div class="faq-list">
        <div class="faq-item">
          <h3>What if my kid is homesick?</h3>
          <p>We check in weekly. Group chat with all three mentors. We treat every player like our own. Your kid is never alone in Canada.</p>
        </div>
        <div class="faq-item">
          <h3>What if the team isn't the right fit?</h3>
          <p>We evaluate before placement. We know the coaches. We've done this before. If something isn't working, we address it early.</p>
        </div>
        <div class="faq-item">
          <h3>Do you guarantee placement?</h3>
          <p>No. We guarantee effort. We don't make promises we can't keep. But we've placed players because we do the work.</p>
        </div>
        <div class="faq-item">
          <h3>How do I stay connected with my kid?</h3>
          <p>Weekly updates from us. Coach communication. WhatsApp group. You'll know what's happening every step of the way.</p>
        </div>
        <div class="faq-item">
          <h3>How much does it cost?</h3>
          <p>It depends on the service. <a href="/#contact">Contact us</a> for a conversation about your kid's needs and what makes sense.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. CONTACT — I'm ready to reach out -->
  <section id="contact" class="contact-section section" style="background-color: var(--rise-neutral-50);">
    <div class="container" style="max-width: 640px; text-align: center;">
      <SectionHeader
        title="Get In Touch"
        subtitle="No commitment. Just a conversation about your kid's hockey future."
      />
      <div class="contact-center">
        <div class="contact-person">
          <h3>Talk to Ryan</h3>
          <p>Co-founder, RISE Advancement. Former player, now coaching. He'll answer your questions honestly.</p>
        </div>
        <ContactForm />
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ========== HERO ========== */
  .hero {
    padding-top: var(--space-20);
    padding-bottom: var(--space-20);
  }

  .hero-content {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-eyebrow {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--rise-neutral-500);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: var(--space-4);
  }

  .hero-title {
    font-size: var(--text-5xl);
    margin-bottom: var(--space-6);
  }

  @media (max-width: 639px) {
    .hero-title {
      font-size: var(--text-3xl);
    }
  }

  .hero-title-red {
    color: var(--rise-red);
  }

  .hero-lead {
    font-size: var(--text-lg);
    color: var(--rise-neutral-500);
    margin-bottom: var(--space-8);
    max-width: none;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ========== BUTTONS ========== */
  .btn-primary,
  .btn-secondary {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: var(--space-3) var(--space-8);
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-primary {
    background-color: var(--rise-red);
    color: var(--rise-white);
  }

  .btn-primary:hover {
    background-color: var(--rise-red-dark);
    color: var(--rise-white);
    text-decoration: none;
  }

  .btn-secondary {
    background-color: transparent;
    color: var(--rise-black);
    border: 2px solid var(--rise-neutral-300);
  }

  .btn-secondary:hover {
    border-color: var(--rise-red);
    color: var(--rise-red);
    text-decoration: none;
  }

  /* ========== HOW IT WORKS ========== */
  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .steps-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .step {
    text-align: center;
    padding: var(--space-6);
  }

  .step-number {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--rise-red);
    margin-bottom: var(--space-3);
  }

  .step h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
  }

  .step p {
    font-size: var(--text-sm);
    color: var(--rise-neutral-500);
    line-height: 1.6;
  }

  /* ========== SERVICES ========== */
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .services-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ========== PLAYERS ========== */
  .players-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .players-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .players-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ========== FAQ ========== */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .faq-item h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }

  .faq-item p {
    font-size: var(--text-sm);
    color: var(--rise-neutral-500);
    line-height: 1.7;
  }

  .faq-item a {
    color: var(--rise-red);
    text-decoration: underline;
  }

  /* ========== CONTACT ========== */
  .contact-center {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    align-items: center;
  }

  .contact-person h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
  }

  .contact-person p {
    font-size: var(--text-sm);
    color: var(--rise-neutral-500);
    line-height: 1.6;
  }

  /* ========== MID-PAGE CTAs ========== */
  .mid-cta {
    text-align: center;
    margin-top: var(--space-8);
  }
</style>
