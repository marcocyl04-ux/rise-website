---
// 香港體能訓練計劃 — 中文 (dark theme)
import MarketingLayout from "../../../layouts/MarketingLayout.astro";
---

<MarketingLayout title="香港體能訓練計劃" lang="zh" description="為期10週的夏季訓練計劃。與 EJ Elite Shooting 合作。">

  <section class="mpg-hero">
    <div class="mpg-container">
      <p class="mpg-hero__eyebrow">2026 夏季</p>
      <h1 class="mpg-hero__title">香港體能<span class="accent">訓練計劃</span></h1>
      <p class="mpg-hero__lead">為期10週的夏季訓練計劃。與 EJ Elite Shooting 合作。</p>
      <a href="mailto:riseadvancements@gmail.com?subject=香港體能訓練 - 報名" class="hp-btn-primary"><span>報名參加</span></a>
    </div>
  </section>

  <div class="hp-divider"><div class="hp-divider__puck"></div></div>

  <section class="mpg-section mpg-surface">
    <div class="mpg-container">
      <div class="mpg-header-center">
        <div class="mpg-label">詳細資料</div>
        <h2 class="mpg-heading">詳細資料</h2>
        <p class="mpg-subtitle">6月8日至8月16日。10週。</p>
      </div>
      <div class="mpg-cards">
        <div class="mpg-card"><h3>ONYX 健身中心</h3><p>太古坊。冰球專項訓練。</p></div>
        <div class="mpg-card"><h3>The Flying Puck</h3><p>陸地射門訓練。</p></div>
        <div class="mpg-card"><h3>鰂魚涌公園</h3><p>戶外訓練。</p></div>
        <div class="mpg-card"><h3>愉景灣冰場/LOHAS Park</h3><p>冰上訓練。</p></div>
      </div>
    </div>
  </section>

  <div class="hp-divider"><div class="hp-divider__puck"></div></div>

  <section class="mpg-section">
    <div class="mpg-container mpg-container--narrow">
      <div class="mpg-header-center"><h2 class="mpg-heading">常見問題</h2></div>
      <div class="mpg-faq__list">
        <div class="mpg-faq-item"><h3>什麼年齡段？</h3><p>12至16歲。</p></div>
        <div class="mpg-faq-item"><h3>需要自備裝備嗎？</h3><p>包含定制裝備。</p></div>
      </div>
    </div>
  </section>

  <nav class="mpg-service-nav">
    <a href="/zh/services/the-move">球員安置</a>
    <a href="/zh/services/mentoring">訓練指導</a>
    <a href="/zh/services/hk-program" class="active">香港計劃</a>
    <a href="/zh/why-us">為什麼選擇我們</a>
  </nav>

  <section class="mpg-cta">
    <div class="mpg-container" style="text-align: center;">
      <h2>名額有限。</h2>
      <div class="mpg-cta__buttons">
        <a href="mailto:riseadvancements@gmail.com?subject=香港體能訓練 - 報名" class="hp-btn-white">發送電子郵件</a>
        <a href="https://wa.me/85290950387" class="hp-btn-ghost">WhatsApp</a>
      </div>
    </div>
  </section>

</MarketingLayout>
