---
// Home page — 中文 (aligned with EN May 13 2026)
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import PlayerCard from "../../components/PlayerCard.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import ContactForm from "../../components/ContactForm.astro";
---

<BaseLayout title="首頁" lang="zh-HK" description="RISE Advancement：精英冰球訓練和球員安置服務。暑期計劃、訓練指導、以及從香港到加拿大的完整安置服務。">
  <Header slot="header" lang="zh" />

  <!-- JSON-LD Structured Data -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SportsActivityLocation",
    "name": "RISE Advancement",
    "description": "精英冰球球員發展和安置機構。我們將年輕球員從香港帶到加拿大的球隊。",
    "url": "https://riseadvancement.com",
    "email": "riseadvancements@gmail.com",
    "telephone": "+852-9095-0387",
    "areaServed": ["Hong Kong", "Canada"],
    "sport": "Ice Hockey"
  })} />

  <!-- 1. HERO -->
  <section class="hero section">
    <div class="container">
      <div class="hero-content">
        <p class="hero-eyebrow">RISE Advancement</p>
        <h1 class="hero-title">
          冰球<span class="hero-title-red">發展與安置</span>
        </h1>
        <p class="hero-lead">
          我們將年輕冰球運動員送到加拿大的球隊。
          我們評估他們、安置他們、在整個賽季中培養他們。
          由親身經歷過這條管道的球員創立。
        </p>
        <div class="hero-actions">
          <a href="/zh/services/hk-program" class="btn-primary">休賽期計劃</a>
          <a href="#contact" class="btn-secondary">聯繫我們</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. HOW IT WORKS -->
  <section id="how-it-works" class="section" style="background-color: var(--rise-neutral-50);">
    <div class="container">
      <SectionHeader
        title="運作方式"
        subtitle="到加拿大的四個步驟。"
      />
      <div class="steps-grid">
        <div class="step">
          <div class="step-number">1</div>
          <h3>評估</h3>
          <p>比賽錄像、技能評估、水平確定。</p>
        </div>
        <div class="step">
          <div class="step-number">2</div>
          <h3>配對</h3>
          <p>我們找到合適的球隊和學校。我們了解加拿大的教練、課程和各個級別。</p>
        </div>
        <div class="step">
          <div class="step-number">3</div>
          <h3>搬遷</h3>
          <p>VISA、文件處理、後勤支援，確保一切順利。</p>
        </div>
        <div class="step">
          <div class="step-number">4</div>
          <h3>發展</h3>
          <p>每週跟進、比賽回顧、技術訓練、營養、心理技能。你的孩子絕不孤單。</p>
        </div>
      </div>
    </div>
    <div class="mid-cta">
      <a href="#contact" class="btn-primary">和我們聊聊</a>
    </div>
  </section>

  <!-- 3. SERVICES -->
  <section id="services" class="section">
    <div class="container">
      <SectionHeader
        title="我們的服務"
        subtitle="三種方式幫助你的孩子。每個服務針對旅程的不同階段。"
      />
      <div class="services-grid">
        <ServiceCard
          title="球員安置"
          description="全面的球員安置和過渡服務。我們管理整個過程，從初步評估到孩子在新球隊首次上場，確保每個環節都不出差錯。"
          price="請聯繫我們"
          features={[
            "深入評估比賽錄像和技術水平",
            "根據目標篩選合適的教練和球隊",
            "安排與教練團隊的介紹和會面",
            "在合適的競技水平提供曝光機會",
            "整個過程中的全程指導和支持",
          ]}
          ctaText="了解更多"
          ctaLink="/zh/services/the-move"
        />
        <ServiceCard
          title="訓練指導"
          description="賽季發展計劃。你根據自己的需要選擇服務。每項合作都從入門會議、目標設定和定期跟進開始。"
          price="請聯繫我們"
          features={[
            "每週與專屬導師跟進",
            "一對一比賽回顧課程",
            "導師指導的冰上訓練",
            "定制體能和營養計劃",
            "專業心理訓練指導",
          ]}
          ctaText="了解更多"
          ctaLink="/zh/services/mentoring"
        />
        <ServiceCard
          title="香港體能訓練計劃"
          description="為期10週的休賽期訓練計劃，在香港舉行。與 EJ Elite Shooting 合作。健身房、陸地射門、滑冰、心理訓練。"
          price="2026 夏季"
          features={[
            "6月8日至8月16日",
            "ONYX 健身中心，太古坊",
            "The Flying Puck 射門訓練",
            "鰂魚涌公園訓練",
            "愉景灣冰場/LOHAS Park",
            "包含定制裝備",
          ]}
          ctaText="了解更多"
          ctaLink="/zh/services/hk-program"
        />
      </div>
    </div>
  </section>

  <!-- 3b. OFF-SEASON PROGRAM -->
  <section class="section" style="background-color: var(--rise-neutral-50);">
    <div class="container" style="max-width: 720px; text-align: center;">
      <h2 style="margin-bottom: var(--space-4);">不只是一个计划。</h2>
      <p style="font-size: var(--text-base); color: var(--rise-neutral-500); line-height: 1.7; margin-bottom: var(--space-6);">
        我们的休赛期计划是10周的精英训练。健身房、射门、滑冰、心理训练。6月8日至8月16日。这也是进入RISE体系的第一步，球员在这里被评估、培养，并安置到加拿大的球队。
      </p>
      <a href="/zh/why-us" class="btn-secondary">為什麼選擇 RISE?</a>
    </div>
  </section>

  <!-- 4. PLAYERS -->
  <section id="players" class="section">
    <div class="container">
      <SectionHeader
        title="我們的運動員"
        subtitle="真實的孩子。真實的球隊。真實的進步。"
      />
      <div class="players-grid">
        <PlayerCard
          number="#7"
          name="Wilshere Tung"
          position="後衛"
          team="2012 Toronto Titans"
        />
        <PlayerCard
          number="#13"
          name="Felix Lloren"
          position="後衛"
          team="2011 Upper Canada College"
        />
        <PlayerCard
          number="#29"
          name="Marcus Nuyen"
          position="前鋒"
          team="St. George's U15 Prep"
        />
      </div>
    </div>
    <div class="mid-cta">
      <a href="#contact" class="btn-primary">開始孩子的旅程</a>
    </div>
  </section>

  <!-- 5. FAQ -->
  <section id="faq" class="section" style="background-color: var(--rise-neutral-50);">
    <div class="container" style="max-width: 640px;">
      <SectionHeader
        title="家長常問的問題"
        subtitle="坦白的回答。"
      />
      <div class="faq-list">
        <div class="faq-item">
          <h3>如果孩子想家怎麼辦？</h3>
          <p>我們每週跟進。與三位導師的群組聊天。我們把每位球員當作自己的孩子。你的孩子在加拿大絕不孤單。</p>
        </div>
        <div class="faq-item">
          <h3>如果球隊不合適怎麼辦？</h3>
          <p>我們在安置前就進行評估。我們了解教練。我們做過很多次了。如果有問題，我們會及早處理。</p>
        </div>
        <div class="faq-item">
          <h3>你們保證安置嗎？</h3>
          <p>不。我們保證努力。我們不做出無法兌現的承諾。但我們安置球員是因為我們做好工作。</p>
        </div>
        <div class="faq-item">
          <h3>我怎麼和孩子保持聯繫？</h3>
          <p>我們的每週更新。教練溝通。WhatsApp 群組。你會知道每一步的情況。</p>
        </div>
        <div class="faq-item">
          <h3>費用是多少？</h3>
          <p>這取決於服務。<a href="/zh/#contact">聯繫我們</a>聊聊孩子的需求和適合的方案。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. CONTACT -->
  <section id="contact" class="contact-section section">
    <div class="container" style="max-width: 640px; text-align: center;">
      <SectionHeader
        title="聯繫我們"
        subtitle="沒有承諾。只是聊聊孩子的冰球未來。"
      />
      <div class="contact-center">
        <div class="contact-person">
          <h3>和 Ryan 聊聊</h3>
          <p>RISE Advancement 聯合創始人。前球員，現任教練。他會坦白回答你的問題。</p>
        </div>
        <ContactForm lang="zh" />
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .hero { padding-top: var(--space-20); padding-bottom: var(--space-20); }
  .hero-content { max-width: 720px; margin: 0 auto; text-align: center; }
  .hero-eyebrow { font-family: var(--font-heading); font-size: var(--text-sm); font-weight: 500; color: var(--rise-neutral-500); text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: var(--space-4); }
  .hero-title { font-size: var(--text-5xl); margin-bottom: var(--space-6); }
  @media (max-width: 639px) { .hero-title { font-size: var(--text-3xl); } }
  .hero-title-red { color: var(--rise-red); }
  .hero-lead { font-size: var(--text-lg); color: var(--rise-neutral-500); margin-bottom: var(--space-8); max-width: none; }
  .hero-actions { display: flex; gap: var(--space-4); justify-content: center; flex-wrap: wrap; }
  .btn-primary, .btn-secondary { display: inline-block; font-family: var(--font-heading); font-size: var(--text-sm); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; padding: var(--space-3) var(--space-8); border-radius: 4px; text-decoration: none; transition: all 0.2s; }
  .btn-primary { background-color: var(--rise-red); color: var(--rise-white); }
  .btn-primary:hover { background-color: var(--rise-red-dark); color: var(--rise-white); text-decoration: none; }
  .btn-secondary { background-color: transparent; color: var(--rise-black); border: 2px solid var(--rise-neutral-300); }
  .btn-secondary:hover { border-color: var(--rise-red); color: var(--rise-red); text-decoration: none; }
  .steps-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-6); }
  @media (min-width: 640px) { .steps-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .steps-grid { grid-template-columns: repeat(4, 1fr); } }
  .step { text-align: center; padding: var(--space-6); }
  .step-number { font-family: var(--font-heading); font-size: var(--text-3xl); font-weight: 700; color: var(--rise-red); margin-bottom: var(--space-3); }
  .step h3 { font-size: var(--text-xl); margin-bottom: var(--space-2); }
  .step p { font-size: var(--text-sm); color: var(--rise-neutral-500); line-height: 1.6; }
  .services-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-6); }
  @media (min-width: 640px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .services-grid { grid-template-columns: repeat(3, 1fr); } }
  .players-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 640px) { .players-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .players-grid { grid-template-columns: repeat(3, 1fr); } }
  .faq-list { display: flex; flex-direction: column; gap: var(--space-8); }
  .faq-item h3 { font-size: var(--text-lg); margin-bottom: var(--space-2); }
  .faq-item p { font-size: var(--text-sm); color: var(--rise-neutral-500); line-height: 1.7; }
  .faq-item a { color: var(--rise-red); text-decoration: underline; }
  .contact-center { display: flex; flex-direction: column; gap: var(--space-8); align-items: center; }
  .contact-person h3 { font-size: var(--text-xl); margin-bottom: var(--space-2); }
  .contact-person p { font-size: var(--text-sm); color: var(--rise-neutral-500); line-height: 1.6; }
  .mid-cta { text-align: center; margin-top: var(--space-8); }
</style>
