  <!-- ====== PAGE SCRIPTS (same as EN) ====== -->
  <script is:inline>
    (function () {
      var lenis = new Lenis({
        duration: 0.8,
        easing: function(t) { return 1 - Math.pow(1 - t, 4); },
        smoothWheel: true, wheelMultiplier: 1.5, touchMultiplier: 1.2, infinite: false,
      });
      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add(function(time) { lenis.raf(time * 1000); });
      gsap.ticker.lagSmoothing(0);

      // THREE.JS ICE RINK
      (function() {
        var canvas = document.getElementById('hero-canvas');
        if (!canvas) return;
        var renderer = new THREE.WebGLRenderer({ canvas: canvas, antialias: true, alpha: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setClearColor(0x0a0a0a, 1);
        var scene = new THREE.Scene();
        var camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 100);
        camera.position.set(0, 0, 8);
        var mouse = { x: 0, y: 0 };
        var floor = new THREE.Mesh(new THREE.PlaneGeometry(28, 18), new THREE.MeshBasicMaterial({ color: 0x08080c, transparent: true, opacity: 0.5, side: THREE.DoubleSide }));
        floor.position.z = -4; scene.add(floor);
        var dashMat = new THREE.LineDashedMaterial({ color: 0xD3191F, transparent: true, opacity: 0.06, dashSize: 0.3, gapSize: 0.2 });
        var dashMatBlue = new THREE.LineDashedMaterial({ color: 0x4488cc, transparent: true, opacity: 0.04, dashSize: 0.3, gapSize: 0.2 });
        function makeDashedLine(pts, mat) { var g = new THREE.BufferGeometry().setFromPoints(pts); var l = new THREE.Line(g, mat); l.computeLineDistances(); return l; }
        function makeCircle(cx, cy, r, seg, mat) { var pts = []; for (var i = 0; i <= seg; i++) { var a = (i / seg) * Math.PI * 2; pts.push(new THREE.Vector3(cx + Math.cos(a) * r, cy + Math.sin(a) * r, -3.85)); } return makeDashedLine(pts, mat); }
        scene.add(makeDashedLine([new THREE.Vector3(0,-9,-3.85), new THREE.Vector3(0,9,-3.85)], dashMat));
        scene.add(makeDashedLine([new THREE.Vector3(-6,-9,-3.85), new THREE.Vector3(-6,9,-3.85)], dashMatBlue));
        scene.add(makeDashedLine([new THREE.Vector3(6,-9,-3.85), new THREE.Vector3(6,9,-3.85)], dashMatBlue));
        scene.add(makeDashedLine([new THREE.Vector3(-13,-8,-3.85), new THREE.Vector3(13,-8,-3.85)], dashMat));
        scene.add(makeDashedLine([new THREE.Vector3(13,-8,-3.85), new THREE.Vector3(13,8,-3.85)], dashMat));
        scene.add(makeDashedLine([new THREE.Vector3(13,8,-3.85), new THREE.Vector3(-13,8,-3.85)], dashMat));
        scene.add(makeDashedLine([new THREE.Vector3(-13,8,-3.85), new THREE.Vector3(-13,-8,-3.85)], dashMat));
        scene.add(makeCircle(0,0,3,64,dashMat)); scene.add(makeCircle(-8,0,2,48,dashMat)); scene.add(makeCircle(8,0,2,48,dashMat));
        scene.add(makeCircle(-8,-5,0.5,32,dashMat)); scene.add(makeCircle(-8,5,0.5,32,dashMat));
        scene.add(makeCircle(8,-5,0.5,32,dashMat)); scene.add(makeCircle(8,5,0.5,32,dashMat));
        var dotGeom = new THREE.CircleGeometry(0.12, 16);
        var dotMat = new THREE.MeshBasicMaterial({ color: 0xD3191F, transparent: true, opacity: 0.15 });
        var centerDot = new THREE.Mesh(dotGeom, dotMat); centerDot.position.z = -3.84; scene.add(centerDot);
        var count = window.innerWidth < 768 ? 400 : 1000;
        var positions = new Float32Array(count * 3), colors = new Float32Array(count * 3), velocities = new Float32Array(count * 3);
        var iceColor = new THREE.Color(0xB8D4E3), redColor = new THREE.Color(0xD3191F), whiteColor = new THREE.Color(0xE8E8E8);
        for (var i = 0; i < count; i++) {
          positions[i*3] = (Math.random()-0.5)*24; positions[i*3+1] = (Math.random()-0.5)*16; positions[i*3+2] = (Math.random()-0.5)*8-1;
          velocities[i*3] = (Math.random()-0.5)*0.002; velocities[i*3+1] = -Math.random()*0.004-0.001; velocities[i*3+2] = (Math.random()-0.5)*0.001;
          var r = Math.random(), c; if (r < 0.12) c = redColor; else if (r < 0.45) c = iceColor; else c = whiteColor;
          colors[i*3] = c.r; colors[i*3+1] = c.g; colors[i*3+2] = c.b;
        }
        var particleGeom = new THREE.BufferGeometry();
        particleGeom.setAttribute('position', new THREE.BufferAttribute(positions, 3));
        particleGeom.setAttribute('color', new THREE.BufferAttribute(colors, 3));
        var particles = new THREE.Points(particleGeom, new THREE.PointsMaterial({ size: 0.04, vertexColors: true, transparent: true, opacity: 0.6, sizeAttenuation: true }));
        scene.add(particles);
        var rafId, heroKilled = false;
        function animate() {
          rafId = requestAnimationFrame(animate);
          var pos = particleGeom.attributes.position.array;
          for (var i = 0; i < count; i++) { pos[i*3] += velocities[i*3]; pos[i*3+1] += velocities[i*3+1]; pos[i*3+2] += velocities[i*3+2]; if (pos[i*3+1] < -8) { pos[i*3+1] = 8; pos[i*3] = (Math.random()-0.5)*24; } }
          particleGeom.attributes.position.needsUpdate = true;
          camera.position.x += (mouse.x * 0.4 - camera.position.x) * 0.015;
          camera.position.y += (-mouse.y * 0.3 - camera.position.y) * 0.015;
          camera.lookAt(0, 0, 0); renderer.render(scene, camera);
        }
        animate();
        window.addEventListener('mousemove', function(e) { mouse.x = (e.clientX/window.innerWidth)*2-1; mouse.y = (e.clientY/window.innerHeight)*2-1; });
        window.addEventListener('resize', function() { camera.aspect = window.innerWidth/window.innerHeight; camera.updateProjectionMatrix(); renderer.setSize(window.innerWidth, window.innerHeight); });
        window.addEventListener('scroll', function() { if (!heroKilled && window.scrollY > window.innerHeight*1.5) { cancelAnimationFrame(rafId); heroKilled = true; } else if (heroKilled && window.scrollY < window.innerHeight*1.5) { heroKilled = false; animate(); } }, { passive: true });
      })();

      gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);
      var loaderTl = gsap.timeline();
      loaderTl.to('#loader-fill', { width: '100%', duration: 0.8, ease: 'power2.inOut' }).to('#loader', { yPercent: -100, duration: 0.6, ease: 'power4.inOut', delay: 0.15 }).to('.hp-hero__eyebrow span', { y: 0, duration: 0.5, ease: 'power3.out' }, '-=0.2').to('.hp-hero__title .line-inner', { y: 0, duration: 0.8, stagger: 0.12, ease: 'power4.out' }, '-=0.3').to('.hp-hero__subtitle span', { y: 0, duration: 0.6, ease: 'power3.out' }, '-=0.4').to('.hp-hero__actions', { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' }, '-=0.2').to('.hp-hero__scroll', { opacity: 1, duration: 0.4 }, '-=0.1');
      ScrollTrigger.create({ start: 80, onUpdate: function(self) { document.getElementById('hp-nav').classList.toggle('scrolled', self.progress > 0); } });
      gsap.utils.toArray('.hp-step').forEach(function(step, i) { var marker = step.querySelector('.hp-step__marker'); gsap.from(step, { opacity: 0, y: 30, duration: 0.8, ease: 'power3.out', delay: i * 0.1, immediateRender: false, scrollTrigger: { trigger: step, start: 'top 75%' } }); ScrollTrigger.create({ trigger: step, start: 'top 75%', onEnter: function() { marker.classList.add('active'); gsap.to(marker, { borderColor: 'rgba(211,25,31,0.5)', boxShadow: '0 0 30px rgba(211,25,31,0.15)', duration: 0.6 }); } }); });
      ScrollTrigger.create({ trigger: '.hp-pipeline', start: 'top 70%', end: 'bottom 40%', onUpdate: function(self) { gsap.set('#pipeline-fill', { width: (self.progress * 100) + '%' }); } });
      gsap.utils.toArray('.hp-service-row').forEach(function(row) { var content = row.querySelector('[data-service-content]'); var visual = row.querySelector('.hp-service__visual'); if (content) gsap.from(content, { opacity: 0, x: 40, duration: 0.8, ease: 'power3.out', immediateRender: false, scrollTrigger: { trigger: row, start: 'top 80%' } }); if (visual) gsap.from(visual, { opacity: 0, x: -40, duration: 0.8, ease: 'power3.out', immediateRender: false, scrollTrigger: { trigger: row, start: 'top 80%' } }); });
      gsap.from('.hp-interlude h2', { opacity: 0, y: 30, duration: 0.8, ease: 'power3.out', immediateRender: false, scrollTrigger: { trigger: '.hp-interlude', start: 'top 75%' } });
      gsap.from('.hp-interlude p', { opacity: 0, y: 20, duration: 0.8, ease: 'power3.out', delay: 0.2, immediateRender: false, scrollTrigger: { trigger: '.hp-interlude', start: 'top 75%' } });
      gsap.utils.toArray('.hp-player-card').forEach(function(card, i) { gsap.from(card, { opacity: 0, y: 40, duration: 0.8, ease: 'power3.out', delay: i * 0.15, immediateRender: false, scrollTrigger: { trigger: card, start: 'top 80%' } }); });
      gsap.utils.toArray('[data-count]').forEach(function(el) { var target = parseInt(el.dataset.count); var obj = { val: 0 }; ScrollTrigger.create({ trigger: el, start: 'top 85%', once: true, onEnter: function() { gsap.to(obj, { val: target, duration: 1.5, ease: 'power2.out', onUpdate: function() { el.textContent = Math.round(obj.val); } }); } }); });
      gsap.from('.hp-cta__content h2', { opacity: 0, y: 30, duration: 0.8, ease: 'power3.out', immediateRender: false, scrollTrigger: { trigger: '.hp-cta', start: 'top 75%' } });
      gsap.from('.hp-cta__content p', { opacity: 0, y: 20, duration: 0.8, ease: 'power3.out', delay: 0.15, immediateRender: false, scrollTrigger: { trigger: '.hp-cta', start: 'top 75%' } });
      gsap.from('.hp-cta__buttons', { opacity: 0, y: 20, duration: 0.8, ease: 'power3.out', delay: 0.3, immediateRender: false, scrollTrigger: { trigger: '.hp-cta', start: 'top 75%' } });
      document.querySelectorAll('.hp-faq-item__question').forEach(function(btn) { btn.addEventListener('click', function() { var item = btn.closest('.hp-faq-item'); var answer = item.querySelector('.hp-faq-item__answer'); var isOpen = item.classList.contains('active'); document.querySelectorAll('.hp-faq-item.active').forEach(function(a) { a.classList.remove('active'); gsap.to(a.querySelector('.hp-faq-item__answer'), { maxHeight: 0, duration: 0.4, ease: 'power3.inOut' }); }); if (!isOpen) { item.classList.add('active'); answer.style.maxHeight = 'none'; var h = answer.scrollHeight; answer.style.maxHeight = '0px'; answer.offsetHeight; gsap.to(answer, { maxHeight: h, duration: 0.5, ease: 'power3.out' }); } }); });
      document.querySelectorAll('.hp-nav__links a[href^="#"]').forEach(function(a) { a.addEventListener('click', function(e) { e.preventDefault(); var target = document.querySelector(a.getAttribute('href')); if (target) lenis.scrollTo(target, { offset: -80, duration: 1.5 }); }); });
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) { lenis.destroy(); ScrollTrigger.getAll().forEach(function(st) { st.kill(); }); gsap.globalTimeline.progress(1); document.querySelectorAll('.hp-service-row, [data-service-content], .hp-service__visual, .hp-player-card, .hp-step, .hp-hero__actions, .hp-hero__scroll, .hp-hero__eyebrow span, .hp-hero__title .line-inner, .hp-hero__subtitle span, .hp-interlude h2, .hp-interlude p, .hp-cta__content h2, .hp-cta__content p, .hp-cta__buttons').forEach(function(el) { el.style.opacity = '1'; el.style.transform = 'none'; }); var loader = document.getElementById('loader'); if (loader) loader.style.display = 'none'; }
    })();
  </script>
</HomeLayout>
