---
// HomeNav.astro — Fixed dark nav for homepage
---

<nav class="hp-nav" id="hp-nav">
  <a href="/" class="hp-nav__logo">
    <img src="https://riseadvancement.com/logo-header.png" alt="RISE Advancement" />
  </a>
  <ul class="hp-nav__links">
    <li><a href="#how-it-works">How It Works</a></li>
    <li><a href="#services">Services</a></li>
    <li><a href="#players">Players</a></li>
    <li><a href="#faq">FAQ</a></li>
    <li><a href="#contact" class="hp-nav__cta">Contact</a></li>
    <li>
      <button class="hp-nav__cta" type="button" data-open-auth data-auth-anon hidden>Portal</button>
    </li>
    <li class="hp-nav__user-menu" data-auth-user hidden>
      <a href="/portal" class="hp-nav__cta">Portal</a>
    </li>
  </ul>
  <button class="hp-nav__hamburger" id="hp-hamburger" aria-label="Menu">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <!-- Mobile portal login -->
  <div class="hp-nav__mobile-auth" id="hp-mobile-auth">
    <button class="hp-nav__cta hp-nav__cta--mobile" type="button" data-open-auth data-auth-anon hidden>Portal</button>
    <a href="/portal" class="hp-nav__cta hp-nav__cta--mobile" data-auth-user hidden>Portal</a>
  </div>
</nav>

<style>
  .hp-nav__user-menu[hidden] { display: none !important; }
  .hp-nav__mobile-auth { display: none; }
  .hp-nav__cta--mobile { display: none; }
  [data-auth-user][hidden] { display: none !important; }

  /* Make the button look identical to the anchor CTA */
  button.hp-nav__cta {
    font-family: var(--font-heading, 'Oswald', sans-serif);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.6rem 1.5rem;
    border: 1px solid var(--rise-red, #D3191F);
    border-radius: 0;
    background: transparent;
    color: var(--rise-red, #D3191F);
    cursor: pointer;
    transition: all 0.3s;
  }
  button.hp-nav__cta:hover {
    background: var(--rise-red, #D3191F);
    color: var(--rise-white, #fff);
  }

  @media (max-width: 639px) {
    .hp-nav__links li:has(button.hp-nav__cta),
    .hp-nav__links li:has(.hp-nav__user-menu) {
      display: none;
    }
    .hp-nav__mobile-auth {
      display: flex;
      gap: 0.5rem;
      padding: 0.5rem 1.25rem;
    }
    .hp-nav__cta--mobile:not([hidden]) {
      display: inline-flex;
    }
  }
</style>

<script>
  function initHomeAuth() {
    const sb = (window as any).supabaseClient;
    if (!sb) { setTimeout(initHomeAuth, 100); return; }
    sb.auth.getSession().then(({ data }: any) => {
      applyHomeAuthState(data.session?.user || null);
    });
    sb.auth.onAuthStateChange((_e: string, session: any) => {
      applyHomeAuthState(session?.user || null);
    });
  }
  function applyHomeAuthState(user: any) {
    const isAuthed = !!user;
    document.querySelectorAll<HTMLElement>('[data-auth-anon]').forEach(el => {
      el.toggleAttribute('hidden', isAuthed);
    });
    document.querySelectorAll<HTMLElement>('[data-auth-user]').forEach(el => {
      el.toggleAttribute('hidden', !isAuthed);
    });
  }
  initHomeAuth();
</script>
