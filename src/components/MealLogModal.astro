  .tk-item-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
  }
  .tk-item-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .tk-item-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--rise-black);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .tk-item-meta {
    font-size: 0.78rem;
    color: var(--rise-neutral-500);
  }
  .tk-item-protein {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--rise-red);
    font-size: 1rem;
    min-width: 44px;
    text-align: right;
  }
  .tk-item-remove {
    background: transparent;
    border: 1px solid var(--rise-neutral-200);
    width: 28px;
    height: 28px;
    border-radius: 6px;
    color: var(--rise-neutral-500);
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }
  .tk-item-remove:hover {
    border-color: var(--rise-red);
    color: var(--rise-red);
    background: var(--rise-red-light);
  }

  /* ----- Footer ----- */
  .tk-modal-foot {
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-top: 1px solid var(--rise-neutral-100);
    padding-top: 12px;
  }
  .tk-modal-foot[hidden] { display: none !important; }
  .tk-meal-total {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 0.9rem;
    color: var(--rise-neutral-500);
  }
  .tk-meal-total strong {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    color: var(--rise-red);
    font-weight: 700;
  }
  /* Reuse .tk-row / .tk-btn from tracker page styles, but reaffirm here so
     the modal still looks right if ever rendered outside that page. */
  .tk-modal-foot .tk-row { display: flex; gap: 10px; }
  .tk-modal-foot .tk-row .tk-btn { flex: 1; }
  .tk-modal-foot .tk-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 18px;
    border-radius: 10px;
    border: 1px solid transparent;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    width: 100%;
  }
  .tk-modal-foot .tk-btn-primary {
    background: var(--rise-red);
    color: var(--rise-white);
  }
  .tk-modal-foot .tk-btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
  .tk-modal-foot .tk-btn-ghost {
    background: transparent;
    color: var(--rise-neutral-700);
    border-color: var(--rise-neutral-200);
  }
  .tk-form-msg {
    font-size: 0.85rem;
    text-align: center;
    margin: 0;
    min-height: 1.1em;
    color: var(--rise-neutral-500);
  }
  .tk-form-msg.error { color: var(--rise-red-dark); }
  .tk-form-msg.success { color: #15803d; }
</style>

