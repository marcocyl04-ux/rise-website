    align-items: baseline;
    font-size: 0.9rem;
    color: var(--rise-neutral-500);
  }
  #meal-modal-foot .tk-meal-total strong,
  .tk-modal-foot .tk-meal-total strong,
  .tk-meal-total strong {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    color: var(--rise-red);
    font-weight: 700;
  }
  #meal-modal-foot .tk-form-msg,
  .tk-modal-foot .tk-form-msg {
    font-size: 0.85rem;
    text-align: center;
    margin: 0;
    min-height: 1.1em;
    color: var(--rise-neutral-500);
  }
  #meal-modal-foot .tk-form-msg.error,
  .tk-modal-foot .tk-form-msg.error { color: var(--rise-red-dark); }
  #meal-modal-foot .tk-form-msg.success,
  .tk-modal-foot .tk-form-msg.success { color: #15803d; }
</style>

<script>
  import { analyzeMealPhoto, analyzeMealText, type AnalyzedItem } from "../lib/analyze-meal";

  type ModalState = {
    open: boolean;
    slotKey: string | null;
    slotLabel: string | null;
    dateISO: string;
    items: AnalyzedItem[];
    photoFile: File | null;
    photoDataUrl: string | null;
    addMode: boolean;
  };

  const state: ModalState = {
    open: false,
    slotKey: null,
    slotLabel: null,
    dateISO: new Date().toISOString().slice(0, 10),
    items: [],
    photoFile: null,
    photoDataUrl: null,
    addMode: false,
  };

  const modal = () => document.getElementById("meal-modal") as HTMLDivElement | null;
  const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T | null;

  function setView(view: "choice" | "photo" | "text-input") {
    document.querySelectorAll<HTMLElement>("#meal-modal [data-view]").forEach((el) => {
      el.toggleAttribute("hidden", el.dataset.view !== view);
    });
  }

  function setMsg(text: string, kind: "" | "error" | "success" = "") {
    const m = $("meal-modal-msg");
    if (!m) return;
    m.textContent = text;
    m.className = "tk-form-msg" + (kind ? " " + kind : "");
  }

  function totalProtein(): number {
    const t = state.items.reduce((acc, it) => acc + (Number(it.protein_g) || 0), 0);
    return Math.round(t * 10) / 10;
  }

  function totalCalories(): number {
    return state.items.reduce((acc, it) => acc + (Number(it.calories_kcal) || 0), 0);
  }

  function totalFat(): number {
    const t = state.items.reduce((acc, it) => acc + (Number(it.fat_g) || 0), 0);
    return Math.round(t * 10) / 10;
  }

  function totalSugar(): number {
    const t = state.items.reduce((acc, it) => acc + (Number(it.sugar_g) || 0), 0);
    return Math.round(t * 10) / 10;
  }

  function renderItems() {
    const list = $("meal-items-list");
    const foot = $("meal-modal-foot");
    if (!list || !foot) return;

    if (state.items.length === 0) {
      list.hidden = true;
      foot.hidden = true;
      list.innerHTML = "";
      return;
    }

    list.hidden = false;
    foot.hidden = false;
    list.innerHTML = state.items
      .map((it, i) => {
        const protein = Number(it.protein_g) || 0;
        const calories = Number(it.calories_kcal) || 0;
        const fat = Number(it.fat_g) || 0;
        const sugar = Number(it.sugar_g) || 0;
        return `
          <div class="tk-item-row">
            <div class="tk-item-info">
              <span class="tk-item-name">${escapeHtml(it.name)}${
                it.name_zh ? ` · ${escapeHtml(it.name_zh)}` : ""
              }</span>
              <span class="tk-item-meta">${escapeHtml(it.portion_label || "")} · ${calories}kcal · ${fat}g fat · ${sugar}g sugar · ${protein}g protein</span>
            </div>
            <button class="tk-item-remove" type="button" data-remove-idx="${i}" aria-label="Remove">×</button>
          </div>
        `;
      })
      .join("");

    list.querySelectorAll<HTMLButtonElement>("[data-remove-idx]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const idx = Number(btn.dataset.removeIdx);
        if (!Number.isFinite(idx)) return;
        state.items.splice(idx, 1);
        renderItems();
      });
    });

    const totalEl = $("meal-total");
    if (totalEl) totalEl.textContent = String(totalProtein());

    const calEl = $("meal-total-cal");
    if (calEl) calEl.textContent = String(totalCalories());

    const fatEl = $("meal-total-fat");
    if (fatEl) fatEl.textContent = String(totalFat());

    const sugarEl = $("meal-total-sugar");
    if (sugarEl) sugarEl.textContent = String(totalSugar());

    const confirmBtn = $("meal-confirm") as HTMLButtonElement | null;
    if (confirmBtn) confirmBtn.disabled = state.items.length === 0;
  }

  function escapeHtml(s: string): string {
    return String(s).replace(/[&<>"']/g, (c) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;",
    }[c] as string));
  }

  // --- Photo flow -------------------------------------------------------------
  function pickPhoto() {
    const input = $("meal-photo-input") as HTMLInputElement | null;
    if (!input) return;
    input.value = "";
    input.click();
  }

  async function handlePhoto(file: File) {
    setView("photo");
    setMsg("");

    const notRightBtn = $("meal-not-right");
    if (notRightBtn) notRightBtn.hidden = true;

    const reader = new FileReader();
    const dataUrl: string = await new Promise((resolve) => {
      reader.onload = () => resolve(String(reader.result || ""));
      reader.readAsDataURL(file);
    });
    state.photoFile = file;
    state.photoDataUrl = dataUrl;

    const img = $("meal-photo-img") as HTMLImageElement | null;
    if (img) img.src = dataUrl;

    const status = $("meal-analyze-status");
    if (status) {
      status.textContent = "Analyzing…";
      status.className = "tk-analyze-status";
    }

    try {
      const result = await analyzeMealPhoto(file);
      if (state.addMode) {
        state.items.push(...result.items);
      } else {
        state.items = result.items.slice();
      }
      state.addMode = true;
      renderItems();
      if (status) {
        if (result.mock) {
          status.textContent = result.notice || "Mock analysis, adjust as needed";
          status.className = "tk-analyze-status mock";
        } else {
          status.textContent = "Adjust if needed, then confirm";
          status.className = "tk-analyze-status";
        }
      }
      if (notRightBtn) notRightBtn.hidden = false;
      // Go back to choice screen so user can add more items or confirm.
      setView("choice");
    } catch (err: any) {
      console.error("analyze", err);
      if (status) {
        status.textContent = "Could not analyze photo. Try describing what you ate.";
        status.className = "tk-analyze-status error";
      }
      if (notRightBtn) notRightBtn.hidden = false;
      setView("choice");
    }
  }

  async function handleTextAnalysis() {
    const textInput = $("meal-text-input") as HTMLInputElement | null;
    const status = $("meal-text-status");
    const analyzeBtn = $("meal-text-analyze") as HTMLButtonElement | null;

    const description = (textInput?.value || "").trim();
    if (!description) {
      if (status) {
        status.textContent = "Type what you ate first";
        status.className = "tk-analyze-status error";
      }
      return;
    }

    if (status) {
      status.textContent = "Analyzing…";
      status.className = "tk-analyze-status";
    }
    if (analyzeBtn) analyzeBtn.disabled = true;

    try {
      const result = await analyzeMealText(description);
      if (state.addMode) {
        state.items.push(...result.items);
      } else {
        state.items = result.items.slice();
      }
      state.addMode = true;
      renderItems();

      const photoStatus = $("meal-analyze-status");
      if (photoStatus) {
        const count = state.items.length;
        photoStatus.textContent = `AI found ${count} item${count === 1 ? "" : "s"}, tap any to adjust`;
        photoStatus.className = "tk-analyze-status";
      }

      // Always return to choice screen so user can add more or confirm.
      setView("choice");
    } catch (err: any) {
      console.error("analyze text", err);
      if (status) {
        status.textContent = "Could not analyze. Try again.";
        status.className = "tk-analyze-status error";
      }
    } finally {
      if (analyzeBtn) analyzeBtn.disabled = false;
    }
  }

  function showTextInput() {
    setView("text-input");
    const status = $("meal-text-status");
    if (status) {
      status.textContent = "";
      status.className = "tk-analyze-status";
    }
    const textInput = $("meal-text-input") as HTMLInputElement | null;
    setTimeout(() => textInput?.focus(), 30);
  }

  // --- Confirm + upload + save ------------------------------------------------
  async function uploadPhoto(userId: string, slotKey: string, dateISO: string): Promise<string | null> {
    if (!state.photoFile) return null;
    const sb = (window as any).supabaseClient;
    if (!sb) return null;

    const ext = (state.photoFile.type.split("/")[1] || "jpg").replace("jpeg", "jpg");
    const path = `${userId}/${dateISO}/${slotKey}.${ext}`;

    try {
      const { error } = await sb.storage
        .from("meal-photos")
        .upload(path, state.photoFile, {
          upsert: true,
          contentType: state.photoFile.type || "image/jpeg",
        });
      if (error) {
        console.warn("storage upload", error);
        return null;
      }
      return path;
    } catch (e) {
      console.warn("storage upload threw", e);
      return null;
    }
  }

  async function confirmMeal() {
    if (state.items.length === 0) return;
    const btn = $("meal-confirm") as HTMLButtonElement | null;
    if (btn) btn.disabled = true;
    setMsg("Saving…");

    try {
      const sb = (window as any).supabaseClient;
      if (!sb) throw new Error("Supabase not available");

      const { data: { user } } = await sb.auth.getUser();
      if (!user) throw new Error("Not signed in");

      const dateISO = state.dateISO;
      const photoPath = await uploadPhoto(user.id, state.slotKey || "meal", dateISO);

      const total = totalProtein();
      const cals = totalCalories();
      const fats = totalFat();
      const sugars = totalSugar();
      const foodItems = state.items.map((it) => ({
        name: it.name,
        name_zh: it.name_zh || "",
        portion_label: it.portion_label,
        protein_g: Number(it.protein_g) || 0,
        calories_kcal: Number(it.calories_kcal) || 0,
        fat_g: Number(it.fat_g) || 0,
        sugar_g: Number(it.sugar_g) || 0,
        confidence: typeof it.confidence === "number" ? it.confidence : 1,
      }));

      const { error } = await sb.from("meal_logs").upsert(
        {
          user_id: user.id,
          meal_slot: state.slotKey,
          logged_date: dateISO,
          photo_url: photoPath,
          food_items: foodItems,
          total_protein_g: total,
          total_calories_kcal: cals,
          total_fat_g: fats,
          total_sugar_g: sugars,
        },
        { onConflict: "user_id,meal_slot,logged_date" }
      );
      if (error) throw error;

      setMsg("Saved", "success");
      window.dispatchEvent(
        new CustomEvent("meal-logged", {
          detail: {
            slot: state.slotKey,
            total,
            items: foodItems,
            photo_url: photoPath,
          },
        })
      );

      setTimeout(closeModal, 400);
    } catch (err: any) {
      console.error("confirm meal", err);
      setMsg(err?.message || "Could not save meal", "error");
      if (btn) btn.disabled = false;
    }
  }

  // --- Open / close -----------------------------------------------------------
  function resetState() {
    state.items = [];
    state.photoFile = null;
    state.photoDataUrl = null;
    state.addMode = false;
    const img = $("meal-photo-img") as HTMLImageElement | null;
    if (img) img.src = "";
    const textInput = $("meal-text-input") as HTMLInputElement | null;
    if (textInput) textInput.value = "";
    const textStatus = $("meal-text-status");
    if (textStatus) {
      textStatus.textContent = "";
      textStatus.className = "tk-analyze-status";
    }
    const notRightBtn = $("meal-not-right");
    if (notRightBtn) notRightBtn.hidden = true;
    setMsg("");
    renderItems();
  }

  function openModal(slotKey: string, slotLabel: string, prefill?: AnalyzedItem[], dateISO?: string) {
    const m = modal();
    if (!m) return;
    resetState();
    state.open = true;
    state.slotKey = slotKey;
    state.slotLabel = slotLabel;
    state.dateISO = dateISO || new Date().toISOString().slice(0, 10);

    const title = $("meal-modal-title");
    if (title) title.textContent = (prefill && prefill.length ? "Edit" : "Log") + ` · ${slotLabel}`;

    if (prefill && prefill.length) {
      state.items = prefill.map((it) => ({ ...it }));
      state.addMode = true;
      renderItems();
      setView("choice");
    } else {
      state.addMode = false;
      setView("choice");
    }

    m.hidden = false;
    m.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    const m = modal();
    if (!m) return;
    m.hidden = true;
    m.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
    state.open = false;
  }

  function wireModal() {
    const m = modal();
    if (!m) return;

    document.querySelectorAll<HTMLElement>("#meal-modal [data-meal-modal-close]").forEach((el) => {
      el.addEventListener("click", closeModal);
    });

    $("meal-photo-cta")?.addEventListener("click", pickPhoto);
    $("meal-text-cta")?.addEventListener("click", showTextInput);

    $("meal-add-more")?.addEventListener("click", showTextInput);
    $("meal-confirm")?.addEventListener("click", confirmMeal);

    $("meal-not-right")?.addEventListener("click", () => {
      state.addMode = false;
      showTextInput();
    });
    $("meal-text-analyze")?.addEventListener("click", handleTextAnalysis);

    const textInput = $("meal-text-input") as HTMLInputElement | null;
    textInput?.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        handleTextAnalysis();
      }
    });

    const photoInput = $("meal-photo-input") as HTMLInputElement | null;
    photoInput?.addEventListener("change", () => {
      const f = photoInput.files?.[0];
      if (f) handlePhoto(f);
    });

    const uploadInput = $("meal-upload-input") as HTMLInputElement | null;
    $("meal-upload-cta")?.addEventListener("click", () => {
      if (!uploadInput) return;
      uploadInput.value = "";
      uploadInput.click();
    });
    uploadInput?.addEventListener("change", () => {
      const f = uploadInput.files?.[0];
      if (f) handlePhoto(f);
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && state.open) closeModal();
    });
  }

  // Expose to global scope for tracker.astro to invoke.
  (window as any).openMealLog = openModal;
  (window as any).closeMealLog = closeModal;

  wireModal();
</script>
