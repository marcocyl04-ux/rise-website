---
// Meal logging modal — overlay for capturing or searching a meal entry.
// Opens via window.openMealLog(slotKey, slotLabel, prefillItems?).
// Closes via window.closeMealLog(). Fires a 'meal-logged' CustomEvent on
// window when a meal is saved (detail: { slot, total, items, photo_url }).
//
// IMPORTANT: assumes a Supabase Storage bucket named "meal-photos" exists.
// Create it manually in the Supabase dashboard (Storage > New Bucket,
// private, 5 MB limit, allowed: image/jpeg, image/png, image/webp). Add an
// RLS policy on storage.objects so users can only access their own folder.
---

<div id="meal-modal" class="tk-modal" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="meal-modal-title">
  <div class="tk-modal-backdrop" data-meal-modal-close></div>

  <div class="tk-modal-card">
    <header class="tk-modal-head">
      <h3 class="tk-modal-title" id="meal-modal-title">Log meal</h3>
      <button class="tk-modal-x" type="button" data-meal-modal-close aria-label="Close">×</button>
    </header>

    <!-- CHOICE: three input methods -->
    <div class="tk-modal-body" data-view="choice">
      <button class="tk-photo-cta" id="meal-photo-cta" type="button">
        <span class="tk-photo-icon" aria-hidden="true">▣</span>
        <span class="tk-photo-cta-label" data-i18n="modal.takePhoto">Take photo</span>
        <span class="tk-photo-cta-sub" data-i18n="modal.takePhoto.sub">Snap your meal, AI estimates protein</span>
      </button>
      <button class="tk-search-cta" id="meal-upload-cta" type="button">
        <span aria-hidden="true">⇪</span>
        <span data-i18n="modal.uploadPhoto">Upload photo</span>
      </button>
      <button class="tk-photo-cta" id="meal-text-cta" type="button">
        <span class="tk-photo-icon" aria-hidden="true">✎</span>
        <span class="tk-photo-cta-label" data-i18n="modal.textToAI">Describe your meal</span>
        <span class="tk-photo-cta-sub" data-i18n="modal.textToAI.sub">Type what you ate, AI estimates nutrition</span>
      </button>
    </div>

    <!-- PHOTO: preview + analyzing + results -->
    <div class="tk-modal-body" data-view="photo" hidden>
      <div class="tk-photo-preview">
        <img id="meal-photo-img" alt="Meal photo" />
      </div>
      <p class="tk-analyze-status" id="meal-analyze-status">Analyzing…</p>
      <button class="tk-text-fallback-cta" id="meal-not-right" type="button" hidden>
        Not right? Tell us what you had
      </button>
    </div>

    <!-- TEXT INPUT: describe meal as fallback -->
    <div class="tk-modal-body" data-view="text-input" hidden>
      <div class="tk-search-wrap">
        <input
          type="text"
          id="meal-text-input"
          class="tk-search-input"
          placeholder="Describe what you ate... (e.g. tuna don, chicken sandwich)"
          autocomplete="off"
        />
      </div>
      <button class="tk-btn tk-btn-primary tk-text-analyze-btn" id="meal-text-analyze" type="button">
        Analyze
      </button>
      <p class="tk-analyze-status" id="meal-text-status"></p>
    </div>

    <!-- Items list (shared) -->
    <div class="tk-meal-items" id="meal-items-list" hidden></div>

    <!-- Footer: total + actions -->
    <footer class="tk-modal-foot" id="meal-modal-foot" hidden>
      <div class="tk-meal-total">
        <span>Total protein</span>
        <strong><span id="meal-total">0</span>g</strong>
      </div>
      <div class="tk-meal-total">
        <span>Total calories</span>
        <strong><span id="meal-total-cal">0</span>kcal</strong>
      </div>
      <div class="tk-meal-total">
        <span>Total fat</span>
        <strong><span id="meal-total-fat">0</span>g</strong>
      </div>
      <div class="tk-meal-total">
        <span>Total sugar</span>
        <strong><span id="meal-total-sugar">0</span>g</strong>
      </div>
      <div class="tk-row">
        <button class="tk-btn tk-btn-ghost" type="button" id="meal-add-more">+ Add more</button>
        <button class="tk-btn tk-btn-primary" type="button" id="meal-confirm">Confirm</button>
      </div>
      <p class="tk-form-msg" id="meal-modal-msg"></p>
    </footer>

    <!-- Hidden file inputs: camera (capture) vs gallery (no capture) -->
    <input
      type="file"
      id="meal-photo-input"
      accept="image/jpeg,image/png,image/webp"
      capture="environment"
      hidden
    />
    <input
      type="file"
      id="meal-upload-input"
      accept="image/jpeg,image/png,image/webp"
      hidden
    />
  </div>
</div>

<style>
  .tk-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    animation: tk-modal-in 0.2s ease;
  }
  @media (min-width: 640px) {
    .tk-modal { align-items: center; }
  }
  .tk-modal[hidden] { display: none !important; }

  @keyframes tk-modal-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .tk-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(18, 18, 18, 0.55);
    backdrop-filter: blur(2px);
  }

  .tk-modal-card {
    position: relative;
    background: var(--rise-white);
    width: 100%;
    max-width: 520px;
    max-height: 92vh;
    border-radius: 16px 16px 0 0;
    padding: 18px 18px 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    box-shadow: 0 -20px 60px rgba(18, 18, 18, 0.25);
    overflow-y: auto;
    color: var(--rise-black);
    font-family: var(--font-body);
  }
  @media (min-width: 640px) {
    .tk-modal-card {
      border-radius: 16px;
      box-shadow: 0 30px 60px rgba(18, 18, 18, 0.25);
    }
  }

  .tk-modal-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding-bottom: 4px;
    border-bottom: 1px solid var(--rise-neutral-100);
  }
  .tk-modal-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 0;
    color: var(--rise-black);
  }
  .tk-modal-x {
    background: transparent;
    border: 0;
    font-size: 1.8rem;
    line-height: 1;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    color: var(--rise-neutral-500);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .tk-modal-x:hover { background: var(--rise-neutral-100); color: var(--rise-black); }

  .tk-modal-body {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .tk-modal-body[hidden] { display: none !important; }

  /* ----- Choice CTAs ----- */
  .tk-photo-cta {
    background: linear-gradient(135deg, var(--rise-red), var(--rise-red-dark));
    color: var(--rise-white);
    border: 0;
    border-radius: 14px;
    padding: 28px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    cursor: pointer;
    font-family: var(--font-body);
    box-shadow: 0 8px 22px rgba(211, 25, 31, 0.22);
    transition: transform 0.1s, box-shadow 0.15s;
  }
  .tk-photo-cta:hover { box-shadow: 0 10px 26px rgba(211, 25, 31, 0.3); }
  .tk-photo-cta:active { transform: scale(0.98); }
  .tk-photo-icon {
    font-size: 2.4rem;
    line-height: 1;
    margin-bottom: 2px;
  }
  .tk-photo-cta-label {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  .tk-photo-cta-sub {
    font-size: 0.85rem;
    opacity: 0.9;
  }

  .tk-search-cta {
    background: var(--rise-white);
    color: var(--rise-black);
    border: 1px solid var(--rise-neutral-200);
    border-radius: 12px;
    padding: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .tk-search-cta:hover { border-color: var(--rise-red); color: var(--rise-red); }

  .tk-shake-cta {
    background: var(--rise-white);
    color: var(--rise-black);
    border: 1px solid var(--rise-neutral-200);
    border-radius: 12px;
    padding: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .tk-shake-cta:hover { border-color: var(--rise-red); color: var(--rise-red); }
  .tk-shake-cta-sub {
    font-size: 0.78rem;
    color: var(--rise-neutral-400);
    font-weight: 400;
    margin-left: auto;
  }
  .tk-shakes-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
    color: var(--rise-black);
    text-align: center;
  }

  /* ----- Photo preview ----- */
  .tk-photo-preview {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--rise-neutral-100);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .tk-photo-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .tk-analyze-status {
    text-align: center;
    color: var(--rise-neutral-500);
    font-size: 0.9rem;
    margin: 0;
  }
  .tk-analyze-status.error { color: var(--rise-red-dark); }
  .tk-analyze-status.mock { color: var(--rise-neutral-400); font-style: italic; }

  /* ----- Text fallback ----- */
  .tk-text-fallback-cta {
    background: transparent;
    color: var(--rise-neutral-700);
    border: 1px solid var(--rise-neutral-200);
    border-radius: 10px;
    padding: 10px 14px;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
    align-self: center;
  }
  .tk-text-fallback-cta:hover {
    border-color: var(--rise-red);
    color: var(--rise-red);
    background: var(--rise-red-light);
  }
  .tk-text-fallback-cta[hidden] { display: none !important; }

  .tk-text-analyze-btn {
    background: var(--rise-red);
    color: var(--rise-white);
    border: 1px solid transparent;
    border-radius: 10px;
    padding: 14px 18px;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    width: 100%;
  }
  .tk-text-analyze-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  /* ----- Search ----- */
  .tk-search-wrap {
    position: relative;
  }
  .tk-search-input {
    width: 100%;
    background: var(--rise-white);
    border: 1px solid var(--rise-neutral-200);
    border-radius: 12px;
    padding: 14px 16px;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--rise-black);
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .tk-search-input:focus {
    border-color: var(--rise-red);
    box-shadow: 0 0 0 3px var(--rise-red-light);
  }
  .tk-search-results {
    max-height: 240px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .tk-search-empty {
    color: var(--rise-neutral-400);
    font-size: 0.9rem;
    text-align: center;
    padding: 16px;
    margin: 0;
  }
  .tk-food-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    background: var(--rise-white);
    border: 1px solid var(--rise-neutral-100);
    border-radius: 10px;
    padding: 10px 12px;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    text-align: left;
    width: 100%;
    font-family: var(--font-body);
    color: var(--rise-black);
  }
  .tk-food-row:hover {
    border-color: var(--rise-red);
    background: var(--rise-red-light);
  }
  .tk-food-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .tk-food-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--rise-black);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .tk-food-meta {
    font-size: 0.78rem;
    color: var(--rise-neutral-500);
  }
  .tk-food-protein {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--rise-red);
    font-size: 1rem;
    white-space: nowrap;
  }

  /* ----- Items list (shared review) ----- */
  .tk-meal-items {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 8px 0;
    border-top: 1px solid var(--rise-neutral-100);
