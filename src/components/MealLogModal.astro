<script>
  import { analyzeMealPhoto, type AnalyzedItem } from "../lib/analyze-meal";

  type FoodRow = {
    id: number;
    name: string;
    name_zh: string | null;
    category: string;
    portion_label: string;
    protein_per_portion: number;
    common_in_hk: boolean;
  };

  type ModalState = {
    open: boolean;
    slotKey: string | null;
    slotLabel: string | null;
    items: AnalyzedItem[];
    photoFile: File | null;
    photoDataUrl: string | null;
    foodCache: FoodRow[] | null;
  };

  const state: ModalState = {
    open: false,
    slotKey: null,
    slotLabel: null,
    items: [],
    photoFile: null,
    photoDataUrl: null,
    foodCache: null,
  };

  const modal = () => document.getElementById("meal-modal") as HTMLDivElement | null;
  const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T | null;

  function setView(view: "choice" | "photo" | "search") {
    document.querySelectorAll<HTMLElement>("#meal-modal [data-view]").forEach((el) => {
      el.toggleAttribute("hidden", el.dataset.view !== view);
    });
  }

  function setMsg(text: string, kind: "" | "error" | "success" = "") {
    const m = $("meal-modal-msg");
    if (!m) return;
    m.textContent = text;
    m.className = "tk-form-msg" + (kind ? " " + kind : "");
  }

  function totalProtein(): number {
    const t = state.items.reduce((acc, it) => acc + (Number(it.protein_g) || 0), 0);
    return Math.round(t * 10) / 10;
  }

  function renderItems() {
    const list = $("meal-items-list");
    const foot = $("meal-modal-foot");
    console.log("[meal-modal] renderItems", {
      itemsCount: state.items.length,
      items: state.items,
      hasList: !!list,
      hasFoot: !!foot,
    });
    if (!list || !foot) return;

    if (state.items.length === 0) {
      list.hidden = true;
      foot.hidden = true;
      list.innerHTML = "";
      return;
    }

    list.hidden = false;
    foot.hidden = false;
    console.log("[meal-modal] renderItems showing list/foot", {
      listHidden: list.hidden,
      footHidden: foot.hidden,
    });

    list.innerHTML = state.items
      .map((it, i) => {
        const protein = Number(it.protein_g) || 0;
        return `
          <div class="tk-item-row">
            <div class="tk-item-info">
              <span class="tk-item-name">${escapeHtml(it.name)}${
                it.name_zh ? ` · ${escapeHtml(it.name_zh)}` : ""
              }</span>
              <span class="tk-item-meta">${escapeHtml(it.portion_label || "")}</span>
            </div>
            <span class="tk-item-protein">${protein}g</span>
            <button class="tk-item-remove" type="button" data-remove-idx="${i}" aria-label="Remove">×</button>
          </div>
        `;
      })
      .join("");

    list.querySelectorAll<HTMLButtonElement>("[data-remove-idx]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const idx = Number(btn.dataset.removeIdx);
        if (!Number.isFinite(idx)) return;
        state.items.splice(idx, 1);
        renderItems();
      });
    });

    const totalEl = $("meal-total");
    if (totalEl) totalEl.textContent = String(totalProtein());

    const confirmBtn = $("meal-confirm") as HTMLButtonElement | null;
    if (confirmBtn) confirmBtn.disabled = state.items.length === 0;
  }

  function escapeHtml(s: string): string {
    return String(s).replace(/[&<>"']/g, (c) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;",
    }[c] as string));
  }

  // --- Food cache + search ----------------------------------------------------
  async function loadFoodCache(): Promise<FoodRow[]> {
    if (state.foodCache) return state.foodCache;
    const sb = (window as any).supabaseClient;
    if (!sb) return [];
    const { data, error } = await sb
      .from("food_database")
      .select("id, name, name_zh, category, portion_label, protein_per_portion, common_in_hk")
      .eq("active", true)
      .order("common_in_hk", { ascending: false })
      .order("name");
    if (error) {
      console.warn("food_database", error);
      return [];
    }
    state.foodCache = (data || []) as FoodRow[];
    return state.foodCache;
  }

  function filterFoods(rows: FoodRow[], q: string): FoodRow[] {
    const term = q.trim().toLowerCase();
    if (!term) {
      return rows.slice(0, 40);
    }
    return rows
      .filter((r) => {
        const n = r.name.toLowerCase();
        const z = (r.name_zh || "").toLowerCase();
        return n.includes(term) || z.includes(term);
      })
      .slice(0, 40);
  }

  function renderSearchResults(rows: FoodRow[]) {
    const wrap = $("meal-search-results");
    if (!wrap) return;
    if (!rows.length) {
      wrap.innerHTML = '<p class="tk-search-empty">No matches. Try another name.</p>';
      return;
    }
    wrap.innerHTML = rows
      .map(
        (r) => `
          <button class="tk-food-row" type="button" data-food-id="${r.id}">
            <div class="tk-food-info">
              <span class="tk-food-name">${escapeHtml(r.name)}${
                r.name_zh ? ` · ${escapeHtml(r.name_zh)}` : ""
              }</span>
              <span class="tk-food-meta">${escapeHtml(r.portion_label)}</span>
            </div>
            <span class="tk-food-protein">${Number(r.protein_per_portion)}g</span>
          </button>
        `
      )
      .join("");
  }

  async function showSearch() {
    setView("search");
    setMsg("");
    const input = $("meal-search-input") as HTMLInputElement | null;
    const results = $("meal-search-results");
    if (results) results.innerHTML = '<p class="tk-search-empty">Loading…</p>';
    const rows = await loadFoodCache();
    renderSearchResults(filterFoods(rows, input?.value || ""));
    setTimeout(() => input?.focus(), 30);
  }

  // --- Photo flow -------------------------------------------------------------
  function pickPhoto() {
    const input = $("meal-photo-input") as HTMLInputElement | null;
    if (!input) return;
    input.value = "";
    input.click();
  }

  async function handlePhoto(file: File) {
    setView("photo");
    setMsg("");

    const reader = new FileReader();
    const dataUrl: string = await new Promise((resolve) => {
      reader.onload = () => resolve(String(reader.result || ""));
      reader.readAsDataURL(file);
    });
    state.photoFile = file;
    state.photoDataUrl = dataUrl;

    const img = $("meal-photo-img") as HTMLImageElement | null;
    if (img) img.src = dataUrl;

    const status = $("meal-analyze-status");
    if (status) {
      status.textContent = "Analyzing…";
      status.className = "tk-analyze-status";
    }

    try {
      const result = await analyzeMealPhoto(file);
      // Replace items with AI result (user can still edit / add more).
      state.items = result.items.slice();
      renderItems();
      if (status) {
        if (result.mock) {
          status.textContent = result.notice || "Mock analysis — adjust as needed";
          status.className = "tk-analyze-status mock";
        } else {
          status.textContent = "Adjust if needed, then confirm";
          status.className = "tk-analyze-status";
        }
      }
    } catch (err: any) {
      console.error("analyze", err);
      if (status) {
        status.textContent = "Could not analyze photo. Search foods manually.";
        status.className = "tk-analyze-status error";
      }
    }
  }

  // --- Confirm + upload + save ------------------------------------------------
  async function uploadPhoto(userId: string, slotKey: string, dateISO: string): Promise<string | null> {
    if (!state.photoFile) return null;
    const sb = (window as any).supabaseClient;
    if (!sb) return null;

    const ext = (state.photoFile.type.split("/")[1] || "jpg").replace("jpeg", "jpg");
    const path = `${userId}/${dateISO}/${slotKey}.${ext}`;

    try {
      const { error } = await sb.storage
        .from("meal-photos")
        .upload(path, state.photoFile, {
          upsert: true,
          contentType: state.photoFile.type || "image/jpeg",
        });
      if (error) {
        console.warn("storage upload", error);
        return null;
      }
      return path;
    } catch (e) {
      console.warn("storage upload threw", e);
      return null;
    }
  }

  async function confirmMeal() {
    if (state.items.length === 0) return;
    const btn = $("meal-confirm") as HTMLButtonElement | null;
    if (btn) btn.disabled = true;
    setMsg("Saving…");

    try {
      const sb = (window as any).supabaseClient;
      if (!sb) throw new Error("Supabase not available");

      const { data: { user } } = await sb.auth.getUser();
      if (!user) throw new Error("Not signed in");

      const dateISO = new Date().toISOString().slice(0, 10);
      const photoPath = await uploadPhoto(user.id, state.slotKey || "meal", dateISO);

      const total = totalProtein();
      const foodItems = state.items.map((it) => ({
        name: it.name,
        name_zh: it.name_zh || "",
        portion_label: it.portion_label,
        protein_g: Number(it.protein_g) || 0,
        confidence: typeof it.confidence === "number" ? it.confidence : 1,
      }));

      const { error } = await sb.from("meal_logs").upsert(
        {
          user_id: user.id,
          meal_slot: state.slotKey,
          logged_date: dateISO,
          photo_url: photoPath,
          food_items: foodItems,
          total_protein_g: total,
        },
        { onConflict: "user_id,meal_slot,logged_date" }
      );
      if (error) throw error;

      setMsg("Saved", "success");
      window.dispatchEvent(
        new CustomEvent("meal-logged", {
          detail: {
            slot: state.slotKey,
            total,
            items: foodItems,
            photo_url: photoPath,
          },
        })
      );

      setTimeout(closeModal, 400);
    } catch (err: any) {
      console.error("confirm meal", err);
      setMsg(err?.message || "Could not save meal", "error");
      if (btn) btn.disabled = false;
    }
  }

  // --- Open / close -----------------------------------------------------------
  function resetState() {
    state.items = [];
    state.photoFile = null;
    state.photoDataUrl = null;
    const img = $("meal-photo-img") as HTMLImageElement | null;
    if (img) img.src = "";
    const input = $("meal-search-input") as HTMLInputElement | null;
    if (input) input.value = "";
    const results = $("meal-search-results");
    if (results) results.innerHTML = "";
    setMsg("");
    renderItems();
  }

  function openModal(slotKey: string, slotLabel: string, prefill?: AnalyzedItem[]) {
    const m = modal();
    if (!m) return;
    resetState();
    state.open = true;
    state.slotKey = slotKey;
    state.slotLabel = slotLabel;

    const title = $("meal-modal-title");
    if (title) title.textContent = `Log · ${slotLabel}`;

    if (prefill && prefill.length) {
      state.items = prefill.map((it) => ({ ...it }));
      renderItems();
      // Skip choice screen — go straight to search so user can add more.
      setView("search");
      const status = $("meal-search-results");
      if (status) status.innerHTML = "";
      loadFoodCache().then((rows) => renderSearchResults(filterFoods(rows, "")));
    } else {
      setView("choice");
    }

    m.hidden = false;
    m.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    const m = modal();
    if (!m) return;
    m.hidden = true;
    m.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
    state.open = false;
  }

  function wireModal() {
    const m = modal();
    if (!m) return;

    document.querySelectorAll<HTMLElement>("#meal-modal [data-meal-modal-close]").forEach((el) => {
      el.addEventListener("click", closeModal);
    });

    $("meal-photo-cta")?.addEventListener("click", pickPhoto);
    $("meal-search-cta")?.addEventListener("click", showSearch);

    $("meal-add-more")?.addEventListener("click", showSearch);
    $("meal-confirm")?.addEventListener("click", confirmMeal);

    const photoInput = $("meal-photo-input") as HTMLInputElement | null;
    photoInput?.addEventListener("change", () => {
      const f = photoInput.files?.[0];
      if (f) handlePhoto(f);
    });

    const uploadInput = $("meal-upload-input") as HTMLInputElement | null;
    $("meal-upload-cta")?.addEventListener("click", () => {
      if (!uploadInput) return;
      uploadInput.value = "";
      uploadInput.click();
    });
    uploadInput?.addEventListener("change", () => {
      const f = uploadInput.files?.[0];
      if (f) handlePhoto(f);
    });

    const searchInput = $("meal-search-input") as HTMLInputElement | null;
    let searchTimer: number | null = null;
    searchInput?.addEventListener("input", () => {
      if (searchTimer) window.clearTimeout(searchTimer);
      searchTimer = window.setTimeout(async () => {
        const rows = await loadFoodCache();
        renderSearchResults(filterFoods(rows, searchInput.value));
      }, 120);
    });

    const searchResults = $("meal-search-results");
    console.log("[meal-modal] wireModal: searchResults found?", !!searchResults);
    searchResults?.addEventListener("click", (e) => {
      const target = e.target as HTMLElement | null;
      console.log("[meal-modal] search-results click", { target: target?.tagName, classes: target?.className });
      const btn = target?.closest<HTMLButtonElement>(".tk-food-row");
      console.log("[meal-modal] closest tk-food-row", { found: !!btn, dataFoodId: btn?.dataset.foodId });
      if (!btn) return;
      const id = Number(btn.dataset.foodId);
      const row = (state.foodCache || []).find((r) => r.id === id);
      console.log("[meal-modal] row lookup", { id, found: !!row, cacheSize: state.foodCache?.length || 0 });
      if (!row) return;
      state.items.push({
        name: row.name,
        name_zh: row.name_zh || "",
        portion_label: row.portion_label,
        protein_g: Number(row.protein_per_portion) || 0,
        confidence: 1,
      });
      console.log("[meal-modal] item pushed, total items:", state.items.length);
      renderItems();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && state.open) closeModal();
    });
  }

  // Expose to global scope for tracker.astro to invoke.
  (window as any).openMealLog = openModal;
  (window as any).closeMealLog = closeModal;

  wireModal();
</script>
