---
// Header.astro — Site header with CSS-only dropdown on hover
export interface Props {
  lang?: string;
}
const { lang = "en" } = Astro.props;
---

<header class="site-header">
  <div class="container header-inner">
    <a href={import.meta.env.BASE_URL} class="logo" aria-label="RISE Advancement Home">
      <img src="/logo-header.png" alt="RISE Advancement" class="logo-img" />
    </a>

    <nav class="nav-desktop" aria-label="Main navigation">
      <a href={lang === "zh" ? "/zh/#how-it-works" : "/#how-it-works"}>
        {lang === "zh" ? "流程" : "How It Works"}
      </a>

      <div class="nav-dropdown">
        <button type="button" class="nav-dropdown-trigger" aria-haspopup="true">
          {lang === "zh" ? "服務" : "Services"}
          <svg class="dropdown-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 1l4 4 4-4"/></svg>
        </button>
        <div class="nav-dropdown-menu">
          {lang === "zh" ? (
            <>
              <a href="/zh/services/the-move">
                <span class="dropdown-label">球員安置</span>
                <span class="dropdown-desc">全面安置到加拿大</span>
              </a>
              <a href="/zh/services/mentoring">
                <span class="dropdown-label">訓練指導</span>
                <span class="dropdown-desc">賽季發展計劃</span>
              </a>
              <a href="/zh/services/hk-program">
                <span class="dropdown-label">香港體能訓練</span>
                <span class="dropdown-desc">2026 夏季計劃</span>
              </a>
            </>
          ) : (
            <>
              <a href="/services/the-move">
                <span class="dropdown-label">The Move</span>
                <span class="dropdown-desc">Full placement to Canada</span>
              </a>
              <a href="/services/mentoring">
                <span class="dropdown-label">Mentoring</span>
                <span class="dropdown-desc">Season-long development</span>
              </a>
              <a href="/services/hk-program">
                <span class="dropdown-label">HK Program</span>
                <span class="dropdown-desc">Summer 2026 training</span>
              </a>
            </>
          )}
        </div>
      </div>

      <a href={lang === "zh" ? "/zh/why-us" : "/why-us"}>
        {lang === "zh" ? "為什麼我們" : "Why RISE"}
      </a>
      <a href={lang === "zh" ? "/zh/#faq" : "/#faq"}>
        {lang === "zh" ? "常見問題" : "FAQ"}
      </a>
      <a href={lang === "zh" ? "/zh/#contact" : "/#contact"}>
        {lang === "zh" ? "聯繫我們" : "Contact"}
      </a>
    </nav>

    <div class="header-actions">
      <button class="auth-login-btn" type="button" data-open-auth data-auth-anon hidden>
        {lang === "zh" ? "登入" : "Log in"}
      </button>

      <div class="user-menu" data-auth-user hidden>
        <button class="user-menu-trigger" type="button" id="user-menu-btn" aria-haspopup="true" aria-expanded="false">
          <span class="user-avatar" id="user-avatar">?</span>
          <span class="user-name" id="user-name-label"></span>
          <svg class="user-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 1l4 4 4-4"/></svg>
        </button>
        <div class="user-menu-panel" id="user-menu-panel" hidden>
          <a href="/portal" class="user-menu-item">{lang === "zh" ? "我的入口" : "My Portal"}</a>
          <a href="/portal/tracker" class="user-menu-item">{lang === "zh" ? "營養追蹤" : "Nutrition Tracker"}</a>
          <button type="button" class="user-menu-item logout" id="header-logout-btn">{lang === "zh" ? "登出" : "Log out"}</button>
        </div>
      </div>

      {lang === "zh" ? (
        <a href={import.meta.env.BASE_URL} class="lang-toggle"><span class="sr-only">Switch to </span>EN</a>
      ) : (
        <a href={`${import.meta.env.BASE_URL}zh/`} class="lang-toggle"><span class="sr-only">Switch to </span>中文</a>
      )}

      <button class="hamburger" id="hamburger-btn" aria-label="Open menu" aria-expanded="false" type="button">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>

  <nav class="nav-mobile" id="mobile-nav" aria-label="Mobile navigation" hidden>
    <a href={lang === "zh" ? "/zh/#how-it-works" : "/#how-it-works"}>
      {lang === "zh" ? "流程" : "How It Works"}
    </a>
    <div class="mobile-section-label">{lang === "zh" ? "服務" : "Services"}</div>
    {lang === "zh" ? (
      <>
        <a href="/zh/services/the-move" class="mobile-sub">球員安置</a>
        <a href="/zh/services/mentoring" class="mobile-sub">訓練指導</a>
        <a href="/zh/services/hk-program" class="mobile-sub">香港體能訓練</a>
      </>
    ) : (
      <>
        <a href="/services/the-move" class="mobile-sub">The Move</a>
        <a href="/services/mentoring" class="mobile-sub">Mentoring</a>
        <a href="/services/hk-program" class="mobile-sub">HK Program</a>
      </>
    )}
    <a href={lang === "zh" ? "/zh/why-us" : "/why-us"}>
      {lang === "zh" ? "為什麼我們" : "Why RISE"}
    </a>
    <a href={lang === "zh" ? "/zh/#faq" : "/#faq"}>
      {lang === "zh" ? "常見問題" : "FAQ"}
    </a>
    <a href={lang === "zh" ? "/zh/#contact" : "/#contact"}>
      {lang === "zh" ? "聯繫我們" : "Contact"}
    </a>
    <button class="mobile-auth-btn" type="button" data-open-auth data-auth-anon hidden>
      {lang === "zh" ? "登入" : "Log in"}
    </button>
    <div class="mobile-auth-user" data-auth-user hidden>
      <a href="/portal" class="mobile-sub">{lang === "zh" ? "我的入口" : "My Portal"}</a>
      <a href="/portal/tracker" class="mobile-sub">{lang === "zh" ? "營養追蹤" : "Nutrition Tracker"}</a>
      <button type="button" class="mobile-logout" id="mobile-logout-btn">{lang === "zh" ? "登出" : "Log out"}</button>
    </div>

    {lang === "zh" ? (
      <a href={import.meta.env.BASE_URL} class="mobile-lang">EN</a>
    ) : (
      <a href={`${import.meta.env.BASE_URL}zh/`} class="mobile-lang">中文</a>
    )}
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--rise-white);
    border-bottom: 1px solid var(--rise-neutral-100);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 6rem;
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo:hover { text-decoration: none; }

  .logo-img {
    height: 70px;
    width: auto;
    display: block;
    padding: 8px 0;
  }

  @media (max-width: 639px) {
    .logo-img {
      height: 60px;
    }
  }

  .nav-desktop { display: none; }

  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
      align-items: center;
      gap: var(--space-6);
    }

    .nav-desktop > a,
    .nav-dropdown-trigger {
      font-family: var(--font-body);
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--rise-neutral-700);
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      padding: 0.75rem 0.5rem;
      min-height: 44px;
      border-bottom: 2px solid transparent;
      transition: color 0.2s, border-color 0.2s;
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      background: none;
      border-top: none;
      border-left: none;
      border-right: none;
      cursor: pointer;
    }

    .nav-desktop > a:hover,
    .nav-dropdown-trigger:hover {
      color: var(--rise-red);
      border-bottom-color: var(--rise-red);
      text-decoration: none;
    }
  }

  /* CSS-only dropdown on hover */
  .nav-dropdown { position: relative; }

  .dropdown-chevron {
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-dropdown:hover .dropdown-chevron {
    transform: rotate(180deg);
  }

  .nav-dropdown-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(-4px);
    background-color: var(--rise-white);
    border: 1px solid var(--rise-neutral-100);
    border-radius: 6px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08), 0 2px 8px rgba(0, 0, 0, 0.04);
    min-width: 220px;
    z-index: 200;
    display: flex;
    flex-direction: column;
    padding: var(--space-2) 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s cubic-bezier(0.4, 0, 0.2, 1), transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-dropdown:hover .nav-dropdown-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  /* Invisible bridge between trigger and menu */
  .nav-dropdown-menu::before {
    content: "";
    position: absolute;
    top: -12px;
    left: 0;
    right: 0;
    height: 12px;
  }

  .nav-dropdown-menu a {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-family: var(--font-body);
    text-decoration: none;
    padding: var(--space-3) var(--space-4);
    transition: background-color 0.15s;
  }

  .nav-dropdown-menu a:hover {
    background-color: var(--rise-neutral-50);
    text-decoration: none;
  }

  .dropdown-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--rise-black);
  }

  .nav-dropdown-menu a:hover .dropdown-label {
    color: var(--rise-red);
  }

  .dropdown-desc {
    font-size: 0.75rem;
    color: var(--rise-neutral-400);
    font-weight: 400;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .lang-toggle {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--rise-neutral-500);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--rise-neutral-200);
    border-radius: 4px;
    transition: all 0.2s;
  }

  .lang-toggle:hover {
    color: var(--rise-red);
    border-color: var(--rise-red);
    text-decoration: none;
  }

  .hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  @media (min-width: 768px) { .hamburger { display: none; } }

  .hamburger-line {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--rise-black);
    border-radius: 1px;
  }

  .nav-mobile {
    background-color: var(--rise-white);
    border-bottom: 1px solid var(--rise-neutral-100);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .nav-mobile[hidden] { display: none; }

  .nav-mobile a {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    color: var(--rise-neutral-700);
    text-decoration: none;
    padding: var(--space-2) var(--space-4);
    border-radius: 4px;
    transition: background-color 0.2s, color 0.2s;
  }

  .nav-mobile a:hover {
    background-color: var(--rise-neutral-50);
    color: var(--rise-red);
    text-decoration: none;
  }

  .mobile-section-label {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--rise-neutral-400);
    padding: var(--space-3) var(--space-4) var(--space-1);
  }

  .mobile-sub {
    padding-left: var(--space-8) !important;
    font-size: 0.9375rem !important;
  }

  .mobile-lang {
    border-top: 1px solid var(--rise-neutral-100);
    margin-top: var(--space-2);
    padding-top: var(--space-3) !important;
  }

  /* ===== Auth button (desktop) ===== */
  .auth-login-btn {
    display: none;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--rise-white);
    background: var(--rise-red);
    border: 1px solid var(--rise-red);
    border-radius: 6px;
    padding: 0.5rem 1rem;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .auth-login-btn:hover {
    background: var(--rise-red-dark);
    border-color: var(--rise-red-dark);
  }
  .auth-login-btn[hidden] { display: none !important; }

  @media (min-width: 768px) {
    .auth-login-btn:not([hidden]) { display: inline-flex; }
  }

  /* ===== User menu (desktop) ===== */
  .user-menu {
    position: relative;
    display: none;
  }
  .user-menu[hidden] { display: none !important; }

  @media (min-width: 768px) {
    .user-menu:not([hidden]) { display: inline-flex; }
  }

  .user-menu-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    border: 1px solid var(--rise-neutral-200);
    border-radius: 6px;
    padding: 0.35rem 0.75rem 0.35rem 0.35rem;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--rise-neutral-700);
    transition: border-color 0.15s, color 0.15s;
  }
  .user-menu-trigger:hover {
    border-color: var(--rise-red);
    color: var(--rise-red);
  }
  .user-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--rise-red);
    color: var(--rise-white);
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
  }
  .user-name {
    max-width: 120px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .user-chevron {
    transition: transform 0.2s;
  }
  .user-menu-trigger[aria-expanded="true"] .user-chevron {
    transform: rotate(180deg);
  }

  .user-menu-panel {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 200px;
    background: var(--rise-white);
    border: 1px solid var(--rise-neutral-100);
    border-radius: 6px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08), 0 2px 8px rgba(0, 0, 0, 0.04);
    z-index: 200;
    padding: var(--space-2) 0;
    display: flex;
    flex-direction: column;
  }
  .user-menu-panel[hidden] { display: none; }

  .user-menu-item {
    display: block;
    text-align: left;
    background: transparent;
    border: 0;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--rise-neutral-700);
    text-decoration: none;
    padding: var(--space-3) var(--space-4);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    width: 100%;
  }
  .user-menu-item:hover {
    background: var(--rise-neutral-50);
    color: var(--rise-red);
    text-decoration: none;
  }
  .user-menu-item.logout {
    border-top: 1px solid var(--rise-neutral-100);
    margin-top: var(--space-1);
    padding-top: var(--space-3);
    color: var(--rise-neutral-500);
  }

  /* ===== Mobile auth ===== */
  .mobile-auth-btn {
    display: block;
    margin: var(--space-3) var(--space-4) var(--space-2);
    padding: 0.75rem 1rem;
    background: var(--rise-red);
    color: var(--rise-white);
    border: 0;
    border-radius: 6px;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    text-align: center;
  }
  .mobile-auth-btn[hidden] { display: none !important; }

  .mobile-auth-user[hidden] { display: none; }
  .mobile-auth-user {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--rise-neutral-100);
    margin-top: var(--space-2);
    padding-top: var(--space-2);
  }
  .mobile-logout {
    text-align: left;
    background: transparent;
    border: 0;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    color: var(--rise-neutral-500);
    padding: var(--space-2) var(--space-4);
    cursor: pointer;
    border-radius: 4px;
    transition: background 0.15s, color 0.15s;
  }
  .mobile-logout:hover {
    background: var(--rise-neutral-50);
    color: var(--rise-red);
  }
</style>


<script>
  import "../lib/header-auth";
</script>
