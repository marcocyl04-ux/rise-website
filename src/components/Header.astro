---
// Header.astro — Site header with animated Services dropdown
export interface Props {
  lang?: string;
}
const { lang = "en" } = Astro.props;
---

<header class="site-header">
  <div class="container header-inner">
    <a href={import.meta.env.BASE_URL} class="logo" aria-label="RISE Advancement Home">
      <span class="logo-text">RISE</span>
      <span class="logo-subtext">Advancement</span>
    </a>

    <nav class="nav-desktop" aria-label="Main navigation">
      <a href={lang === "zh" ? "/zh/#how-it-works" : "/#how-it-works"}>
        {lang === "zh" ? "流程" : "How It Works"}
      </a>

      <div class="nav-dropdown">
        <button class="nav-dropdown-trigger" aria-expanded="false" aria-haspopup="true">
          {lang === "zh" ? "服務" : "Services"}
          <svg class="dropdown-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 1l4 4 4-4"/></svg>
        </button>
        <div class="nav-dropdown-menu" hidden>
          {lang === "zh" ? (
            <>
              <a href="/zh/services/the-move">
                <span class="dropdown-label">球員安置</span>
                <span class="dropdown-desc">全面安置到加拿大</span>
              </a>
              <a href="/zh/services/mentoring">
                <span class="dropdown-label">訓練指導</span>
                <span class="dropdown-desc">賽季發展計劃</span>
              </a>
              <a href="/zh/services/hk-program">
                <span class="dropdown-label">香港體能訓練</span>
                <span class="dropdown-desc">2026 夏季計劃</span>
              </a>
            </>
          ) : (
            <>
              <a href="/services/the-move">
                <span class="dropdown-label">The Move</span>
                <span class="dropdown-desc">Full placement to Canada</span>
              </a>
              <a href="/services/mentoring">
                <span class="dropdown-label">Mentoring</span>
                <span class="dropdown-desc">Season-long development</span>
              </a>
              <a href="/services/hk-program">
                <span class="dropdown-label">HK Program</span>
                <span class="dropdown-desc">Summer 2026 training</span>
              </a>
            </>
          )}
        </div>
      </div>

      <a href={lang === "zh" ? "/zh/#faq" : "/#faq"}>
        {lang === "zh" ? "常見問題" : "FAQ"}
      </a>
      <a href={lang === "zh" ? "/zh/#contact" : "/#contact"}>
        {lang === "zh" ? "聯繫我們" : "Contact"}
      </a>
    </nav>

    <div class="header-actions">
      {lang === "zh" ? (
        <a href={import.meta.env.BASE_URL} class="lang-toggle" aria-label="Switch to English">EN</a>
      ) : (
        <a href={`${import.meta.env.BASE_URL}zh/`} class="lang-toggle" aria-label="Switch to Chinese">中文</a>
      )}

      <button class="hamburger" id="hamburger-btn" aria-label="Open menu" aria-expanded="false" type="button">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>

  <nav class="nav-mobile" id="mobile-nav" aria-label="Mobile navigation" hidden>
    <a href={lang === "zh" ? "/zh/#how-it-works" : "/#how-it-works"}>
      {lang === "zh" ? "流程" : "How It Works"}
    </a>
    <div class="mobile-section-label">{lang === "zh" ? "服務" : "Services"}</div>
    {lang === "zh" ? (
      <>
        <a href="/zh/services/the-move" class="mobile-sub">球員安置</a>
        <a href="/zh/services/mentoring" class="mobile-sub">訓練指導</a>
        <a href="/zh/services/hk-program" class="mobile-sub">香港體能訓練</a>
      </>
    ) : (
      <>
        <a href="/services/the-move" class="mobile-sub">The Move</a>
        <a href="/services/mentoring" class="mobile-sub">Mentoring</a>
        <a href="/services/hk-program" class="mobile-sub">HK Program</a>
      </>
    )}
    <a href={lang === "zh" ? "/zh/#faq" : "/#faq"}>
      {lang === "zh" ? "常見問題" : "FAQ"}
    </a>
    <a href={lang === "zh" ? "/zh/#contact" : "/#contact"}>
      {lang === "zh" ? "聯繫我們" : "Contact"}
    </a>
    {lang === "zh" ? (
      <a href={import.meta.env.BASE_URL} class="mobile-lang">EN</a>
    ) : (
      <a href={`${import.meta.env.BASE_URL}zh/`} class="mobile-lang">中文</a>
    )}
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--rise-white);
    border-bottom: 1px solid var(--rise-neutral-100);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }

  .logo {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    text-decoration: none;
    color: var(--rise-black);
    flex-shrink: 0;
  }

  .logo:hover { text-decoration: none; color: var(--rise-black); }

  .logo-text {
    font-family: var(--font-heading);
    font-size: 1.563rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--rise-red);
    letter-spacing: 0.02em;
  }

  .logo-subtext {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 500;
    text-transform: uppercase;
    color: var(--rise-neutral-500);
    letter-spacing: 0.04em;
  }

  /* Desktop nav */
  .nav-desktop { display: none; }

  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
      align-items: center;
      gap: var(--space-6);
    }

    .nav-desktop > a,
    .nav-dropdown-trigger {
      font-family: var(--font-body);
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--rise-neutral-700);
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      padding: 0.25rem 0;
      border: none;
      background: none;
      cursor: pointer;
      border-bottom: 2px solid transparent;
      transition: color 0.2s, border-color 0.2s;
      display: flex;
      align-items: center;
      gap: 0.35rem;
    }

    .nav-desktop > a:hover,
    .nav-dropdown-trigger:hover {
      color: var(--rise-red);
      border-bottom-color: var(--rise-red);
      text-decoration: none;
    }
  }

  /* Dropdown */
  .nav-dropdown { position: relative; }

  .dropdown-chevron {
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-dropdown.open .dropdown-chevron {
    transform: rotate(180deg);
  }

  .nav-dropdown-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(-4px);
    background-color: var(--rise-white);
    border: 1px solid var(--rise-neutral-100);
    border-radius: 6px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08), 0 2px 8px rgba(0, 0, 0, 0.04);
    min-width: 220px;
    z-index: 200;
    display: flex;
    flex-direction: column;
    padding: var(--space-2) 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s cubic-bezier(0.4, 0, 0.2, 1), transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-dropdown.open .nav-dropdown-menu {
    display: flex;
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  /* Invisible bridge so cursor doesn't lose hover between trigger and menu */
  .nav-dropdown-menu::before {
    content: "";
    position: absolute;
    top: -8px;
    left: 0;
    right: 0;
    height: 8px;
  }

  .nav-dropdown-menu a {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-family: var(--font-body);
    text-decoration: none;
    padding: var(--space-3) var(--space-4);
    transition: background-color 0.15s;
  }

  .nav-dropdown-menu a:hover {
    background-color: var(--rise-neutral-50);
    text-decoration: none;
  }

  .dropdown-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--rise-black);
  }

  .nav-dropdown-menu a:hover .dropdown-label {
    color: var(--rise-red);
  }

  .dropdown-desc {
    font-size: 0.75rem;
    color: var(--rise-neutral-400);
    font-weight: 400;
  }

  /* Header actions */
  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .lang-toggle {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--rise-neutral-500);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--rise-neutral-200);
    border-radius: 4px;
    transition: all 0.2s;
  }

  .lang-toggle:hover {
    color: var(--rise-red);
    border-color: var(--rise-red);
    text-decoration: none;
  }

  /* Hamburger */
  .hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  @media (min-width: 768px) { .hamburger { display: none; } }

  .hamburger-line {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--rise-black);
    border-radius: 1px;
    transition: transform 0.2s, opacity 0.2s;
  }

  /* Mobile nav */
  .nav-mobile {
    background-color: var(--rise-white);
    border-bottom: 1px solid var(--rise-neutral-100);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .nav-mobile[hidden] { display: none; }

  .nav-mobile a {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    color: var(--rise-neutral-700);
    text-decoration: none;
    padding: var(--space-2) var(--space-4);
    border-radius: 4px;
    transition: background-color 0.2s, color 0.2s;
  }

  .nav-mobile a:hover {
    background-color: var(--rise-neutral-50);
    color: var(--rise-red);
    text-decoration: none;
  }

  .mobile-section-label {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--rise-neutral-400);
    padding: var(--space-3) var(--space-4) var(--space-1);
  }

  .mobile-sub {
    padding-left: var(--space-8) !important;
    font-size: 0.9375rem !important;
  }

  .mobile-lang {
    border-top: 1px solid var(--rise-neutral-100);
    margin-top: var(--space-2);
    padding-top: var(--space-3) !important;
  }
</style>

<script>
  // Mobile hamburger
  const btn = document.getElementById("hamburger-btn");
  const nav = document.getElementById("mobile-nav");

  btn?.addEventListener("click", () => {
    const isOpen = nav?.hasAttribute("hidden") === false;
    if (isOpen) {
      nav?.setAttribute("hidden", "");
      btn.setAttribute("aria-expanded", "false");
    } else {
      nav?.removeAttribute("hidden");
      btn.setAttribute("aria-expanded", "true");
    }
  });

  // Desktop dropdown — hover + click
  const dropdown = document.querySelector(".nav-dropdown");
  const trigger = dropdown?.querySelector(".nav-dropdown-trigger");
  let hoverTimeout: ReturnType<typeof setTimeout>;

  function openDropdown() {
    clearTimeout(hoverTimeout);
    menu?.removeAttribute("hidden");
    dropdown?.classList.add("open");
    trigger?.setAttribute("aria-expanded", "true");
  }

  function closeDropdown() {
    hoverTimeout = setTimeout(() => {
      dropdown?.classList.remove("open");
      menu?.setAttribute("hidden", "");
      trigger?.setAttribute("aria-expanded", "false");
    }, 150);
  }

  // Hover open
  dropdown?.addEventListener("mouseenter", openDropdown);
  dropdown?.addEventListener("mouseleave", closeDropdown);

  // Click toggle
  trigger?.addEventListener("click", () => {
    const isOpen = dropdown?.classList.contains("open");
    if (isOpen) closeDropdown();
    else openDropdown();
  });

  // Close on outside click
  document.addEventListener("click", (e) => {
    if (dropdown && !dropdown.contains(e.target as Node)) {
      dropdown.classList.remove("open");
      menu?.setAttribute("hidden", "");
      trigger?.setAttribute("aria-expanded", "false");
    }
  });

  // Close on Escape
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      dropdown?.classList.remove("open");
      menu?.setAttribute("hidden", "");
      trigger?.setAttribute("aria-expanded", "false");
    }
  });
</script>
