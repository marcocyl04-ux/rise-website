---
// MarketingLayout.astro — Dark theme layout for marketing sub-pages
// Used by services, why-us, zh variants. NOT for portal.
import "../styles/global.css";
import "../styles/homepage.css";
import "../styles/marketing-pages.css";
import HomeNav from "../components/home/HomeNav.astro";
import FloatingWhatsApp from "../components/FloatingWhatsApp.astro";
import AuthModal from "../components/AuthModal.astro";

export interface Props {
  title: string;
  description?: string;
  lang?: string;
  ogImage?: string;
}

const {
  title,
  description = "RISE Advancement — Elite hockey player development and placement. Hong Kong / Canada.",
  lang = "en",
  ogImage = "/og-image.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, "https://riseadvancement.com");
const ogImageURL = new URL(ogImage, "https://riseadvancement.com");
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={`${title} | RISE Advancement`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:locale" content={lang === "zh" ? "zh_HK" : "en_US"} />
    <meta property="og:site_name" content="RISE Advancement" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | RISE Advancement`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />
    <link rel="canonical" href={canonicalURL.href} />

    <link rel="icon" type="image/png" href="/favicon.png?v=2" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png?v=2" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0a0a0a" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Oswald:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- GSAP for scroll animations on sub-pages -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

    <title>{title} | RISE Advancement</title>

    <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script is:inline define:vars={{
      SUPABASE_URL: "https://zeczlwypqqvvpraosodv.supabase.co",
      SUPABASE_ANON_KEY: "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InplY3psd3lwcXF2dnByYW9zb2R2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkzNDEyMDgsImV4cCI6MjA5NDkxNzIwOH0.I7HWRsBOXDH2UG0u6NMEkXlosrlkuMkY6w9g5RtV_KM"
    }}>
      (function () {
        if (window.supabaseClient) return;
        if (!window.supabase) return;
        window.supabaseClient = window.supabase.createClient(
          SUPABASE_URL,
          SUPABASE_ANON_KEY,
          { auth: { persistSession: true, autoRefreshToken: true, detectSessionInUrl: true } }
        );
      })();
    </script>
  </head>
  <body class="home-dark">
    <HomeNav />

    <main>
      <slot />
    </main>

    <!-- Footer (dark) -->
    <footer class="hp-footer">
      <div class="hp-footer__grid">
        <div class="hp-footer__brand">
          <img src="https://riseadvancement.com/logo-header.png" alt="RISE Advancement" style="height:32px;width:auto;opacity:0.4;filter:brightness(0) invert(1);" />
          <p>Hockey player development and placement. Hong Kong to Canada. Founded by players who lived the pipeline.</p>
        </div>
        <div>
          <h4>Links</h4>
          <ul>
            <li><a href="/#how-it-works">How It Works</a></li>
            <li><a href="/#services">Services</a></li>
            <li><a href="/#players">Players</a></li>
            <li><a href="/#faq">FAQ</a></li>
            <li><a href="/#contact">Contact</a></li>
          </ul>
        </div>
        <div>
          <h4>Contact</h4>
          <ul>
            <li><a href="mailto:riseadvancements@gmail.com">riseadvancements@gmail.com</a></li>
            <li><a href="tel:+852****0387">+852 9095 0387</a></li>
            <li>WeChat: RISE-Advancement</li>
          </ul>
        </div>
        <div>
          <h4>Follow</h4>
          <ul>
            <li><a href="https://instagram.com/riseadvancement">Instagram</a></li>
            <li><a href="https://facebook.com/riseadvancement">Facebook</a></li>
          </ul>
        </div>
      </div>
      <div class="hp-footer__bottom">
        <p>&copy; 2026 RISE Advancement. All rights reserved.</p>
      </div>
    </footer>

    <FloatingWhatsApp lang={lang} />
    <AuthModal />

    <script is:inline>
      // Nav scroll effect
      (function() {
        var nav = document.getElementById('hp-nav');
        if (!nav) return;
        window.addEventListener('scroll', function() {
          nav.classList.toggle('scrolled', window.scrollY > 80);
        }, { passive: true });

        // Simple fade-in animations
        gsap.registerPlugin(ScrollTrigger);
        gsap.utils.toArray('.mpg-section, .mpg-surface, .mpg-interlude, .mpg-cta').forEach(function(el) {
          gsap.from(el.children, {
            opacity: 0, y: 30, duration: 0.6, ease: 'power3.out', stagger: 0.1,
            immediateRender: false,
            scrollTrigger: { trigger: el, start: 'top 80%' }
          });
        });
      })();
    </script>
  </body>
</html>
