---
// BaseLayout.astro — HTML shell with meta tags, font loading, header/footer slots
import "../styles/global.css";
import FloatingWhatsApp from "../components/FloatingWhatsApp.astro";

export interface Props {
  title: string;
  description?: string;
  lang?: string;
  ogImage?: string;
}

const {
  title,
  description = "RISE Advancement — Elite hockey player development and placement. Hong Kong / Canada.",
  lang = "en",
  ogImage = "/og-image.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, "https://riseadvancement.com");
const ogImageURL = new URL(ogImage, "https://riseadvancement.com");
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / WhatsApp / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={`${title} | RISE Advancement`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:locale" content={lang === "zh" ? "zh_HK" : "en_US"} />
    <meta property="og:site_name" content="RISE Advancement" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | RISE Advancement`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" href="/favicon.ico" />

    <!-- Google Fonts: Oswald (headings) + Inter (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;1,14..32,400&family=Oswald:wght@500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title} | RISE Advancement</title>
  </head>
  <body>
    <slot name="header" />

    <main>
      <slot />
    </main>

    <slot name="footer" />

    <FloatingWhatsApp lang={lang} />
  </body>
</html>
