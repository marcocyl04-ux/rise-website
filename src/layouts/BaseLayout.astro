---
// BaseLayout.astro — HTML shell with meta tags, font loading, header/footer slots
import "../styles/global.css";
import FloatingWhatsApp from "../components/FloatingWhatsApp.astro";
import AuthModal from "../components/AuthModal.astro";

export interface Props {
  title: string;
  description?: string;
  lang?: string;
  ogImage?: string;
}

const {
  title,
  description = "RISE Advancement — Elite hockey player development and placement. Hong Kong / Canada.",
  lang = "en",
  ogImage = "/og-image.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, "https://riseadvancement.com");
const ogImageURL = new URL(ogImage, "https://riseadvancement.com");
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / WhatsApp / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={`${title} | RISE Advancement`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:locale" content={lang === "zh" ? "zh_HK" : "en_US"} />
    <meta property="og:site_name" content="RISE Advancement" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | RISE Advancement`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}favicon.png?v=2`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${import.meta.env.BASE_URL}favicon-32.png?v=2`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}apple-touch-icon.png?v=2`} />
    <link rel="icon" href="/favicon.ico" />

    <!-- Google Fonts: Oswald (headings) + Inter (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;1,14..32,400&family=Oswald:wght@500;600;700&display=block"
      rel="stylesheet"
    />

    <title>{title} | RISE Advancement</title>

    <!-- Supabase JS v2 (for auth + portal) -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script is:inline define:vars={{
      SUPABASE_URL: "https://zeczlwypqqvvpraosodv.supabase.co",
      SUPABASE_ANON_KEY: "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InplY3psd3lwcXF2dnByYW9zb2R2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkzNDEyMDgsImV4cCI6MjA5NDkxNzIwOH0.I7HWRsBOXDH2UG0u6NMEkXlosrlkuMkY6w9g5RtV_KM"
    }}>
      // Initialize the Supabase client once, attach to window.
      (function () {
        if (window.supabaseClient) return;
        if (!window.supabase) return;
        window.supabaseClient = window.supabase.createClient(
          SUPABASE_URL,
          SUPABASE_ANON_KEY,
          {
            auth: {
              persistSession: true,
              autoRefreshToken: true,
              detectSessionInUrl: true,
            },
          }
        );
      })();
    </script>
  </head>
  <body>
    <slot name="header" />

    <main>
      <slot />
    </main>

    <slot name="footer" />

    <FloatingWhatsApp lang={lang} />
    <AuthModal />
  </body>
</html>
