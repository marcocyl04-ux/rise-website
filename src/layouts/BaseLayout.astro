---
// BaseLayout.astro — HTML shell with meta tags, font loading, header/footer slots
import "../styles/global.css";
import FloatingWhatsApp from "../components/FloatingWhatsApp.astro";
import AuthModal from "../components/AuthModal.astro";

export interface Props {
  title: string;
  description?: string;
  lang?: string;
  ogImage?: string;
}

const {
  title,
  description = "RISE Advancement — Elite hockey player development and placement. Hong Kong / Canada.",
  lang = "en",
  ogImage = "/og-image.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, "https://riseadvancement.com");
const ogImageURL = new URL(ogImage, "https://riseadvancement.com");
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / WhatsApp / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={`${title} | RISE Advancement`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:locale" content={lang === "zh" ? "zh_HK" : "en_US"} />
    <meta property="og:site_name" content="RISE Advancement" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | RISE Advancement`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}favicon.png?v=2`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${import.meta.env.BASE_URL}favicon-32.png?v=2`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}apple-touch-icon.png?v=2`} />
    <link rel="icon" href="/favicon.ico" />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#D3191F" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="RISE" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Google Fonts: Oswald (headings) + Inter (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;1,14..32,400&family=Oswald:wght@500;600;700&display=block"
      rel="stylesheet"
    />

    <title>{title} | RISE Advancement</title>

    <!-- Supabase JS v2 (for auth + portal) -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script is:inline define:vars={{
      SUPABASE_URL: "https://zeczlwypqqvvpraosodv.supabase.co",
      SUPABASE_ANON_KEY: "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InplY3psd3lwcXF2dnByYW9zb2R2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkzNDEyMDgsImV4cCI6MjA5NDkxNzIwOH0.I7HWRsBOXDH2UG0u6NMEkXlosrlkuMkY6w9g5RtV_KM"
    }}>
      // Initialize the Supabase client once, attach to window.
      (function () {
        if (window.supabaseClient) return;
        if (!window.supabase) return;
        window.supabaseClient = window.supabase.createClient(
          SUPABASE_URL,
          SUPABASE_ANON_KEY,
          {
            auth: {
              persistSession: true,
              autoRefreshToken: true,
              detectSessionInUrl: true,
            },
          }
        );
      })();
    </script>
  </head>
  <body>
    <slot name="header" />

    <main>
      <slot />
    </main>

    <slot name="footer" />

    <FloatingWhatsApp lang={lang} />
    <AuthModal />

    <!-- PWA service worker registration -->
    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", function () {
          navigator.serviceWorker
            .register("/sw.js")
            .catch(function (err) {
              console.warn("[pwa] sw register failed:", err);
            });
        });
      }
    </script>

    <!-- PWA install banner (portal pages only) -->
    <style is:global>
      .pwa-install-banner {
        position: fixed;
        left: 16px;
        right: 16px;
        bottom: 16px;
        z-index: 9999;
        display: flex;
        align-items: center;
        gap: 12px;
        background: #121212;
        color: #fafafa;
        border-radius: 12px;
        padding: 12px 14px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        font-family: var(--font-body, system-ui, sans-serif);
        font-size: 0.9rem;
        transform: translateY(120%);
        transition: transform 0.25s ease;
      }
      .pwa-install-banner.is-visible {
        transform: translateY(0);
      }
      .pwa-install-banner__text {
        flex: 1;
        line-height: 1.35;
      }
      .pwa-install-banner__btn {
        background: #D3191F;
        color: #fff;
        border: 0;
        border-radius: 8px;
        padding: 8px 12px;
        font-weight: 600;
        cursor: pointer;
        font-family: inherit;
        font-size: 0.85rem;
      }
      .pwa-install-banner__dismiss {
        background: transparent;
        color: #bdbdbd;
        border: 0;
        padding: 6px 8px;
        cursor: pointer;
        font-family: inherit;
        font-size: 0.85rem;
      }
      @media (min-width: 640px) {
        .pwa-install-banner {
          left: auto;
          right: 24px;
          bottom: 24px;
          max-width: 380px;
        }
      }
    </style>
    <script is:inline>
      (function () {
        var STORAGE_KEY = "rise-pwa-install-dismissed";
        var deferredPrompt = null;

        function onPortalPage() {
          return /^\/portal(\/|$)/.test(window.location.pathname);
        }
        function alreadyDismissed() {
          try { return window.localStorage.getItem(STORAGE_KEY) === "1"; }
          catch (e) { return false; }
        }
        function isStandalone() {
          return (
            window.matchMedia && window.matchMedia("(display-mode: standalone)").matches
          ) || window.navigator.standalone === true;
        }
        function tText(key, fallback) {
          try {
            if (window.__t && window.__t[key]) return window.__t[key];
          } catch (e) {}
          return fallback;
        }

        function showBanner() {
          if (!onPortalPage() || alreadyDismissed() || isStandalone()) return;
          if (document.getElementById("pwa-install-banner")) return;

          var banner = document.createElement("div");
          banner.id = "pwa-install-banner";
          banner.className = "pwa-install-banner";
          banner.setAttribute("role", "dialog");
          banner.setAttribute("aria-live", "polite");

          var text = document.createElement("div");
          text.className = "pwa-install-banner__text";
          text.textContent = tText("pwa.install.text", "Add RISE to your home screen");

          var installBtn = document.createElement("button");
          installBtn.type = "button";
          installBtn.className = "pwa-install-banner__btn";
          installBtn.textContent = tText("pwa.install.install", "Install");
          installBtn.addEventListener("click", async function () {
            if (!deferredPrompt) return;
            deferredPrompt.prompt();
            try { await deferredPrompt.userChoice; } catch (e) {}
            deferredPrompt = null;
            hideBanner(true);
          });

          var dismissBtn = document.createElement("button");
          dismissBtn.type = "button";
          dismissBtn.className = "pwa-install-banner__dismiss";
          dismissBtn.textContent = tText("pwa.install.dismiss", "Not now");
          dismissBtn.addEventListener("click", function () { hideBanner(true); });

          banner.appendChild(text);
          banner.appendChild(installBtn);
          banner.appendChild(dismissBtn);
          document.body.appendChild(banner);
          requestAnimationFrame(function () { banner.classList.add("is-visible"); });
        }

        function hideBanner(persist) {
          var banner = document.getElementById("pwa-install-banner");
          if (banner) {
            banner.classList.remove("is-visible");
            setTimeout(function () { if (banner.parentNode) banner.parentNode.removeChild(banner); }, 250);
          }
          if (persist) {
            try { window.localStorage.setItem(STORAGE_KEY, "1"); } catch (e) {}
          }
        }

        window.addEventListener("beforeinstallprompt", function (e) {
          e.preventDefault();
          deferredPrompt = e;
          showBanner();
        });

        window.addEventListener("appinstalled", function () {
          hideBanner(true);
          deferredPrompt = null;
        });
      })();
    </script>
  </body>
</html>
