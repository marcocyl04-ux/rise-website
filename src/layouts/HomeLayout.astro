---
// HomeLayout.astro — Dark theme layout for the homepage only
// Loads: Three.js, GSAP, homepage.css
import "../styles/global.css";
import "../styles/homepage.css";
import Loader from "../components/home/Loader.astro";
import HomeNav from "../components/home/HomeNav.astro";
import FloatingWhatsApp from "../components/FloatingWhatsApp.astro";
import AuthModal from "../components/AuthModal.astro";

export interface Props {
  title?: string;
  description?: string;
  lang?: string;
  ogImage?: string;
}

const {
  title = "RISE Advancement",
  description = "RISE Advancement: elite hockey training and player placement for Hong Kong youth. Summer program, mentoring, and full placement services to Canada.",
  lang = "en",
  ogImage = "/og-image.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, "https://riseadvancement.com");
const ogImageURL = new URL(ogImage, "https://riseadvancement.com");
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={`${title} | RISE Advancement`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:locale" content={lang === "zh" ? "zh_HK" : "en_US"} />
    <meta property="og:site_name" content="RISE Advancement" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | RISE Advancement`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png?v=2" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png?v=2" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />
    <link rel="icon" href="/favicon.ico" />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0a0a0a" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Oswald:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- External Libraries (defer = don't block first paint) -->
    <script defer src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollToPlugin.min.js"></script>

    <!-- JSON-LD Structured Data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SportsActivityLocation",
      "name": "RISE Advancement",
      "description": "Elite hockey player development and placement agency. We get young players from Hong Kong onto teams in Canada.",
      "url": "https://riseadvancement.com",
      "email": "riseadvancements@gmail.com",
      "telephone": "+852-9095-0387",
      "areaServed": ["Hong Kong", "Canada"],
      "sport": "Ice Hockey"
    })} />

    <title>{title} | RISE Advancement</title>
  </head>
  <body class="home-dark">
    <Loader />
    <HomeNav />

    <slot />

    <FloatingWhatsApp lang={lang} />
    <AuthModal />

    <!-- Supabase JS v2 (loaded at end, not blocking first paint) -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script is:inline define:vars={{
      SUPABASE_URL: "https://zeczlwypqqvvpraosodv.supabase.co",
      SUPABASE_ANON_KEY: "eyJhbG...V_KM"
    }}>
      (function () {
        if (window.supabaseClient) return;
        if (!window.supabase) return;
        window.supabaseClient = window.supabase.createClient(
          SUPABASE_URL,
          SUPABASE_ANON_KEY,
          { auth: { persistSession: true, autoRefreshToken: true, detectSessionInUrl: true } }
        );
      })();
    </script>
  </body>
</html>
